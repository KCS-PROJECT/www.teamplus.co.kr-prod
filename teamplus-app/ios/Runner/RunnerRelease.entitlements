<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Release/Profile(App Store·TestFlight 아카이브) 전용 entitlements.
	     Debug 는 Runner.entitlements(aps-environment=development)를 사용한다.
	     배포 빌드는 반드시 production APNs 로 서명되어야 한다(iOS 푸시·App Store 심사). -->
	<key>aps-environment</key>
	<string>production</string>
	<!-- Universal Links (딥링크 검증). AASA(/.well-known/apple-app-site-association)와 도메인 일치 필수.
	     Apple Developer 포털 App ID에 Associated Domains capability 활성화 + 각 도메인이 HTTPS로 AASA를 서빙해야 한다. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<!-- 2026-06-15: 레거시 app.teamplus.com 제거 (DNS 폐기 — AASA 서빙 불가). -->
		<string>applinks:teamplusweb.icetimes.co.kr</string>
	</array>
</dict>
</plist>
