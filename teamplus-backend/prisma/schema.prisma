model AppBanner {
  id                   String    @id @default(cuid())
  title                String
  imageUrl             String    @map("image_url") @db.Text
  linkUrl              String?   @map("link_url") @db.Text
  linkType             String    @default("none") @map("link_type") // none, internal, external
  targetRole           String?   @map("target_role") // all, PARENT, COACH, TEEN, CHILD
  targetRolesJson      Json      @default("[]") @map("target_roles_json") @db.JsonB
  displayLocationsJson Json      @default("[]") @map("display_locations_json") @db.JsonB // app_home, app_popup, web_home, web_popup 등
  sortOrder            Int       @default(0) @map("sort_order")
  isActive             Boolean   @default(true) @map("is_active")
  startAt              DateTime? @map("start_at")
  endAt                DateTime? @map("end_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([sortOrder])
  @@index([isActive, sortOrder])
  @@map("app_banners")
}

/// 앱 버전 - 강제 업데이트 관리
model AppVersion {
  id           String   @id @default(cuid())
  platform     String // ios, android
  version      String // 예: "1.2.3"
  minVersion   String   @map("min_version") // 강제 업데이트 최소 버전
  forceUpdate  Boolean  @default(false) @map("force_update")
  releaseNotes String?  @map("release_notes") @db.Text
  storeUrl     String?  @map("store_url") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([platform, version])
  @@index([platform, isActive])
  @@map("app_versions")
}

/// 앱 FAQ - 자주 묻는 질문
model AppFaq {
  id        String   @id @default(cuid())
  category  String // general, payment, class, club, etc.
  question  String   @db.Text
  answer    String   @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category, isActive])
  @@index([sortOrder])
  @@index([category, isActive, sortOrder])
  @@map("app_faqs")
}

/// 앱 피드백 - 사용자 의견/버그 신고
model AppFeedback {
  id           String    @id @default(cuid())
  userId       String?   @map("user_id") // 비로그인 허용
  category     String // bug, improvement, question, etc.
  content      String    @db.Text
  rating       Int? // 1-5 별점
  appVersion   String?   @map("app_version")
  platform     String? // ios, android, web
  status       String    @default("pending") // pending, reviewed, resolved
  adminNote    String?   @map("admin_note") @db.Text
  adminReplyAt DateTime? @map("admin_reply_at") /// 어드민 답변 시각 (사용자 알림 트리거용)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("app_feedbacks")
}

/// 앱 약관 - 이용약관/개인정보처리방침 등
model AppTerms {
  id          String    @id @default(cuid())
  type        String // terms_of_service, privacy_policy, marketing, etc.
  title       String
  content     String    @db.Text
  version     String // 예: "1.0.0"
  isActive    Boolean   @default(true) @map("is_active")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([type, isActive])
  @@index([publishedAt])
  @@map("app_terms")
}

/// 사용자 디바이스 - FCM 푸시 토큰 관리
model UserDevice {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  // [2026-06-20] 앱 발급·영속 디바이스 식별자(불투명 UUID). fcmToken(회전됨)과 독립.
  //   one-user-one-device 정책 B(한 물리 디바이스=활성 소유자 1명)의 안정 키.
  //   nullable — 구버전 앱(미전송)은 fcmToken fallback 경로 사용(하위호환).
  deviceId    String?  @map("device_id") @db.VarChar(255)
  fcmToken    String   @map("fcm_token") @db.VarChar(512) // FCM 토큰 최대 길이
  platform    String // ios, android
  deviceModel String?  @map("device_model")
  osVersion   String?  @map("os_version")
  appVersion  String?  @map("app_version")
  isActive    Boolean  @default(true) @map("is_active")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fcmToken])
  @@unique([userId, deviceId]) // [2026-06-20] 정책 A 키 — 같은 user의 같은 디바이스 = 1행
  @@index([userId, isActive])
  @@index([fcmToken])
  @@index([deviceId]) // [2026-06-20] 정책 B 조회·비활성화용
  @@index([deviceId, isActive]) // [2026-06-20] 정책 B 핵심 — deviceId별 active 탐색
  @@map("user_devices")
}

// ==================== Pickup Match (매치 마켓플레이스) ====================

/// 픽업 매치 - 참가자 모집형 친선 경기
model PickupMatch {
  id              String    @id @default(cuid())
  managerId       String    @map("manager_id") // 주최자 (User ID)
  title           String // 경기명
  scheduledAt     DateTime  @map("scheduled_at") // 경기 일시
  rinkName        String    @map("rink_name") // 링크 이름
  rinkAddress     String?   @map("rink_address") // 링크 주소
  rinkVenueInfo   String?   @map("rink_venue_info") // 상세 구역 (제2링크장 등)
  price           Int // 참가비 (원)
  level           String // 초급|중급|고급
  levelCode       String?   @map("level_code") // Level A|B|C
  gender          String    @default("혼성") // 남성|여성|혼성
  maxParticipants Int       @map("max_participants") // 최대 참가인원
  homeTeamName    String?   @map("home_team_name") // 홈팀 이름
  awayTeamName    String?   @map("away_team_name") // 어웨이팀 이름
  rules           Json      @default("[]") // 경기 규칙 배열
  description     String?   @db.Text // 추가 설명
  status          String    @default("recruiting") // recruiting|closing_soon|closed|cancelled
  isFeatured      Boolean   @default(false) @map("is_featured") // 추천 매치
  viewCount       Int       @default(0) @map("view_count") // 조회수 (1일 1회 증가, DailyViewLog UNIQUE 기반)
  cancelledAt     DateTime? @map("cancelled_at") // 매치 취소 시각
  cancelledReason String?   @map("cancelled_reason") // 매치 취소 사유 (관리자 입력)
  updatedByUserId String?   @map("updated_by_user_id") // 마지막 수정자 (감독/코치)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  manager    User                   @relation("ManagedPickupMatches", fields: [managerId], references: [id], onDelete: Cascade)
  updatedBy  User?                  @relation("MatchUpdater", fields: [updatedByUserId], references: [id])
  applicants PickupMatchApplicant[]

  @@index([managerId])
  @@index([scheduledAt])
  @@index([status])
  @@index([level])
  @@index([gender])
  @@index([status, scheduledAt]) // 목록 페이지 필터용
  @@index([viewCount]) // 인기 매치 정렬용
  @@map("pickup_matches")
}

/// 앱 전체 운영 설정 - 싱글턴 패턴 (레코드 1개만 유지)
model AppSettings {
  id String @id @default(cuid())

  // 기본 정보 (어드민 UI - 기본 정보 섹션)
  appName    String @default("TEAMPLUS") @map("app_name")
  appVersion String @default("1.0.0") @map("app_version")
  apiUrl     String @default("http://localhost:5003 ") @map("api_url")

  // 고객 지원 (어드민 UI - 고객 지원 섹션)
  supportEmail String  @default("admin@teamplus.com") @map("support_email")
  supportPhone String? @map("support_phone")
  supportHours String? @map("support_hours") // 고객센터 운영시간(예: 평일 09:00~18:00) — M4 화면 표시

  // 시스템 모드 (어드민 UI - 시스템 모드 섹션)
  maintenanceMode    Boolean @default(false) @map("maintenance_mode")
  maintenanceMessage String? @map("maintenance_message") @db.Text
  debugMode          Boolean @default(false) @map("debug_mode")

  // 서버 설정 (어드민 UI - 서버 설정 섹션)
  maxUploadSize  Int @default(10) @map("max_upload_size") // MB
  sessionTimeout Int @default(60) @map("session_timeout") // 분

  // 앱 버전 관리 (운영 전용)
  minimumAppVersionIos String  @default("1.0.0") @map("minimum_app_version_ios")
  minimumAppVersionAnd String  @default("1.0.0") @map("minimum_app_version_and")
  forceUpdateMessage   String? @map("force_update_message") @db.Text

  // 회원/인증 설정 (운영 전용)
  signupEnabled      Boolean @default(true) @map("signup_enabled")
  socialLoginEnabled Boolean @default(true) @map("social_login_enabled")
  maxLoginAttempts   Int     @default(5) @map("max_login_attempts")

  // 크레딧/QR 설정 (운영 전용)
  creditExpireDays Int @default(90) @map("credit_expire_days")
  qrExpireMinutes  Int @default(5) @map("qr_expire_minutes")

  // 약관 버전 (운영 전용)
  termsVersion   String @default("1.0") @map("terms_version")
  privacyVersion String @default("1.0") @map("privacy_version")

  // 정산 설정 (P-12, P-13 — 2026-05-21 추가)
  commissionRate Decimal @default(0.03) @map("commission_rate") @db.Decimal(5, 4) /// 플랫폼 수수료율 (0.0000 ~ 1.0000, 기본 0.03 = 3%)
  settlementDays Int[]   @default([10, 31]) @map("settlement_days") /// 정산 지급일 (월간, 31은 말일 의미. 예: [10, 31] = 매월 10일·말일)

  // 메타데이터
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

/// 부상 면책 동의서 저장 (C-09 — 2026-05-21 추가)
/// 가입 시 + 수업 등록 시 재확인용. termsVersion 으로 약관 버전 추적.
model LiabilityWaiver {
  id           String   @id @default(cuid())
  userId       String   @map("user_id") /// 동의자
  termsVersion String   @map("terms_version") /// 동의 시점 면책 약관 버전
  signedAt     DateTime @default(now()) @map("signed_at") /// 동의 시각
  ipAddress    String?  @map("ip_address") /// 동의 시 IP (법적 증거)
  userAgent    String?  @map("user_agent") @db.Text /// 동의 시 User-Agent
  context      String?  @map("context") /// 동의 맥락 (SIGNUP|CLASS_ENROLL|TOURNAMENT_REG 등)
  contextId    String?  @map("context_id") /// 맥락별 ID (수업/대회 등)
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, context])
  @@index([signedAt])
  @@map("liability_waivers")
}

/// 픽업 매치 신청자 - 매치 참가 신청 정보
model PickupMatchApplicant {
  id              String    @id @default(cuid())
  matchId         String    @map("match_id")
  userId          String    @map("user_id")
  position        String? // FW|MF|DF|GK
  level           String? // 초급|중급|고급
  paymentStatus   String    @default("pending") @map("payment_status") // paid|pending|refunded|refund_pending|refund_failed
  status          String    @default("pending") // pending|approved|rejected
  note            String?   @db.Text // 신청 메모
  rejectionReason String?   @map("rejection_reason") // 거절 사유 (감독/코치가 입력)
  rejectedAt      DateTime? @map("rejected_at") // 거절 시각
  refundedAt      DateTime? @map("refunded_at") // 환불 시각 (매치 취소 시 자동 설정)
  refundAmount    Int?      @map("refund_amount") // 환불 금액
  paymentId       String?   @map("payment_id") // 결제 완료 시 연결되는 Payment ID (KG이니시스 환불용)
  appliedAt       DateTime  @default(now()) @map("applied_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  match   PickupMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user    User        @relation("PickupMatchApplications", fields: [userId], references: [id], onDelete: Cascade)
  payment Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([paymentId])
  @@map("pickup_match_applicants")
}

// ==================== Player Class History & Awards (수업 이력 · 수상 기록) ====================

/// 선수 수업 이력 - 수업 참여 이력 및 이수 기록 (포트폴리오)
model PlayerClassHistory {
  id               String    @id @default(cuid())
  memberId         String    @map("member_id") /// TeamMember ID
  classId          String    @map("class_id")
  enrollmentId     String?   @unique @map("enrollment_id") /// 수강신청 연결 (1:1)
  startDate        DateTime  @map("start_date") /// 수업 시작일
  endDate          DateTime? @map("end_date") /// 수업 종료일
  totalSessions    Int       @default(0) @map("total_sessions") /// 총 수업 횟수
  attendedSessions Int       @default(0) @map("attended_sessions") /// 출석 횟수
  attendanceRate   Int       @default(0) @map("attendance_rate") /// 출석률 (0-100%)
  status           String    @default("active") /// active|completed|withdrawn|suspended
  coachComment     String?   @map("coach_comment") @db.Text /// 코치 총평
  finalScore       Int?      @map("final_score") /// 최종 평가 점수 (1-100)
  certificateUrl   String?   @map("certificate_url") @db.Text /// 수료증 URL
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  member     TeamMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  class      Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@unique([memberId, classId])
  @@index([memberId])
  @@index([classId])
  @@index([status])
  @@index([startDate])
  @@index([memberId, status])
  @@map("player_class_histories")
}

/// 개인 수상 기록 - 선수 개인 수상/성취 기록
model PlayerAward {
  id             String   @id @default(cuid())
  memberId       String   @map("member_id") /// TeamMember ID
  awardName      String   @map("award_name") /// 수상명
  awardType      String   @map("award_type") /// mvp|best_scorer|best_goalie|most_improved|sportsmanship|skill|attendance|special
  description    String?  @db.Text /// 수상 설명
  awardedAt      DateTime @map("awarded_at") /// 수상일
  tournamentId   String?  @map("tournament_id") /// 대회 관련 (optional)
  matchId        String?  @map("match_id") /// 경기 관련 (optional)
  season         String? /// 시즌 (예: "2025-2026")
  awardedBy      String?  @map("awarded_by") /// 수여자 이름 또는 기관명
  certificateUrl String?  @map("certificate_url") @db.Text /// 수상 증서 URL
  imageUrl       String?  @map("image_url") @db.Text /// 수상 사진 URL
  isDisplayed    Boolean  @default(true) @map("is_displayed") /// 프로필 표시 여부
  displayOrder   Int      @default(0) @map("display_order") /// 표시 순서
  createdAt      DateTime @default(now()) @map("created_at")

  member     TeamMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tournament Tournament?  @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  match      HockeyMatch? @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([awardType])
  @@index([awardedAt])
  @@index([tournamentId])
  @@index([season])
  @@index([isDisplayed])
  @@index([memberId, isDisplayed])
  @@map("player_awards")
}

/// 팀 수상 기록 - 팀 단위 수상/성취 기록
model TeamAward {
  id             String   @id @default(cuid())
  teamId         String   @map("team_id")
  awardName      String   @map("award_name") /// 수상명
  awardType      String   @map("award_type") /// champion|runner_up|third_place|league_winner|fair_play|best_team|special
  description    String?  @db.Text /// 수상 설명
  awardedAt      DateTime @map("awarded_at") /// 수상일
  tournamentId   String?  @map("tournament_id") /// 대회 관련 (optional)
  season         String? /// 시즌 (예: "2025-2026")
  awardedBy      String?  @map("awarded_by") /// 수여 기관/단체명
  certificateUrl String?  @map("certificate_url") @db.Text /// 수상 증서 URL
  imageUrl       String?  @map("image_url") @db.Text /// 수상 사진 URL
  createdAt      DateTime @default(now()) @map("created_at")

  // Phase 4 rename 완료. teamId 는 teams.id 를 가리킴
  team       Team        @relation("TeamAwardsTeam", fields: [teamId], references: [id], onDelete: Cascade)
  tournament Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([awardType])
  @@index([awardedAt])
  @@index([tournamentId])
  @@index([season])
  @@map("team_awards")
}

// ==================== 경력 관리 (Career) ====================

/// 선수 경력 - CHILD/TEEN 선수의 이전 팀·포지션·활동 이력 (리스트)
model PlayerCareer {
  id           String    @id @default(cuid())
  memberId     String    @map("member_id") /// TeamMember ID
  teamName     String    @map("team_name") /// 소속 팀명 (현재/이전)
  position     String? /// 포지션 (goalie|center|left_wing|right_wing|defense)
  jerseyNumber Int?      @map("jersey_number") /// 등번호
  leagueName   String?   @map("league_name") /// 리그/대회명
  startDate    DateTime  @map("start_date") /// 활동 시작일
  endDate      DateTime? @map("end_date") /// 활동 종료일 (null=현재)
  isCurrent    Boolean   @default(false) @map("is_current") /// 현재 소속 여부
  description  String?   @db.Text /// 활동 내용·특이사항
  displayOrder Int       @default(0) @map("display_order") /// 표시 순서
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([isCurrent])
  @@index([startDate])
  @@index([memberId, isCurrent])
  @@map("player_careers")
}

/// 스태프 경력 - DIRECTOR/COACH 등 지도자·운영진의 경력 이력 (리스트)
model StaffCareer {
  id               String    @id @default(cuid())
  userId           String    @map("user_id") /// User ID (DIRECTOR/COACH/ADMIN)
  role             String?   /// 역할 (head_coach|assistant_coach|goalie_coach|director|manager|trainer|referee|analyst)
  organizationName String?   @map("organization_name") /// 소속 기관/클럽명
  leagueName       String?   @map("league_name") /// 리그명
  startDate        DateTime? @map("start_date") /// 경력 시작일
  endDate          DateTime? @map("end_date") /// 경력 종료일 (null=현재)
  isCurrent        Boolean   @default(false) @map("is_current") /// 현재 재직 여부
  description      String?   @db.Text /// 주요 업무·성과
  certifications   String?   @db.Text /// 보유 자격증 (JSON 배열)
  displayOrder     Int       @default(0) @map("display_order") /// 표시 순서
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([role])
  @@index([isCurrent])
  @@index([startDate])
  @@index([userId, isCurrent])
  @@map("staff_careers")
}

// ==================== 푸시 알림 발송 이력 ====================

/// 푸시 알림 발송 이력 - 관리자 발송 Push 로그
model PushNotificationLog {
  id           String   @id @default(cuid())
  title        String // 알림 제목
  body         String   @db.Text // 알림 본문
  targetType   String   @map("target_type") // all|role|specific
  targetValue  String?  @map("target_value") @db.Text // 역할명 또는 특정 사용자 ID 목록 (JSON)
  sentBy       String   @map("sent_by") // 발송한 관리자 User.id
  sentAt       DateTime @default(now()) @map("sent_at")
  totalCount   Int      @default(0) @map("total_count") // 발송 대상 수
  successCount Int      @default(0) @map("success_count") // 성공 수
  failCount    Int      @default(0) @map("fail_count") // 실패 수
  status       String   @default("pending") // pending|sent|failed|partial
  metadata     String?  @db.Text // 추가 데이터 (JSON)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([targetType])
  @@index([status])
  @@index([sentBy])
  @@index([sentAt])
  @@map("push_notification_logs")
}

// ==================== Venue Scheduling (대관 관리) ====================

/// 훈련 유형
enum TrainingType {
  LESSON /// 레슨 (1:1/소그룹 코칭)
  REGULAR_TRAINING /// 정규훈련 (팀 연습)
  REGULAR_CLASS /// 정규수업 (구조화된 수업)
  GROUP_CLASS /// 그룹수업 (그룹 레슨)
  GAME /// 시합 (경기)
  FUN /// 펀하키 (레크리에이션)
  CAMP /// 캠프 (다일 행사)
  PICKUP /// 픽업 게임
}

/// 대관 시간대 - 빙상장 시간별 슬롯 관리
model VenueTimeSlot {
  id        String   @id @default(cuid())
  venueId   String   @map("venue_id")
  date      DateTime @db.Date
  startTime String   @map("start_time") // "06:00" 형식
  endTime   String   @map("end_time") // "07:00" 형식
  slotType  String   @default("open") @map("slot_type") // open|reserved|maintenance|event|pt
  status    String   @default("available") // available|booked|blocked
  price     Decimal? @db.Decimal(10, 2)
  memo      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  venue    Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  bookings VenueBooking[]

  @@unique([venueId, date, startTime])
  @@index([venueId])
  @@index([date])
  @@index([status])
  @@index([slotType])
  @@map("venue_time_slots")
}

/// 대관 예약 - 빙상장 시간대 예약
model VenueBooking {
  id           String   @id @default(cuid())
  venueId      String   @map("venue_id")
  timeSlotId   String?  @map("time_slot_id")
  teamId       String?  @map("team_id")
  contractId   String?  @map("contract_id")
  scheduleId   String?  @map("schedule_id")
  bookedById   String   @map("booked_by_id") // User ID
  date         DateTime @db.Date
  startTime    String   @map("start_time")
  endTime      String   @map("end_time")
  purpose      String? // training|match|lesson|event|rental|pt
  totalPrice   Decimal? @map("total_price") @db.Decimal(10, 2)
  status       String   @default("pending") // pending|confirmed|cancelled|completed
  cancelReason String?  @map("cancel_reason")
  memo         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  venue    Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  timeSlot VenueTimeSlot?       @relation(fields: [timeSlotId], references: [id], onDelete: SetNull)
  team     Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  contract VenueRentalContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  schedule VenueRentalSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  bookedBy User                 @relation(fields: [bookedById], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([teamId])
  @@index([contractId])
  @@index([scheduleId])
  @@index([bookedById])
  @@index([date])
  @@index([status])
  @@index([venueId, date])
  @@map("venue_bookings")
}

/// 대관 계약 - 팀과 빙상장 간 정기 대관 계약
model VenueRentalContract {
  id            String    @id @default(cuid())
  teamId        String    @map("team_id")
  venueId       String    @map("venue_id")
  title         String // e.g., "2026년 3월 인천 대관 계약"
  contractType  String    @default("monthly") @map("contract_type") // monthly|quarterly|yearly|custom
  startDate     DateTime  @map("start_date") @db.Date
  endDate       DateTime  @map("end_date") @db.Date
  monthlyFee    Decimal?  @map("monthly_fee") @db.Decimal(10, 2)
  totalAmount   Decimal?  @map("total_amount") @db.Decimal(10, 2)
  depositAmount Decimal?  @map("deposit_amount") @db.Decimal(10, 2)
  status        String    @default("draft") // draft|active|expired|cancelled|pending_renewal
  signedAt      DateTime? @map("signed_at")
  memo          String?
  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  team      Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  venue     Venue                 @relation(fields: [venueId], references: [id], onDelete: Cascade)
  createdBy User                  @relation(fields: [createdById], references: [id], onDelete: Cascade)
  schedules VenueRentalSchedule[]
  bookings  VenueBooking[]

  @@index([teamId])
  @@index([venueId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@map("venue_rental_contracts")
}

/// 대관 반복 스케줄 - 매주 같은 요일/시간 대관 패턴 (예: 매주 월 20:10~22:00 정규훈련)
model VenueRentalSchedule {
  id              String       @id @default(cuid())
  contractId      String       @map("contract_id")
  venueId         String       @map("venue_id")
  teamId          String       @map("team_id")
  title           String // e.g., "월요일 정규훈련", "수요일 레슨"
  trainingType    TrainingType @default(REGULAR_TRAINING) @map("training_type")
  dayOfWeek       Int          @map("day_of_week") // 0=SUN, 1=MON, 2=TUE, ..., 6=SAT
  startTime       String       @map("start_time") // "20:10"
  endTime         String       @map("end_time") // "22:00"
  pricePerSession Decimal?     @map("price_per_session") @db.Decimal(10, 2)
  colorCode       String?      @map("color_code") // "#16A34A" 캘린더 표시 색상
  isActive        Boolean      @default(true) @map("is_active")
  memo            String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  contract VenueRentalContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  venue    Venue               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  team     Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  bookings VenueBooking[]

  @@index([contractId])
  @@index([venueId])
  @@index([teamId])
  @@index([dayOfWeek])
  @@index([isActive])
  @@map("venue_rental_schedules")
}

/// 빙상장 휴무 - 특정 날짜 휴무/정비/행사 (예: 졸업행사, 정기정비)
model VenueHoliday {
  id        String   @id @default(cuid())
  venueId   String   @map("venue_id")
  date      DateTime @db.Date
  reason    String // "정기휴무", "정비", "졸업행사", "대회" 등
  type      String   @default("holiday") // holiday|maintenance|event|custom
  isAllDay  Boolean  @default(true) @map("is_all_day")
  startTime String?  @map("start_time") // 부분 휴무 시
  endTime   String?  @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, date])
  @@index([venueId])
  @@index([date])
  @@index([type])
  @@map("venue_holidays")
}

// ==================== Camp (캠프 관리) ====================

/// 캠프 - 다일 행사 (여름캠프, 봄캠프 등)
model Camp {
  id            String   @id @default(cuid())
  teamId        String   @map("team_id")
  name          String // e.g., "2015 루비덕스 여름캠프"
  description   String?  @db.Text
  venueId       String?  @map("venue_id")
  startDate     DateTime @map("start_date")
  endDate       DateTime @map("end_date")
  maxCapacity   Int?     @map("max_capacity")
  price         Decimal? @db.Decimal(10, 2)
  accommodation String? // 숙박 정보 (숙소명, 주소 등)
  address       String? // 캠프 장소 주소
  status        String   @default("planned") // planned|open|full|ongoing|completed|cancelled
  imageUrl      String?  @map("image_url") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  team          Team               @relation(fields: [teamId], references: [id])
  venue         Venue?             @relation(fields: [venueId], references: [id])
  registrations CampRegistration[]

  @@index([teamId])
  @@index([startDate])
  @@index([status])
  @@map("camps")
}

/// 캠프 등록 - 캠프 참가 신청
model CampRegistration {
  id          String    @id @default(cuid())
  campId      String    @map("camp_id")
  memberId    String    @map("member_id") // TeamMember ID
  status      String    @default("pending") // pending|approved|rejected|cancelled
  paidAmount  Decimal?  @map("paid_amount") @db.Decimal(10, 2)
  paymentId   String?   @map("payment_id")
  memo        String?
  appliedAt   DateTime  @default(now()) @map("applied_at")
  respondedAt DateTime? @map("responded_at")

  camp   Camp       @relation(fields: [campId], references: [id])
  member TeamMember @relation(fields: [memberId], references: [id])

  @@unique([campId, memberId])
  @@index([campId])
  @@index([memberId])
  @@index([status])
  @@map("camp_registrations")
}

// ==================== Lesson Package (레슨 패키지) ====================

/// 레슨 패키지 - 고정 레슨 묶음 상품 (3회/4회 등)
model LessonPackage {
  id            String    @id @default(cuid())
  teamId        String?   @map("team_id")
  name          String // e.g., "펀블랙", "펀실화", "펀모닝"
  description   String?   @db.Text
  trainingType  String    @map("training_type") // lesson|regular|group|fun
  venueId       String?   @map("venue_id")
  totalSessions Int       @map("total_sessions") // 3, 4 etc
  price         Decimal   @db.Decimal(10, 2)
  dayOfWeek     String?   @map("day_of_week") // MON|TUE|WED|THU|FRI|SAT|SUN
  startTime     String?   @map("start_time")
  endTime       String?   @map("end_time")
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  sessionDates  Json?     @map("session_dates") @db.JsonB // 개별 세션 날짜 배열 [16,23,30]
  maxCapacity   Int?      @map("max_capacity")
  status        String    @default("open") // open|full|closed|completed
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  team        Team?                     @relation(fields: [teamId], references: [id])
  venue       Venue?                    @relation(fields: [venueId], references: [id])
  enrollments LessonPackageEnrollment[]

  @@index([teamId])
  @@index([status])
  @@index([trainingType])
  @@map("lesson_packages")
}

/// 레슨 패키지 등록 - 레슨 패키지 수강 등록
model LessonPackageEnrollment {
  id            String    @id @default(cuid())
  packageId     String    @map("package_id")
  memberId      String    @map("member_id") // TeamMember ID
  status        String    @default("enrolled") // enrolled|completed|cancelled|refunded
  attendedCount Int       @default(0) @map("attended_count")
  paidAmount    Decimal?  @map("paid_amount") @db.Decimal(10, 2)
  paymentId     String?   @map("payment_id")
  enrolledAt    DateTime  @default(now()) @map("enrolled_at")
  completedAt   DateTime? @map("completed_at")

  package LessonPackage @relation(fields: [packageId], references: [id])
  member  TeamMember    @relation(fields: [memberId], references: [id])

  @@unique([packageId, memberId])
  @@index([packageId])
  @@index([memberId])
  @@index([status])
  @@map("lesson_package_enrollments")
}

// ==================== Game Expense (경기 비용) ====================

/// 경기 비용 - 대회/경기 관련 비용 관리
model GameExpense {
  id           String   @id @default(cuid())
  matchId      String?  @map("match_id")
  tournamentId String?  @map("tournament_id")
  teamId       String   @map("team_id")
  category     String // participation_fee|bus_rental|accommodation|meal|equipment|referee|ice_rental|other
  description  String?
  amount       Decimal  @db.Decimal(10, 2)
  paidById     String?  @map("paid_by_id") // User ID
  receiptUrl   String?  @map("receipt_url")
  status       String   @default("pending") // pending|approved|paid|rejected
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  match      HockeyMatch? @relation(fields: [matchId], references: [id])
  tournament Tournament?  @relation(fields: [tournamentId], references: [id])
  team       Team         @relation(fields: [teamId], references: [id])

  @@index([matchId])
  @@index([tournamentId])
  @@index([teamId])
  @@index([category])
  @@index([status])
  @@map("game_expenses")
}

// ==================== Common Code (공통코드) ====================

/// 공통코드 그룹 - 코드 분류 마스터 (예: TRAINING_TYPE, EXPENSE_TYPE, VENUE_SLOT_TYPE)
model CommonCodeGroup {
  id          String   @id @default(cuid())
  groupCode   String   @unique @map("group_code") /// 그룹코드 (예: TRAINING_TYPE)
  groupName   String   @map("group_name") /// 그룹명 (예: "훈련유형")
  description String? /// 설명
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdById String   @map("created_by_id")
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User         @relation("CodeGroupCreator", fields: [createdById], references: [id])
  updatedBy User?        @relation("CodeGroupUpdater", fields: [updatedById], references: [id])
  codes     CommonCode[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("common_code_groups")
}

/// 공통코드 - 실제 코드값 (자기참조로 대/중/소/세부 4단계 계층 구현)
model CommonCode {
  id          String   @id @default(cuid())
  groupId     String   @map("group_id")
  parentId    String?  @map("parent_id") /// 상위 코드 (null이면 최상위=대분류)
  level       Int      @default(1) /// 1=대 / 2=중 / 3=소 / 4=세부
  code        String /// 코드값 (예: LESSON, PRIVATE, SKATING)
  name        String /// 코드명 (예: "레슨", "개인레슨", "스케이팅")
  description String? /// 설명
  value1      String? /// 부가값1 (색상, 아이콘 등)
  value2      String? /// 부가값2 (단가, 단위 등)
  value3      String? /// 부가값3
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdById String   @map("created_by_id")
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  group     CommonCodeGroup @relation(fields: [groupId], references: [id])
  parent    CommonCode?     @relation("CodeHierarchy", fields: [parentId], references: [id])
  children  CommonCode[]    @relation("CodeHierarchy")
  createdBy User            @relation("CodeCreator", fields: [createdById], references: [id])
  updatedBy User?           @relation("CodeUpdater", fields: [updatedById], references: [id])

  @@unique([groupId, code])
  @@index([groupId])
  @@index([parentId])
  @@index([level])
  @@index([isActive])
  @@index([sortOrder])
  @@map("common_codes")
}

// ==================== RSVP (참석/불참 사전응답) ====================

/// RSVP - 수업 일정 참석/불참 사전응답
/// 감독/코치가 훈련 등록 시 소속 회원 전원에 PENDING 자동 생성
/// RSVP 마감: 수업 시작 24시간 전 (rsvpDeadline 우선, null이면 자동 계산)
model ClassRsvp {
  id          String    @id @default(cuid())
  scheduleId  String    @map("schedule_id") /// 수업 일정 ID
  userId      String    @map("user_id") /// 응답자 User ID (학부모 또는 학생 본인)
  childId     String?   @map("child_id") /// 자녀 User ID (학부모가 자녀 대신 응답 시)
  status      String    @default("PENDING") /// PENDING | ATTENDING | DECLINED
  respondedAt DateTime? @map("responded_at") /// 응답 일시
  note        String? /// 불참 사유 등 메모
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relationships
  schedule ClassSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User          @relation("RsvpUser", fields: [userId], references: [id], onDelete: Cascade)
  child    User?         @relation("RsvpChild", fields: [childId], references: [id], onDelete: SetNull)

  @@unique([scheduleId, userId, childId])
  @@index([scheduleId, status])
  @@index([userId])
  @@index([childId])
  @@index([status])
  @@map("class_rsvps")
}

// ==================== 해외 원정 (Overseas Trips) ====================

/// 해외 원정 - 팀 해외 원정 대회/훈련 정보
model OverseasTrip {
  id                   String    @id @default(cuid())
  teamId               String    @map("team_id")
  title                String /// 원정 제목
  country              String /// 국가 (ISO 코드 또는 한글명)
  city                 String /// 도시
  description          String?   @db.Text /// 원정 상세 설명
  startDate            DateTime  @map("start_date") /// 원정 시작일
  endDate              DateTime  @map("end_date") /// 원정 종료일
  registrationDeadline DateTime  @map("registration_deadline") /// 참가 등록 마감일
  maxParticipants      Int       @map("max_participants") /// 최대 참가 인원
  ageGroup             String?   @map("age_group") /// 대상 연령대 (예: "16년생", "15-16년생")
  estimatedCost        Decimal?  @default(0) @map("estimated_cost") @db.Decimal(10, 2) /// 예상 총비용
  depositAmount        Decimal?  @default(0) @map("deposit_amount") @db.Decimal(10, 2) /// 예치금
  depositDeadline      DateTime? @map("deposit_deadline") /// 예치금 납부 마감일
  flightInfo           String?   @map("flight_info") /// 항공 정보
  hotelInfo            String?   @map("hotel_info") /// 숙소 정보
  transportInfo        String?   @map("transport_info") /// 현지 교통 정보
  itinerary            String?   @db.Text /// 상세 일정표
  status               String    @default("draft") /// draft | open | closed | ongoing | completed | cancelled
  contactPhone         String?   @map("contact_phone") /// 연락처 전화번호
  contactEmail         String?   @map("contact_email") /// 연락처 이메일
  createdById          String    @map("created_by_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relationships
  team          Team                       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy     User                       @relation("OverseasTripCreator", fields: [createdById], references: [id], onDelete: Cascade)
  registrations OverseasTripRegistration[]

  @@index([teamId])
  @@index([status])
  @@index([startDate])
  @@index([registrationDeadline])
  @@index([createdById])
  @@map("overseas_trips")
}

/// 해외 원정 참가 등록 - 회원의 원정 참가 신청 및 예치금 관리
model OverseasTripRegistration {
  id                  String    @id @default(cuid())
  tripId              String    @map("trip_id")
  memberId            String    @map("member_id")
  childId             String?   @map("child_id") /// 자녀 User ID (학부모가 자녀 대신 등록 시)
  parentId            String    @map("parent_id") /// 학부모 User ID
  status              String    @default("pending") /// pending | confirmed | deposit_paid | cancelled | waitlisted
  depositPaidAt       DateTime? @map("deposit_paid_at") /// 예치금 납부 일시
  depositAmount       Decimal?  @map("deposit_amount") @db.Decimal(10, 2) /// 실제 납부 예치금
  passportVerified    Boolean   @default(false) @map("passport_verified") /// 여권 확인 여부
  passportExpiryDate  DateTime? @map("passport_expiry_date") /// 여권 만료일
  specialRequirements String?   @map("special_requirements") /// 특이사항 (알레르기, 약물 등)
  emergencyContact    String?   @map("emergency_contact") /// 비상 연락처 이름
  emergencyPhone      String?   @map("emergency_phone") /// 비상 연락처 번호
  cancelReason        String?   @map("cancel_reason") /// 취소 사유
  cancelledAt         DateTime? @map("cancelled_at") /// 취소 일시
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relationships
  trip   OverseasTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  member TeamMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  child  User?        @relation("TripChild", fields: [childId], references: [id], onDelete: SetNull)
  parent User         @relation("TripParent", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([tripId, memberId])
  @@index([tripId])
  @@index([memberId])
  @@index([parentId])
  @@index([status])
  @@map("overseas_trip_registrations")
}

// ==================== League / Division System ====================

/// 리그 - i-League, 스포츠클럽 디비전리그 등 리그 정보
model League {
  id          String    @id @default(cuid())
  name        String /// 리그명 (예: "2026 유청소년 클럽리그(i-League)")
  season      String /// 시즌 (예: "2026")
  year        Int /// 연도
  description String?   @db.Text
  ageGroup    String?   @map("age_group") /// 연령 구분: U9 | U12 | U15 | U18
  region      String? /// 지역: 중부권 | 남부권 | null(전국)
  status      String    @default("draft") /// draft | active | completed
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  teamId      String?   @map("team_id") /// 주최 팀 (선택)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  team      Team?      @relation(fields: [teamId], references: [id], onDelete: SetNull)
  divisions Division[]

  @@index([season])
  @@index([ageGroup])
  @@index([status])
  @@index([teamId])
  @@index([year])
  @@map("leagues")
}

/// 디비전 - 리그 내 디비전 (DIV 1 ~ DIV 6, 중부권, 남부권 등)
model Division {
  id          String   @id @default(cuid())
  leagueId    String   @map("league_id")
  name        String /// 디비전명 (예: "DIV 1", "중부권")
  level       Int      @default(1) /// 레벨 (1~6, 낮을수록 상위)
  description String?
  maxTeams    Int?     @map("max_teams") /// 최대 팀 수
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  league            League            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teamDivisions     TeamDivision[]
  tournamentMatches TournamentMatch[]

  @@index([leagueId])
  @@index([level])
  @@index([sortOrder])
  @@map("divisions")
}

/// 팀-디비전 매핑 - 시즌별 팀의 디비전 편성 이력
model TeamDivision {
  id           String   @id @default(cuid())
  teamId       String   @map("team_id")
  divisionId   String   @map("division_id")
  season       String /// 시즌 (예: "2026")
  registeredAt DateTime @default(now()) @map("registered_at")
  status       String   @default("active") /// active | withdrawn | disqualified
  seed         Int? /// 시드 순위
  wins         Int      @default(0)
  losses       Int      @default(0)
  draws        Int      @default(0)
  points       Int      @default(0) /// 승점 (승3, 무1, 패0 등 리그 규정에 따라)

  // Phase 4 rename 완료. teamId 는 teams.id 를 가리킴
  team     Team     @relation("TeamDivisionsTeam", fields: [teamId], references: [id], onDelete: Cascade)
  division Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  @@unique([teamId, divisionId, season])
  @@index([divisionId])
  @@index([season])
  @@index([status])
  @@map("team_divisions")
}

/// 대회 경기 일정 - 리그/대회 상세 경기 일정 (홈/어웨이, 장소, 시간)
model TournamentMatch {
  id           String   @id @default(cuid())
  tournamentId String   @map("tournament_id")
  divisionId   String?  @map("division_id")
  homeTeamId   String   @map("home_team_id")
  awayTeamId   String   @map("away_team_id")
  matchDate    DateTime @map("match_date")
  startTime    String?  @map("start_time") /// HH:MM 형식 (예: "09:30")
  endTime      String?  @map("end_time") /// HH:MM 형식 (예: "10:45")
  venueId      String?  @map("venue_id")
  round        String? /// group | quarter | semi | third | final
  status       String   @default("scheduled") /// scheduled | ongoing | completed | cancelled
  homeScore    Int?     @map("home_score")
  awayScore    Int?     @map("away_score")
  period       String? /// 기간/카테고리 표시 (예: "U12 DIV 2")
  referee      String? /// 심판
  memo         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  division   Division?  @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  // Phase 4 rename 완료. home_team_id / away_team_id 는 teams.id 를 가리킴
  homeTeam   Team       @relation("TournamentHomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam   Team       @relation("TournamentAwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  venue      Venue?     @relation(fields: [venueId], references: [id], onDelete: SetNull)

  @@index([tournamentId, matchDate])
  @@index([divisionId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([venueId])
  @@index([status])
  @@index([matchDate])
  @@map("tournament_matches")
}

// ==================== TMS (Task Management System) ====================

/// TMS 게시판 - 외부 수정사항/요청사항 관리
model TmsPost {
  id          String    @id @default(cuid())
  title       String /// 제목
  content     String    @db.Text /// 상세 내용 (HTML/텍스트)
  platform    String    @default("web") /// web | app | admin | backend | other
  category    String    @default("bug") /// bug | feature | improvement | design | other
  priority    String    @default("medium") /// low | medium | high | critical
  status      String    @default("todo") /// todo | in_progress | review | done | rejected
  authorName  String    @map("author_name") /// 작성자 이름 (외부 인원 — User FK 없음)
  authorEmail String?   @map("author_email") /// 작성자 이메일 (선택)
  assignee    String? /// 담당자 이름 (자유 입력)
  dueDate     DateTime? @map("due_date") @db.Date /// 마감일
  viewCount   Int       @default(0) @map("view_count")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  attachments TmsAttachment[]
  comments    TmsComment[]

  @@index([platform])
  @@index([category])
  @@index([status])
  @@index([priority])
  @@index([isActive])
  @@index([createdAt])
  @@map("tms_posts")
}

/// TMS 첨부파일 - 이미지/파일 업로드
model TmsAttachment {
  id           String   @id @default(cuid())
  postId       String?  @map("post_id") /// null = 아직 게시글에 연결 안 됨 (업로드 직후)
  fileUrl      String   @map("file_url") @db.Text /// 파일 경로 (로컬/S3)
  fileName     String   @map("file_name")
  fileType     String   @map("file_type") /// image/png, image/jpeg 등
  fileSize     Int      @map("file_size") /// bytes
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  post TmsPost? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("tms_attachments")
}

/// TMS 댓글 - 수정사항에 대한 피드백/진행상황 기록
model TmsComment {
  id         String   @id @default(cuid())
  postId     String   @map("post_id")
  authorName String   @map("author_name") /// 댓글 작성자 이름
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  post TmsPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("tms_comments")
}

/// 소셜 로그인 계정 연동
/// 한 명의 사용자가 여러 소셜 계정을 연결할 수 있음
model SocialAccount {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  provider          String /// kakao | google | apple
  socialId          String   @map("social_id") /// 소셜 서비스의 고유 사용자 ID
  email             String? /// 소셜 계정 이메일 (있는 경우)
  name              String? /// 소셜 계정 이름
  profileImage      String?  @map("profile_image") /// 프로필 이미지 URL
  /// Apple Sign in with Apple refresh token. 계정 삭제(탈퇴) 시 appleid.apple.com/auth/revoke 호출에 사용 (iOS 5.1.1(v) 필수).
  /// authorizationCode 를 /auth/token 으로 교환해 획득. kakao/google 은 사용하지 않음(null).
  appleRefreshToken String?  @map("apple_refresh_token")
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, socialId])
  @@index([userId])
  @@map("social_accounts")
}

// ==================== Videos ====================

/// 영상 관리 - 경기/훈련 영상 업로드 및 관리
model Video {
  id           String   @id @default(cuid())
  uploaderId   String   @map("uploader_id")
  teamId       String?  @map("team_id")
  title        String
  description  String?  @db.Text
  videoUrl     String   @map("video_url") @db.Text /// 파일 경로 또는 외부 URL
  thumbnailUrl String?  @map("thumbnail_url") @db.Text
  duration     Int? /// 초 단위
  fileSize     Int?     @map("file_size") /// bytes
  mimeType     String?  @map("mime_type")
  videoType    String   @default("training") @map("video_type") /// training|match|highlight|other
  tournamentId String?  @map("tournament_id")
  matchId      String?  @map("match_id")
  classId      String?  @map("class_id")
  isPublic     Boolean  @default(false) @map("is_public")
  viewCount    Int      @default(0) @map("view_count")
  status       String   @default("processing") /// processing|ready|failed
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  uploader   User        @relation("VideoUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  team       Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  tournament Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  @@index([uploaderId])
  @@index([teamId])
  @@index([videoType])
  @@index([status])
  @@index([createdAt])
  @@map("videos")
}

// ==================== Academy (아카데미/학원) ====================

/// 아카데미 - 독립 학원 조직 (클럽과 대등한 단위)
/// 클럽 감독과 별개로, 아카데미 감독이 독립적으로 레슨을 운영
/// 한 아카데미 감독이 200~300명의 수강생을 관리
model Academy {
  id           String   @id @default(cuid())
  directorId   String   @map("director_id") /// 아카데미 감독 (ACADEMY_DIRECTOR)
  name         String /// 아카데미 이름 (예: "블랙아이스 아카데미")
  code         String   @unique /// 아카데미 고유 코드 (팀 코드와 별개 체계)
  description  String?  @db.Text /// 소개글
  region       String? /// 지역 (예: "인천", "안양")
  contactPhone String?  @map("contact_phone")
  contactEmail String?  @map("contact_email")
  imageUrl     String?  @map("image_url") @db.Text /// 대표 이미지
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relationships
  director   User               @relation("AcademyDirector", fields: [directorId], references: [id])
  classes    Class[] /// 아카데미 수업 목록
  members    AcademyMember[] /// 수강생 목록
  coaches    AcademyCoach[] /// 소속 코치 목록
  promotions AcademyPromotion[] /// 홍보 게시물

  @@index([directorId])
  @@index([isActive])
  @@index([region])
  @@map("academies")
}

/// 아카데미 수강생 - 아카데미에 등록된 학부모/선수 (TeamMember의 아카데미 버전)
/// 클럽 회원이 아닌 독립 수강생도 아카데미 레슨 이용 가능
model AcademyMember {
  id        String    @id @default(cuid())
  academyId String    @map("academy_id")
  userId    String    @map("user_id") /// 학부모 또는 성인 선수
  childId   String?   @map("child_id") /// 자녀 (선택)
  status    String    @default("PENDING") /// PENDING|ACTIVE|INACTIVE|BLOCKED
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relationships
  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user    User    @relation("AcademyMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  child   User?   @relation("AcademyMemberChild", fields: [childId], references: [id], onDelete: SetNull)

  @@unique([academyId, userId, childId])
  @@index([academyId, status])
  @@index([userId])
  @@map("academy_members")
}

/// 아카데미 코치 - 아카데미 소속 코치 관리
/// 아카데미 감독 아래에서 레슨을 담당하는 코치
model AcademyCoach {
  id        String   @id @default(cuid())
  academyId String   @map("academy_id")
  userId    String   @map("user_id") /// 코치 User ID
  role      String   @default("ASSISTANT_COACH") /// HEAD_COACH|ASSISTANT_COACH
  isActive  Boolean  @default(true) @map("is_active")
  joinedAt  DateTime @default(now()) @map("joined_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user    User    @relation("AcademyCoachUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([academyId, userId])
  @@index([academyId, isActive])
  @@map("academy_coaches")
}

// ==================== Moderation (사용자 차단·신고) ====================

/// 사용자 차단 - blocker가 blocked를 차단
model UserBlock {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("UserBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

/// 사용자 신고 - 부적절한 사용자/콘텐츠 신고 (정보통신망법 대응)
model UserReport {
  id          String    @id @default(cuid())
  reporterId  String    @map("reporter_id")
  reportedId  String    @map("reported_id")
  targetType  String    @map("target_type") /// user | chat_message | pickup_match | review | notice
  targetId    String?   @map("target_id") /// 콘텐츠 신고 시 대상 리소스 ID
  category    String /// spam | harassment | inappropriate | fake_profile | other
  description String?   @db.Text
  status      String    @default("pending") /// pending | reviewing | resolved | rejected
  adminNote   String?   @map("admin_note") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  resolvedAt  DateTime? @map("resolved_at")

  reporter User @relation("UserReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("UserReportReported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([reportedId])
  @@map("user_reports")
}

// ==================== Consultation (학부모-코치 1:1 상담) ====================

/// 상담 - 학부모-코치 1:1 상담 세션 (ChatRoom과 1:1 연결)
/// ChatRoom은 인프라(메시지 스토리지), Consultation은 도메인 메타(상태/카테고리/읽지않음)
model Consultation {
  id         String  @id @default(cuid())
  parentId   String  @map("parent_id") /// 상담 요청자 (학부모)
  coachId    String  @map("coach_id") /// 상담 대상 (코치)
  studentId  String? @map("student_id") /// 상담 대상 자녀 (선택)
  chatRoomId String  @unique @map("chat_room_id") /// 연결된 채팅방 (1:1)

  category ConsultationCategory @default(GENERAL) /// 상담 카테고리
  status   ConsultationStatus   @default(ACTIVE) /// 상담 상태

  lastMessageAt        DateTime? @map("last_message_at") /// 마지막 메시지 일시 (정렬용)
  unreadCountForParent Int       @default(0) @map("unread_count_for_parent") /// 학부모 기준 안읽은 메시지 수
  unreadCountForCoach  Int       @default(0) @map("unread_count_for_coach") /// 코치 기준 안읽은 메시지 수

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  closedAt  DateTime? @map("closed_at") /// 상담 종료 일시

  parent   User     @relation("ConsultationParent", fields: [parentId], references: [id], onDelete: Cascade)
  coach    User     @relation("ConsultationCoach", fields: [coachId], references: [id], onDelete: Cascade)
  student  User?    @relation("ConsultationStudent", fields: [studentId], references: [id], onDelete: SetNull)
  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@index([parentId, status])
  @@index([coachId, status])
  @@index([studentId])
  @@index([lastMessageAt])
  @@map("consultations")
}

/// 상담 상태
enum ConsultationStatus {
  ACTIVE /// 진행중
  CLOSED /// 종료
  ARCHIVED /// 보관
}

/// 상담 카테고리
enum ConsultationCategory {
  GENERAL /// 일반 문의
  CLASS_CONTENT /// 수업 내용
  PROGRESS /// 자녀 성장/실력
  PAYMENT /// 결제/크레딧
  SCHEDULE /// 일정 조정
  ISSUE /// 문제 제기/불만
  OTHER /// 기타
}

// ==================== Settlement Detail (거래 단위 정산 상세) ====================

/// 정산 상세 내역 - 결제(Payment)별 거래 단위 정산 레코드
/// SettlementTransaction(요약)과 구분되며 실제 매니저 승인 대상
model SettlementDetail {
  id            String                 @id @default(cuid())
  settlementId  String                 @map("settlement_id")
  paymentId     String                 @map("payment_id") /// 원본 결제 (FK 보존)
  orderNumber   String                 @unique @map("order_number") /// 결제 주문번호 (멱등성 키)
  productName   String                 @map("product_name")
  paymentDate   DateTime               @map("payment_date")
  paymentMethod String                 @map("payment_method") /// card | wallet | etc
  paymentAmount Int                    @map("payment_amount") /// 결제 금액
  feeRate       Float                  @map("fee_rate") /// 수수료율 (0.0 ~ 1.0)
  feeAmount     Int                    @map("fee_amount") /// 수수료 금액
  actualAmount  Int                    @map("actual_amount") /// 실지급 금액
  status        SettlementDetailStatus @default(PENDING) /// 정산 상세 상태
  memo          String?                @db.Text /// 비고/메모
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  payment    Payment    @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([settlementId, status])
  @@index([paymentDate])
  @@index([paymentId])
  @@map("settlement_details")
}

/// 정산 상세 상태
enum SettlementDetailStatus {
  PENDING /// 대기
  APPROVED /// 승인
  REJECTED /// 반려
  PAID /// 지급 완료
  HOLD /// 보류
}

/// 정산 매니저 승인 상태
enum SettlementApprovalStatus {
  PENDING /// 대기
  APPROVED /// 승인
  REJECTED /// 반려
  REVIEW /// 재검토
}

// ==================== Member Approval Log (회원 승인/반려 감사 로그) ====================

/// 회원 승인 로그 - TeamMember 승인/반려 이력 (append-only, 수정/삭제 불가)
model MemberApprovalLog {
  id        String               @id @default(cuid())
  memberId  String               @map("member_id") /// TeamMember.id
  action    MemberApprovalAction /// 승인/반려/취소 등
  reason    String?              @db.Text /// 반려 사유 등 상세
  actorId   String               @map("actor_id") /// 행위자 (User.id)
  actorRole UserType             @map("actor_role") /// 행위자 역할 스냅샷
  createdAt DateTime             @default(now()) @map("created_at")

  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  actor  User       @relation("MemberApprovalActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([memberId, createdAt])
  @@index([actorId])
  @@index([action])
  @@map("member_approval_logs")
}

/// 회원 승인 감사 로그 액션
enum MemberApprovalAction {
  APPROVED /// 승인
  REJECTED /// 반려
  REVOKED /// 승인 취소
  REAPPLIED /// 재신청
  PENDING_REVIEW /// 재검토 대기
}

// ==================== Payment Receipt (결제 영수증) ====================

/// 결제 영수증 - Payment와 1:1, 현금영수증/세금계산서 발행 정보
model PaymentReceipt {
  id            String   @id @default(cuid())
  paymentId     String   @unique @map("payment_id") /// 원본 결제 (1:1)
  receiptNumber String   @unique @map("receipt_number") /// 영수증 번호 (시퀀셜/포맷)
  issuedAt      DateTime @default(now()) @map("issued_at") /// 발행 일시
  taxable       Boolean  @default(true) /// 과세 여부
  taxAmount     Int      @default(0) @map("tax_amount") /// 부가세 금액
  receiptUrl    String?  @map("receipt_url") @db.Text /// 영수증 PDF/이미지 URL
  emailSent     Boolean  @default(false) @map("email_sent") /// 이메일 발송 여부
  smsSent       Boolean  @default(false) @map("sms_sent") /// SMS 발송 여부
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([receiptNumber])
  @@index([issuedAt])
  @@map("payment_receipts")
}

// ==================== Wishlist (통합 위시리스트) ====================

/// 통합 위시리스트 - 상품/클럽/아카데미/코치 등 다양한 리소스 찜하기
/// ShopWishlist(상품 전용)와 별도로 유지 (데이터 이관은 별도 migration에서)
model Wishlist {
  id         String             @id @default(cuid())
  userId     String             @map("user_id")
  targetType WishlistTargetType @map("target_type") /// 대상 타입
  targetId   String             @map("target_id") /// 대상 리소스 ID
  createdAt  DateTime           @default(now()) @map("created_at")

  user User @relation("WishlistUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId, targetType])
  @@index([targetType, targetId])
  @@map("wishlists")
}

/// 위시리스트 대상 타입
enum WishlistTargetType {
  PRODUCT /// 쇼핑몰 상품
  CLUB /// 클럽
  ACADEMY /// 아카데미
  COACH /// 코치
  CLASS /// 수업
  TOURNAMENT /// 대회
  VENUE /// 경기장
  OTHER /// 기타
}

// ==================== Gallery (팀/코치 갤러리) ====================

/// 갤러리 - 팀 또는 코치가 관리하는 사진첩 (앨범)
model Gallery {
  id            String            @id @default(cuid())
  teamId        String?           @map("team_id") /// 소속 팀 (nullable: 코치 개인 갤러리 가능)
  coachId       String?           @map("coach_id") /// 담당 코치 (nullable)
  title         String /// 갤러리 제목
  description   String?           @db.Text /// 설명
  coverPhotoUrl String?           @map("cover_photo_url") @db.Text /// 대표 사진 URL
  category      GalleryCategory   @default(OTHER) /// 갤러리 카테고리
  visibility    GalleryVisibility @default(CLUB_ONLY) /// 공개 범위
  sortOrder     Int               @default(0) @map("sort_order") /// 정렬 순서
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  team   Team?          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  coach  User?          @relation("GalleryCoach", fields: [coachId], references: [id], onDelete: SetNull)
  photos GalleryPhoto[]

  @@index([teamId, category])
  @@index([coachId])
  @@index([visibility])
  @@map("galleries")
}

/// 갤러리 사진 - 개별 사진 레코드 (Gallery:N)
model GalleryPhoto {
  id           String    @id @default(cuid())
  galleryId    String    @map("gallery_id")
  uploaderId   String    @map("uploader_id") /// 업로드한 User.id
  photoUrl     String    @map("photo_url") @db.Text /// 원본 사진 URL
  thumbnailUrl String    @map("thumbnail_url") @db.Text /// 썸네일 URL
  caption      String?   @db.Text /// 캡션
  takenAt      DateTime? @map("taken_at") /// 촬영 일시 (EXIF)
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  gallery  Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  uploader User    @relation("GalleryPhotoUploader", fields: [uploaderId], references: [id], onDelete: Restrict)

  @@index([galleryId, sortOrder])
  @@index([takenAt])
  @@index([uploaderId])
  @@map("gallery_photos")
}

/// 갤러리 카테고리
enum GalleryCategory {
  TRAINING /// 훈련
  GAME /// 경기
  EVENT /// 이벤트
  TOURNAMENT /// 대회
  DAILY /// 일상
  AWARD /// 시상
  OTHER /// 기타
}

/// 갤러리 공개 범위
enum GalleryVisibility {
  PUBLIC /// 전체 공개
  CLUB_ONLY /// 클럽 회원 한정
  MEMBERS_ONLY /// 특정 회원 한정
  PRIVATE /// 비공개 (업로더만)
}

// ==================== Stickers (칭찬 스티커) ====================

/// 칭찬 스티커 보드 - 아이별 스티커판
model StickerBoard {
  id          String    @id @default(cuid())
  childId     String    @map("child_id") /// User (child) ID
  teamId      String    @map("team_id")
  title       String    @default("칭찬 스티커판") /// 스티커판 제목
  goalCount   Int       @default(10) @map("goal_count") /// 목표 스티커 수
  rewardName  String?   @map("reward_name") /// 보상 이름
  rewardId    String?   @map("reward_id") /// 연결 Coupon ID
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  child User          @relation("ChildStickerBoards", fields: [childId], references: [id], onDelete: Cascade)
  team  Team          @relation("TeamStickerBoards", fields: [teamId], references: [id], onDelete: Cascade)
  slots StickerSlot[]

  @@index([childId, isActive])
  @@index([teamId])
  @@map("sticker_boards")
}

/// 스티커 슬롯 - 스티커판의 각 칸
model StickerSlot {
  id           String    @id @default(cuid())
  boardId      String    @map("board_id")
  slotNumber   Int       @map("slot_number") /// 1부터 시작
  stickerType  String?   @map("sticker_type") /// hockey|helmet|star|heart 등
  isEarned     Boolean   @default(false) @map("is_earned")
  earnedAt     DateTime? @map("earned_at")
  earnedReason String?   @map("earned_reason") /// 스티커 획득 사유
  awardedBy    String?   @map("awarded_by") /// 부여한 코치 User ID
  createdAt    DateTime  @default(now()) @map("created_at")

  board   StickerBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  awarder User?        @relation("StickerAwarder", fields: [awardedBy], references: [id], onDelete: SetNull)

  @@unique([boardId, slotNumber])
  @@index([boardId, isEarned])
  @@map("sticker_slots")
}

// ==================== Training Stats (훈련 스탯) ====================

/// 훈련 세션 기록 - 개별 훈련 세션 데이터
model TrainingSession {
  id           String   @id @default(cuid())
  memberId     String   @map("member_id") /// TeamMember ID
  teamId       String   @map("team_id")
  classId      String?  @map("class_id") /// 연결된 수업 (optional)
  sessionDate  DateTime @map("session_date")
  durationMin  Int      @map("duration_min") /// 훈련 시간 (분)
  intensityLvl String   @default("medium") @map("intensity_level") /// low|medium|high
  focusArea    String?  @map("focus_area") /// skating|shooting|passing|defense|fitness
  notes        String?  @db.Text
  recordedBy   String   @map("recorded_by") /// 기록한 코치 User ID
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  member   TeamMember       @relation("MemberTrainingSessions", fields: [memberId], references: [id], onDelete: Cascade)
  team     Team             @relation("TeamTrainingSessions", fields: [teamId], references: [id], onDelete: Cascade)
  class    Class?           @relation("ClassTrainingSessions", fields: [classId], references: [id], onDelete: SetNull)
  recorder User             @relation("TrainingSessionRecorder", fields: [recordedBy], references: [id], onDelete: Restrict)
  metrics  TrainingMetric[]

  @@index([memberId, sessionDate])
  @@index([teamId, sessionDate])
  @@index([classId])
  @@map("training_sessions")
}

/// 훈련 지표 - 세션별 상세 측정값
model TrainingMetric {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  metricName  String   @map("metric_name") /// speed|accuracy|endurance|agility|strength
  metricValue Float    @map("metric_value") /// 측정값
  unit        String   @default("") /// km/h, %, reps 등
  createdAt   DateTime @default(now()) @map("created_at")

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([metricName])
  @@map("training_metrics")
}

// ==================== Class Diary (수업 일지) ====================

/// 수업 일지 - 코치가 작성하는 수업별 일지
model ClassDiary {
  id             String   @id @default(cuid())
  classId        String   @map("class_id")
  teamId         String   @map("team_id")
  coachId        String   @map("coach_id") /// 작성 코치 User ID
  sessionDate    DateTime @map("session_date") /// 수업 일자
  mainFocus      String?  @map("main_focus") /// 주요 훈련 내용
  drillDesc      String?  @map("drill_description") @db.Text /// 훈련 상세 설명
  intensityLevel String   @default("medium") @map("intensity_level") /// low|medium|high
  presentCount   Int      @default(0) @map("present_count") /// 출석 인원
  absentCount    Int      @default(0) @map("absent_count") /// 결석 인원
  totalCount     Int      @default(0) @map("total_count") /// 전체 인원
  coachNotes     String?  @map("coach_notes") @db.Text /// 코치 종합 의견
  isPublished    Boolean  @default(false) @map("is_published")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  class Class @relation("ClassDiaries", fields: [classId], references: [id], onDelete: Cascade)
  team  Team  @relation("TeamClassDiaries", fields: [teamId], references: [id], onDelete: Cascade)
  coach User  @relation("CoachClassDiaries", fields: [coachId], references: [id], onDelete: Restrict)

  @@index([classId, sessionDate])
  @@index([teamId, sessionDate])
  @@index([coachId])
  @@map("class_diaries")
}

// ==================== Work Schedule (근무 스케줄) ====================

/// 근무 스케줄 - 코치 근무 일정
model WorkSchedule {
  id           String   @id @default(cuid())
  coachId      String   @map("coach_id") /// 코치 User ID
  teamId       String   @map("team_id")
  classId      String?  @map("class_id") /// 연결 수업 (optional)
  scheduleDate DateTime @map("schedule_date")
  startTime    String   @map("start_time") /// HH:mm 형식
  endTime      String   @map("end_time") /// HH:mm 형식
  title        String? /// 일정 제목
  location     String? /// 장소
  status       String   @default("scheduled") /// scheduled|confirmed|cancelled|swapped
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  coach        User                  @relation("CoachWorkSchedules", fields: [coachId], references: [id], onDelete: Cascade)
  team         Team                  @relation("TeamWorkSchedules", fields: [teamId], references: [id], onDelete: Cascade)
  class        Class?                @relation("ClassWorkSchedules", fields: [classId], references: [id], onDelete: SetNull)
  swapRequests ScheduleSwapRequest[]

  @@index([coachId, scheduleDate])
  @@index([teamId, scheduleDate])
  @@index([status])
  @@map("work_schedules")
}

/// 스케줄 변경 요청 - 코치 간 근무 교환 요청
model ScheduleSwapRequest {
  id            String    @id @default(cuid())
  scheduleId    String    @map("schedule_id")
  requesterId   String    @map("requester_id") /// 요청 코치 User ID
  targetCoachId String?   @map("target_coach_id") /// 대상 코치 User ID (null이면 오픈 요청)
  reason        String?   @db.Text
  status        String    @default("pending") /// pending|approved|rejected|cancelled
  respondedAt   DateTime? @map("responded_at")
  respondedBy   String?   @map("responded_by") /// 승인/거부한 감독 User ID
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  schedule    WorkSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  requester   User         @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  targetCoach User?        @relation("SwapTargetCoach", fields: [targetCoachId], references: [id], onDelete: SetNull)
  responder   User?        @relation("SwapResponder", fields: [respondedBy], references: [id], onDelete: SetNull)

  @@index([scheduleId])
  @@index([requesterId, status])
  @@index([targetCoachId, status])
  @@map("schedule_swap_requests")
}

// ==================== Equipment Checklist (준비물 체크리스트) ====================

/// 준비물 체크리스트 - 아이/학부모용 준비물 관리
model EquipmentChecklist {
  id           String    @id @default(cuid())
  userId       String    @map("user_id") /// 소유자 User ID (child 또는 parent)
  classId      String?   @map("class_id") /// 연결 수업 (optional)
  teamId       String?   @map("team_id")
  title        String    @default("가방 챙기기")
  totalItems   Int       @default(0) @map("total_items")
  checkedItems Int       @default(0) @map("checked_items")
  isCompleted  Boolean   @default(false) @map("is_completed")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user  User            @relation("UserEquipmentChecklists", fields: [userId], references: [id], onDelete: Cascade)
  class Class?          @relation("ClassEquipmentChecklists", fields: [classId], references: [id], onDelete: SetNull)
  items ChecklistItem[]

  @@index([userId])
  @@index([classId])
  @@map("equipment_checklists")
}

/// 체크리스트 항목 - 개별 준비물
model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String    @map("checklist_id")
  itemName    String    @map("item_name") /// 항목명 (예: 헬멧, 스케이트)
  iconName    String?   @map("icon_name") /// Material icon 이름
  imageUrl    String?   @map("image_url") @db.Text /// 아이템 이미지 URL
  isChecked   Boolean   @default(false) @map("is_checked")
  checkedAt   DateTime? @map("checked_at")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")

  checklist EquipmentChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, sortOrder])
  @@map("checklist_items")
}

// ==================== Equipment Inspection (장비 점검 리포트) ====================
// 2026-05-14: 링크 시설/공용 장비 주·월간 안전 점검 기록.
//   기존 EquipmentChecklist 는 아동 개인 준비물용. 본 도메인은 *시설/공용 장비*
//   안전 점검(헬멧 손상, 스케이트 날 상태, 골키퍼 패드 등) 으로 별도.
//   이상 발견 시 알림톡 발송 (AlimtalkGateway 연동).

/// 장비 점검 리포트 — 팀/링크 단위 정기 안전 점검
model EquipmentInspection {
  id          String   @id @default(cuid())
  teamId      String   @map("team_id")
  inspectorId String   @map("inspector_id") /// 점검자 User ID (COACH/DIRECTOR)
  venueId     String?  @map("venue_id") /// 점검 장소 (Venue 모델)
  inspectedAt DateTime @default(now()) @map("inspected_at")
  /// pending(점검 시작) / completed(완료) / issue_found(이상 발견)
  status      String   @default("pending")
  /// 종합 메모 — 자유 텍스트
  notes       String?  @db.Text
  /// 이상 발견 시 알림톡 발송 여부 (중복 발송 방지)
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  team      Team             @relation("TeamEquipmentInspections", fields: [teamId], references: [id], onDelete: Cascade)
  inspector User             @relation("UserEquipmentInspections", fields: [inspectorId], references: [id], onDelete: Restrict)
  items     InspectionItem[]

  @@index([teamId, inspectedAt])
  @@index([inspectorId])
  @@index([status])
  @@map("equipment_inspections")
}

/// 점검 항목 — 헬멧/스케이트/패드/골대 등 개별 장비 상태
model InspectionItem {
  id           String   @id @default(cuid())
  inspectionId String   @map("inspection_id")
  /// 장비 카테고리 — helmet / skate / pad / stick / goal / ice / other
  category     String
  /// 항목명 (예: "헬멧 #5", "골키퍼 패드 좌측")
  itemName     String   @map("item_name")
  /// 상태 — good / minor_issue / critical / replaced
  condition    String   @default("good")
  /// 이상 상세 (condition != 'good' 일 때 필수)
  issueDetail  String?  @map("issue_detail") @db.Text
  /// 사진 URL (S3/uploads)
  photoUrl     String?  @map("photo_url") @db.Text
  /// 액션 필요 여부 (true → notification 대상)
  needsAction  Boolean  @default(false) @map("needs_action")
  /// 책임자 — 수리/교체 담당 User ID (optional)
  assigneeId   String?  @map("assignee_id")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  inspection EquipmentInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId, sortOrder])
  @@index([condition])
  @@index([needsAction])
  @@map("inspection_items")
}

// ==================== Unified Upload Files ====================

/// 업로드 파일 카테고리
/// IMAGE: 일반 이미지 (공지·갤러리 등)
/// DOCUMENT: 문서 (PDF·DOCX·PPTX·XLSX)
/// VIDEO: 영상 (MP4·WebM·MOV)
/// AVATAR: 프로필 아바타 (프로필 편집)
/// ATTACHMENT: 범용 첨부파일 (채팅·커뮤니티 등)
enum UploadCategory {
  IMAGE /// 일반 이미지
  DOCUMENT /// 문서 파일
  VIDEO /// 영상 파일
  AVATAR /// 프로필 아바타
  ATTACHMENT /// 범용 첨부파일
}

/// 통합 업로드 파일 메타데이터
/// 모든 업로드(프로필·공지·갤러리·상품·채팅 등)의 단일 진입점
model UploadedFile {
  id           String         @id @default(cuid())
  category     UploadCategory
  originalName String         @map("original_name") /// 사용자가 올린 원본 파일명
  storedName   String         @map("stored_name") /// 서버에 저장된 파일명 (형식: {사용자명}_{YYYYMMDDHHmm}_{hash}.{ext})
  extension    String?        @map("extension") /// 확장자 (예: "jpg", "pdf", "mp4") — 소문자, 점(.) 제외
  mimeType     String         @map("mime_type") /// MIME 타입
  size         Int /// 바이트 단위
  path         String         @db.Text /// 서버 상대 경로 (예: "/image/2026/04/18/홍길동_202604181230_a1b2.jpg")
  url          String         @db.Text /// 공개 접근 URL (/uploads 접두)
  sha256       String? /// 무결성 검증 해시
  width        Int? /// 이미지·영상 가로
  height       Int? /// 이미지·영상 세로
  thumbUrl     String?        @map("thumb_url") @db.Text /// 자동 생성 썸네일 URL (IMAGE/AVATAR만)
  exifJson     Json?          @map("exif_json") /// EXIF 메타데이터 JSON (IMAGE만)

  uploaderId String @map("uploader_id") /// 최초 등록자
  uploader   User   @relation("FileUploader", fields: [uploaderId], references: [id], onDelete: Cascade)

  modifiedById String? @map("modified_by_id") /// 최종 수정자 (nullable — 생성 직후엔 uploaderId와 동일, 메타데이터 수정 시 갱신)
  modifiedBy   User?   @relation("FileModifier", fields: [modifiedById], references: [id], onDelete: SetNull)

  refType String? @map("ref_type") /// 연결 리소스 타입 (예: "notice", "banner", "player_award")
  refId   String? @map("ref_id") /// 연결 리소스 ID

  createdAt DateTime @default(now()) @map("created_at") /// 최초 등록일
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") /// 최종 수정일 (Prisma 자동 갱신)

  @@index([uploaderId])
  @@index([modifiedById])
  @@index([refType, refId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([category])
  @@index([extension])
  /// 본인 업로드 이력 최신순 조회 — `/files?uploaderId=me` 필터 + ORDER BY createdAt DESC 최적화
  @@index([uploaderId, createdAt(sort: Desc)])
  /// 카테고리별 최신 조회 — 관리자/통계 화면에서 카테고리 필터 + 최신순 정렬
  @@index([category, createdAt(sort: Desc)])
  /// 중복 탐지(sha256 동일 파일 탐지) — uploads-doctor 진단 + dedup 향후 확장 대비
  @@index([sha256])
  @@map("uploaded_files")
}

// ==================== 2FA / Security ====================

/// TOTP 2단계 인증 비밀키 — secret은 AES-256-GCM 암호화 저장
model TwoFactorSecret {
  userId    String   @id @map("user_id")
  secret    String   @db.Text /// AES-256-GCM 암호화된 TOTP secret (hex:iv:authTag)
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_secrets")
}

// ==================== PIPA 데이터 내보내기 ====================

/// PIPA §35 개인정보 열람 요청 — 비동기 Bull 워커로 ZIP 생성
model DataExportRequest {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  status       String    @default("pending") /// pending | processing | ready | failed | expired
  fileUrl      String?   @map("file_url") @db.Text /// 서명된 다운로드 URL
  fileSize     Int?      @map("file_size") /// bytes
  requestedAt  DateTime  @default(now()) @map("requested_at")
  readyAt      DateTime? @map("ready_at")
  expiresAt    DateTime? @map("expires_at") /// 7일 후 자동 만료
  errorMessage String?   @map("error_message") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, requestedAt])
  @@index([status, expiresAt])
  @@map("data_export_requests")
}

// ==================== 거래로그 (API Transaction Log) ====================

/// API 거래로그 — 모든 HTTP 요청/응답을 requestId 단위로 1행 저장 (v1, 2026-06-08).
/// 전역 ApiLifecycleInterceptor.finalize 에서 fire-and-forget upsert(requestId)로 적재.
/// 정책: 보관 90일(TransactionLogCleanupService @Cron) · 민감값 마스킹 · 10KB 초과 truncate ·
///       KST 표시(UTC 저장) · 저장 실패가 본 API 응답에 영향 0(try/catch swallow).
/// 가변 payload 는 JsonB 컬럼 + schemaVersion 으로 스키마 변경에도 안 깨지게 설계.
model TransactionLog {
  id        String @id @default(cuid()) /// DB 내부 기본키 — requestId 가 비거나 충돌해도 안전
  /// 업무 키값 — 클라이언트 echo(X-Request-ID) 또는 서버 randomUUID(). IN/OUT 동일성 보장 → UNIQUE
  requestId String @unique @map("request_id")

  // ===== 고정 컬럼 =====
  occurredAt    DateTime @map("occurred_at") /// 요청 수신 시각 (UTC 저장, 조회·표시 시 KST 변환)
  method        String /// GET/POST/PUT/PATCH/DELETE
  path          String /// 쿼리스트링 제외 pathname (쿼리는 requestQuery 에 저장)
  httpStatus    Int      @map("http_status")
  bizSuccess    Boolean? @map("biz_success") /// 응답 body.success 가 boolean 일 때만 (없으면 null)
  result        String /// 'SUCCESS' | 'FAIL' | 'ERROR' — decideResult() 단일 판정
  errorCode     String?  @map("error_code")
  errorMessage  String?  @map("error_message") @db.Text
  durationMs    Int      @map("duration_ms")
  userId        String?  @map("user_id")
  userRole      String?  @map("user_role")
  userEmail     String?  @map("user_email")
  platform      String? /// web|admin|ios|android|flutter|unknown
  clientVersion String?  @map("client_version")
  viewId        String?  @map("view_id") /// X-View-Id echo (호출 발생 화면)
  ip            String?
  responseBytes Int?     @map("response_bytes")
  env           String /// development|staging|production
  truncated     Boolean  @default(false) /// req/res payload 10KB 초과 절단 여부
  schemaVersion Int      @default(1) @map("schema_version")

  // ===== 가변 JSON payload (마스킹·truncate 적용 후 저장) =====
  requestHeaders  Json? @map("request_headers") @db.JsonB
  requestBody     Json? @map("request_body") @db.JsonB
  requestQuery    Json? @map("request_query") @db.JsonB
  requestParams   Json? @map("request_params") @db.JsonB
  responseHeaders Json? @map("response_headers") @db.JsonB
  responseBody    Json? @map("response_body") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  @@index([occurredAt])
  @@index([platform])
  @@index([result])
  @@index([httpStatus])
  @@index([userId])
  @@index([path])
  @@index([viewId])
  @@index([method])
  @@map("transaction_logs")
}

// ==================== Contact Inquiries (도입 상담 신청) ====================
// teamplus-home 랜딩의 도입 상담 신청 폼 저장용. 앱 내 학부모↔코치 1:1 상담(Consultation)과는 완전 별개 도메인.
// 원격 공유 DEV DB(drift) 정책: prisma migrate dev 금지 → manual-migrations SQL 수동 적용 + prisma generate.

enum ContactInquiryStatus {
  NEW // 신규 접수
  IN_PROGRESS // 처리중(담당자 배정/연락 시도)
  DONE // 완료(상담 종료)
  ARCHIVED // 보관(스팸/무효 등)
}

model ContactInquiry {
  id               String               @id @default(cuid())
  organizationName String // 클럽명/단체명 (필수)
  managerName      String // 담당자 성함 (필수)
  email            String // 이메일 (필수)
  phone            String // 연락처 (필수)
  interestedPlan   String? // starter|business|enterprise|undecided (선택)
  clubSize         String? // ~50명|50-150명|150-300명|300명+ (선택)
  message          String? // 문의 내용 (선택, 긴 텍스트)
  privacyAgreed    Boolean              @default(false) // 개인정보 수집·이용 동의 (필수 true)
  status           ContactInquiryStatus @default(NEW)
  adminMemo        String? // 관리자 처리 메모
  source           String               @default("home_contact") // 유입 출처
  ipAddress        String? // 스팸 추적(서버 기록, 선택)
  userAgent        String? // 스팸 추적(서버 기록, 선택)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime? // soft delete

  @@index([status, deletedAt, createdAt])
  @@index([deletedAt, createdAt])
  @@map("contact_inquiries")
}
