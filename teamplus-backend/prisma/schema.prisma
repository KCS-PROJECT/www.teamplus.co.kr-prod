// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  // ⚠️ icehockey_test DB에 기존 운영 테이블 87개 존재 확인(2026-04-18) → shadow로 사용 금지.
  // 전용 빈 DB를 DBA가 생성해야 함 (아래 .env SHADOW_DATABASE_URL 주석 참조).
}

// ==================== Users & Authentication ====================

/// 사용자 - 시스템의 모든 사용자 (부모, 코치, 관리자, 자녀)
model User {
  id           String   @id @default(cuid())
  firstName    String   @map("first_name") /// 이름
  lastName     String   @map("last_name") /// 성
  email        String   @unique
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  userType     UserType @map("user_type")
  createdId    String?  @map("created_id") /// 생성자 ID
  createdAt    DateTime @default(now()) @map("created_at")
  updatedId    String?  @map("updated_id") /// 수정자 ID
  updatedAt    DateTime @updatedAt @map("updated_at")

  // 본인인증 정보 (CI/DI)
  ci         String?   @unique /// 연계정보 (Connecting Information) - 암호화 저장(랜덤 IV, 복호화 전용)
  ciHash     String?   @unique @map("ci_hash") /// [2026-06-10] CI 결정적 HMAC 인덱스 — 1인1계정 중복가입 차단용 (랜덤 IV 암호문은 동등비교 불가)
  di         String? /// 중복가입확인정보 (Duplicate Information) - 암호화 저장
  isVerified Boolean   @default(false) @map("is_verified") /// 본인인증 완료 여부
  verifiedAt DateTime? @map("verified_at") /// 본인인증 완료 시간

  // 생년월일 / 한국 나이
  birthDate DateTime? @map("birth_date") /// 생년월일 (TEEN/CHILD 회원가입 시 저장)
  koreanAge Int?      @map("korean_age") /// 한국 나이 (회원가입 시 계산)

  // 회원 탈퇴 / 휴면 관련
  status              String    @default("ACTIVE") /// ACTIVE|WITHDRAW_PENDING|WITHDRAWN|DORMANT
  tokenVersion        Int       @default(1) @map("token_version") /// 모든 기기 로그아웃 시 +1 → 기존 JWT 전체 무효화 (logout-all)
  withdrawRequestedAt DateTime? @map("withdraw_requested_at") /// 탈퇴 요청 일시
  withdrawReason      String?   @map("withdraw_reason") @db.Text /// 탈퇴 사유
  withdrawProcessedAt DateTime? @map("withdraw_processed_at") /// 탈퇴 처리(비식별화) 완료 일시
  lastLoginAt         DateTime? @map("last_login_at") /// 마지막 로그인 일시 (휴면 계산 기준)
  lastActiveAt        DateTime? @map("last_active_at") /// 마지막 API 활동 시각 (Redis 5분 throttle)
  dormantAt           DateTime? @map("dormant_at") /// 휴면 전환 일시

  // 추가 정보
  gender        String? @map("gender") /// 성별 (M: 남, F: 여)
  note          String? @map("note") @db.Text /// 특이사항/메모
  zipCode       String? @map("zip_code") /// 우편번호
  address       String? /// 기본주소
  addressDetail String? @map("address_detail") /// 상세주소
  avatarUrl     String? @map("avatar_url") @db.Text /// 프로필 아바타 URL (통합 Files 모듈 업로드 결과)

  // 약관 동의 버전 (L-02 — 2026-05-21 추가, 약관 변경 시 재동의 강제)
  agreedTermsVersion   String?   @map("agreed_terms_version") /// 마지막 동의한 이용약관 버전 (AppSettings.termsVersion 과 비교)
  agreedPrivacyVersion String?   @map("agreed_privacy_version") /// 마지막 동의한 개인정보처리방침 버전
  agreedAt             DateTime? @map("agreed_at") /// 마지막 약관 동의 시각

  // Soft Delete (NEW-06 — 2026-05-21 추가, PIPA 30일 보존)
  deletedAt DateTime? @map("deleted_at") /// 논리적 삭제 시각 (NULL = active, 값 있음 = soft-deleted)

  // 면책 동의서 (C-09 — 2026-05-21 추가)
  liabilityWaivers LiabilityWaiver[]

  // Relationships
  parentProfile               ParentProfile?
  coachProfile                CoachProfile?
  childProfile                ChildProfile?
  teamMembers                 TeamMember[]
  payments                    Payment[]
  memberCredits               MemberCredit[]
  monthlyBillingLines         MonthlyPostpaidBillingLine[] /// 월별 후불 청구 라인(청구 대상)
  // 2026-04-27 (N-9): ClassAttendance relation 3종 — 출석 대상자/실제 클릭자/수정자
  attendances                 ClassAttendance[]            @relation("AttendanceMember")
  attendancesCheckedIn        ClassAttendance[]            @relation("AttendanceCheckedInBy")
  attendancesModified         ClassAttendance[]            @relation("AttendanceModifiedBy")
  // PR-C (v0.5): AttendanceAuditLog 3 relation — 대상자/액션 주체/알림 발송 학부모
  attendanceAuditLogsMember   AttendanceAuditLog[]         @relation("AuditLogMember")
  attendanceAuditLogsActor    AttendanceAuditLog[]         @relation("AuditLogActor")
  attendanceAuditLogsNotified AttendanceAuditLog[]         @relation("AuditLogNotifiedParent")
  // 2026-04-27 (N-9): ClassRegistration User 기반 통일
  classRegistrations          ClassRegistration[]
  notifications               Notification[]
  auditLogs                   AuditLog[]
  activityLogs                UserActivityLog[]
  notificationPreference      UserNotificationPreference?
  identityVerifications       IdentityVerification[]

  // Community
  teamPosts        TeamPost[]
  teamPostComments TeamPostComment[]
  teamPostLikes    TeamPostLike[]

  // 학부모-자녀 관계 (ParentChild)
  parentChildren ParentChild[] @relation("ParentChildren") /// 학부모로서 연결된 자녀들
  childParents   ParentChild[] @relation("ChildParents") /// 자녀로서 연결된 보호자들

  // 수강신청 관계 (Enrollment)
  childEnrollments     Enrollment[] @relation("ChildEnrollments") /// 자녀로서의 수강신청 목록
  requestedEnrollments Enrollment[] @relation("EnrollmentRequester") /// 내가 요청한 수강신청
  approvedEnrollments  Enrollment[] @relation("EnrollmentApprover") /// 내가 승인한 수강신청

  // 쇼핑몰 관계
  wishlists   ShopWishlist[]
  shopReviews ShopReview[]   @relation("ShopReviewUser")
  coupons     UserCoupon[]
  shopCart    ShopCart?

  // 수업 리뷰
  classReviews ClassReview[]

  // 쇼핑몰 주문
  shopOrders ShopOrder[]

  // 뱃지 (자녀)
  childBadges ChildBadge[]

  // QR 출석
  attendanceQRs AttendanceQR[] @relation("AttendanceQRGenerator")
  scannedQRs    AttendanceQR[] @relation("AttendanceQRScanner")

  // 기술 평가 (코치)
  coachEvaluations SkillEvaluation[] @relation("SkillEvaluationCoach")

  // 팀 관리 (감독)
  managedTeams Team[] @relation("TeamCoach")

  // 회원 레벨/포인트
  memberLevel        MemberLevel?
  memberLevelHistory MemberLevelHistory[]
  playerSkillLevel   PlayerSkillLevel?
  pointHistory       PointTransaction[]

  // 채팅 관계
  chatRooms        ChatRoomMember[]
  sentMessages     ChatMessage[]    @relation("SentMessages")
  receivedMessages ChatMessage[]    @relation("ReceivedMessages")

  // 앱 관리
  appFeedbacks AppFeedback[]
  userDevices  UserDevice[]

  // 픽업 매치
  managedMatches    PickupMatch[]          @relation("ManagedPickupMatches")
  matchApplications PickupMatchApplicant[] @relation("PickupMatchApplications")
  updatedMatches    PickupMatch[]          @relation("MatchUpdater")

  // 스태프 경력
  staffCareers StaffCareer[]

  // 대관 예약 · 계약
  venueBookings        VenueBooking[]
  venueRentalContracts VenueRentalContract[]

  // 대기자 목록
  waitlists      Waitlist[] @relation("WaitlistUser")
  childWaitlists Waitlist[] @relation("WaitlistChild")

  // RSVP 참석/불참 응답
  rsvpsAsUser  ClassRsvp[] @relation("RsvpUser")
  rsvpsAsChild ClassRsvp[] @relation("RsvpChild")

  // 대회 참가 등록
  tournamentRegistrationsAsUser  TournamentRegistration[] @relation("TournamentRegUser")
  tournamentRegistrationsAsChild TournamentRegistration[] @relation("TournamentRegChild")

  // 공통코드 생성/수정
  createdCodeGroups CommonCodeGroup[] @relation("CodeGroupCreator")
  updatedCodeGroups CommonCodeGroup[] @relation("CodeGroupUpdater")
  createdCodes      CommonCode[]      @relation("CodeCreator")
  updatedCodes      CommonCode[]      @relation("CodeUpdater")

  // 아카데미 홍보
  academyPromotions AcademyPromotion[] @relation("PromotionCoach")

  // 아카데미 관리 (아카데미 감독)
  managedAcademies        Academy[]       @relation("AcademyDirector")
  academyMemberships      AcademyMember[] @relation("AcademyMemberUser")
  academyChildMemberships AcademyMember[] @relation("AcademyMemberChild")
  academyCoachRoles       AcademyCoach[]  @relation("AcademyCoachUser")

  // 해외 원정
  createdOverseasTrips    OverseasTrip[]             @relation("OverseasTripCreator")
  parentTripRegistrations OverseasTripRegistration[] @relation("TripParent")
  childTripRegistrations  OverseasTripRegistration[] @relation("TripChild")

  // 소셜 로그인
  socialAccounts SocialAccount[]

  // 영상
  uploadedVideos Video[] @relation("VideoUploader")

  // 수업 코치 배정
  classesAsCoach Class[] @relation("ClassCoach")

  // 수업 코치 초대/배정 (N:M)
  classCoachAssignments ClassCoachAssignment[] @relation("ClassCoachAssignments")
  classCoachInvitations ClassCoachAssignment[] @relation("ClassCoachInviter")

  // 공지 읽음 로그 (per-user)
  noticeReads    NoticeRead[]
  noticeComments NoticeComment[] @relation("UserNoticeComments")

  // 모더레이션 (차단 / 신고)
  blocksByMe       UserBlock[]  @relation("UserBlockBlocker")
  blocksAgainstMe  UserBlock[]  @relation("UserBlockBlocked")
  reportsByMe      UserReport[] @relation("UserReportReporter")
  reportsAgainstMe UserReport[] @relation("UserReportReported")

  // 2FA / 보안
  twoFactorSecret TwoFactorSecret?

  // PIPA 데이터 내보내기
  dataExportRequests DataExportRequest[]

  // 상담 (학부모-코치 1:1)
  parentConsultations  Consultation[] @relation("ConsultationParent")
  coachConsultations   Consultation[] @relation("ConsultationCoach")
  studentConsultations Consultation[] @relation("ConsultationStudent")

  // 회원 승인 감사 로그 (append-only)
  memberApprovalActions MemberApprovalLog[] @relation("MemberApprovalActor")

  // 정산 승인 (매니저)
  approvedSettlements Settlement[] @relation("SettlementManager")

  // 크레딧 조정 (관리자)
  creditAdjustments CreditTransaction[] @relation("CreditAdjuster")

  // 통합 위시리스트
  unifiedWishlists Wishlist[] @relation("WishlistUser")

  // 갤러리
  coachGalleries        Gallery[]      @relation("GalleryCoach")
  uploadedGalleryPhotos GalleryPhoto[] @relation("GalleryPhotoUploader")

  // 칭찬 스티커
  stickerBoards   StickerBoard[] @relation("ChildStickerBoards")
  awardedStickers StickerSlot[]  @relation("StickerAwarder")

  // 훈련 스탯
  recordedTrainingSessions TrainingSession[] @relation("TrainingSessionRecorder")

  // 수업 일지
  coachClassDiaries ClassDiary[] @relation("CoachClassDiaries")

  // 근무 스케줄
  coachWorkSchedules WorkSchedule[]        @relation("CoachWorkSchedules")
  swapRequests       ScheduleSwapRequest[] @relation("SwapRequester")
  swapTargets        ScheduleSwapRequest[] @relation("SwapTargetCoach")
  swapResponses      ScheduleSwapRequest[] @relation("SwapResponder")

  // 준비물 체크리스트
  equipmentChecklists EquipmentChecklist[] @relation("UserEquipmentChecklists")

  // 장비 점검 리포트 (2026-05-14) — inspector 로 참여한 기록
  equipmentInspections EquipmentInspection[] @relation("UserEquipmentInspections")

  // 통합 업로드 파일 (프로필·첨부·사진·문서·영상)
  uploadedFiles UploadedFile[] @relation("FileUploader")
  modifiedFiles UploadedFile[] @relation("FileModifier")

  @@index([userType])
  @@index([isVerified])
  @@index([createdAt])
  @@index([status])
  @@index([withdrawRequestedAt])
  @@map("users")
}

/// 사용자 유형
/// ADMIN: 시스템 관리자
/// DIRECTOR: 감독 (클럽 총괄)
/// COACH: 코치 (수업 담당)
/// PARENT: 학부모 (보호자)
/// TEEN: 10세 이상 학생 (청소년)
/// CHILD: 10세 미만 학생 (아동)
enum UserType {
  SYSTEM /// 시스템 최고 관리자 (ADM 전용 — 어드민 화면 로그인)
  OPER /// 운영자 (ADM 전용 — 어드민 화면 로그인)
  ADMIN /// 시스템 관리자 (레거시 · APP 화면 로그인 허용)
  DIRECTOR /// 감독 (클럽 총괄)
  ACADEMY_DIRECTOR /// 아카데미 감독 (독립 학원 운영)
  COACH /// 코치 (수업 담당)
  PARENT /// 학부모 (보호자)
  TEEN /// 10세 이상 학생 (청소년)
  CHILD /// 10세 미만 학생 (아동)
}

/// 부모 프로필 - 학부모 추가 정보
model ParentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("parent_profiles")
}

/// 코치 프로필 - 코치 추가 정보 (소속 팀)
model CoachProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  teamId    String?  @map("team_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([teamId]) // P0: teams 서비스 11회 호출 최적화
  @@map("coach_profiles")
}

/// 자녀 프로필 - 자녀 추가 정보 (생년월일 + 학습 레벨/진도)
model ChildProfile {
  id               String    @id @default(cuid())
  userId           String    @unique @map("user_id")
  birthDate        DateTime  @map("birth_date")
  /// 자녀 프로필 사진 URL — 학부모/자녀가 자녀 등록 또는 수정 시 업로드.
  /// `/uploads/avatar/...` 경로 (UploadedFile.url SoT).
  imageUrl         String?   @map("image_url") @db.Text
  pinVerifiedUntil DateTime? @map("pin_verified_until")
  /// 학습 레벨 (1-5: 1=입문, 2=기초, 3=중급, 4=상급, 5=마스터)
  currentLevel     Int       @default(1) @map("current_level")
  levelLabel       String    @default("입문") @map("level_label")
  /// 다음 레벨까지의 진도율 (0-100)
  progressPercent  Int       @default(0) @map("progress_percent")
  /// 다음 평가 테스트 예정일
  nextTestDate     DateTime? @map("next_test_date")
  /// 마지막 평가일
  lastEvaluatedAt  DateTime? @map("last_evaluated_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  childPin ChildPin?

  @@index([pinVerifiedUntil])
  @@map("child_profiles")
}

/// 자녀 PIN 인증 - 학부모가 설정한 자녀 보안 PIN (1:1)
model ChildPin {
  id             String    @id @default(cuid())
  childProfileId String    @unique @map("child_profile_id")
  pinHash        String    @map("pin_hash") // bcrypt salt=10
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastSetBy      String    @map("last_set_by") // PARENT User.id
  lastVerifiedAt DateTime? @map("last_verified_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  childProfile ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  @@index([childProfileId])
  @@index([lockedUntil])
  @@map("child_pins")
}

/// L-10 (2026-05-22 추가) — 만 14세 미만 자녀 등록 시 법정대리인 동의 저장.
/// PIPA(개인정보보호법) §22조 + 정통망법 §31조2 준수.
/// 법정 보존 기간: 동의 철회 후 5년 (분쟁 대비).
///
/// 저장 시점: PARENT 가 자녀를 등록(POST /children) 또는 OTP 인증 가입 시점.
/// guardianUserId — 동의한 학부모(법정대리인) User.id 스냅샷.
/// childUserId — 동의 대상 자녀 User.id (CHILD type · ChildProfile 1:1).
model ChildConsent {
  id                  String    @id @default(cuid())
  guardianUserId      String    @map("guardian_user_id") /// PARENT User.id (법정대리인)
  childUserId         String    @map("child_user_id") /// CHILD User.id (동의 대상 자녀)
  /// 동의 시점의 자녀 만나이(개월). 14세 미만 여부 = ageMonths < 168 검증에 사용.
  childAgeMonths      Int       @map("child_age_months")
  /// 동의한 약관 버전 (AppSettings.termsVersion 스냅샷 — 약관 변경 시 재동의 필요 판별).
  termsVersion        String    @map("terms_version")
  /// 동의한 개인정보처리방침 버전 (AppSettings.privacyVersion 스냅샷).
  privacyVersion      String    @map("privacy_version")
  /// 개인정보 수집·이용 동의 (필수).
  consentPersonalInfo Boolean   @default(false) @map("consent_personal_info")
  /// 제3자 제공 동의 (선택 — 결제·알림톡 등 외부 전송).
  consentThirdParty   Boolean   @default(false) @map("consent_third_party")
  /// 마케팅 활용 동의 (선택).
  consentMarketing    Boolean   @default(false) @map("consent_marketing")
  /// 동의 확인 방법 — 'sms_otp' / 'identity_verify' / 'pin'.
  verificationMethod  String    @map("verification_method")
  /// 동의 시 IP 주소 (법적 증거).
  ipAddress           String?   @map("ip_address")
  /// 동의 시 User-Agent.
  userAgent           String?   @map("user_agent") @db.Text
  /// 동의 철회 시각 (NULL=유효, 값 있음=철회됨).
  revokedAt           DateTime? @map("revoked_at")
  signedAt            DateTime  @default(now()) @map("signed_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([guardianUserId])
  @@index([childUserId])
  @@index([guardianUserId, childUserId])
  @@index([revokedAt])
  @@map("child_consents")
}

// ==================== Teams & Members ====================

/// 팀 - Phase 2 통합으로 구 teams 메타 흡수됨 (logoUrl ~ isActive)
/// Phase 4 Club → Team rename 완료
model Team {
  id                   String    @id @default(cuid())
  /// 팀 초대 코드 — 가입 시점엔 미설정(null) 허용. 감독이 팀 관리에서 등록·변경. nullable UNIQUE(Postgres NULL 다중 허용).
  teamCode             String?   @unique @map("team_code")
  name                 String    @map("name")
  coachId              String    @map("coach_id")
  location             String?
  phone                String?
  defaultBillingTiming String    @default("PREPAID") @map("default_billing_timing")
  // Phase 2 (2026-04-29) — 구 teams 모델 메타 흡수
  logoUrl              String?   @map("logo_url") @db.Text
  shortName            String?   @map("short_name")
  division             String?
  primaryColor         String?   @map("primary_color")
  secondaryColor       String?   @map("secondary_color")
  description          String?   @db.Text
  slogan               String?   @db.Text
  foundingDate         DateTime? @map("founding_date")
  homeArena            String?   @map("home_arena")
  venueId              String?   @map("venue_id") /// 홈 링크장 (Venue FK · 2026-05-22, homeArena 텍스트는 하위호환 유지)
  isActive             Boolean   @default(true) @map("is_active")
  // 04c 감독 팀 관리 카드 메타 (2026-05-09 추가)
  genderType           String    @default("MIX") @map("gender_type") /// MIX|M|F — 팀 성별 구성
  seasonWins           Int       @default(0) @map("season_wins") /// 시즌 누적 승
  seasonLosses         Int       @default(0) @map("season_losses") /// 시즌 누적 패
  seasonDraws          Int       @default(0) @map("season_draws") /// 시즌 누적 무
  recentAttendanceRate Int?      @map("recent_attendance_rate") /// 최근 30일 평균 출석률 (%, 0~100, null = 데이터 부족)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relationships
  coach   User           @relation("TeamCoach", fields: [coachId], references: [id])
  members TeamMember[]
  classes Class[]
  coaches CoachProfile[]

  // 이 팀에 노출된 오픈클래스 (academyId 수업) — ClassTeamVisibility N:M
  visibleOpenClasses ClassTeamVisibility[]

  // Community & Events
  teamPosts   TeamPost[]
  events      TeamEvent[]
  tournaments Tournament[]
  homeMatches HockeyMatch[] @relation("HomeTeam")
  awayMatches HockeyMatch[] @relation("AwayTeam")

  // Teams, Venues, Settlements
  // Phase 2 (2026-04-29) — Team 모델 폐기, team_groups 직접 참조로 변경
  groups                TeamGroup[]
  // Phase 2 (2026-04-29) — TeamAward / TeamDivision / TournamentMatch 의 team 참조도 Team 으로 통합
  teamAwards            TeamAward[]       @relation("TeamAwardsTeam")
  teamDivisions         TeamDivision[]    @relation("TeamDivisionsTeam")
  tournamentHomeMatches TournamentMatch[] @relation("TournamentHomeTeam")
  tournamentAwayMatches TournamentMatch[] @relation("TournamentAwayTeam")
  venues                Venue[]           @relation("VenueOwningTeam")
  homeVenue             Venue?            @relation("TeamHomeVenue", fields: [venueId], references: [id], onDelete: SetNull)
  settlements           Settlement[]

  // 캠프, 레슨 패키지, 경기 비용, 대관 예약 · 계약 · 스케줄
  camps                Camp[]
  lessonPackages       LessonPackage[]
  gameExpenses         GameExpense[]
  venueBookings        VenueBooking[]
  venueRentalContracts VenueRentalContract[]
  venueRentalSchedules VenueRentalSchedule[]

  // 아카데미 홍보
  academyPromotions AcademyPromotion[]

  // 리그
  leagues League[]

  // 해외 원정
  overseasTrips OverseasTrip[]

  // 영상
  videos Video[]

  // 갤러리
  galleries Gallery[]

  // 칭찬 스티커
  stickerBoards StickerBoard[] @relation("TeamStickerBoards")

  // 훈련 스탯
  trainingSessions TrainingSession[] @relation("TeamTrainingSessions")

  // 수업 일지
  classDiaries ClassDiary[] @relation("TeamClassDiaries")

  // 근무 스케줄
  workSchedules WorkSchedule[] @relation("TeamWorkSchedules")

  // 장비 점검 리포트 (2026-05-14)
  equipmentInspections EquipmentInspection[] @relation("TeamEquipmentInspections")

  @@index([createdAt]) // P0: search 페이지네이션 최적화
  @@index([coachId]) // P0: 팀-코치 FK 조회 최적화
  @@index([isActive]) // Phase 2 추가
  @@index([venueId]) // 홈 링크장 FK (2026-05-22)
  @@map("teams")
}

/// 팀 회원 - 팀 가입 회원 정보 (승인 상태 관리)
model TeamMember {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  teamId          String    @map("team_id")
  playerName      String    @map("player_name")
  playerAge       Int       @map("player_age")
  playerLevel     String?   @map("player_level") // beginner|intermediate|advanced
  approvalStatus  String    @default("pending") @map("approval_status") // pending|approved|rejected
  rejectionReason String?   @map("rejection_reason") @db.Text /// 반려 사유 (approvalStatus=rejected 시)
  joinedAt        DateTime  @default(now()) @map("joined_at")
  leftAt          DateTime? @map("left_at") /// 팀 탈퇴/이적 일시 (null이면 현재 활성)
  roleInTeam      String?   @map("role_in_team") // COACH|HEAD_COACH|PLAYER|MANAGER|PARENT
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relationships
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  team               Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  // 2026-04-27 (N-9 + N-10): ClassRegistration / MemberCredit 결합 제거.
  //  - ClassRegistration / MemberCredit 은 User 기반 통일됨 (Team/Academy 호환).
  //  - TeamMember 는 "팀 가입 자격(approvalStatus)" 표현만 담당.
  eventRegistrations TeamEventRegistration[]

  // Team & Evaluation
  // Phase 2 (2026-04-29) — TeamRoster 폐기, TeamGroupMember 단일화
  teamGroupMembers TeamGroupMember[]
  skillEvaluations SkillEvaluation[]

  // 수업 이력 & 수상
  classHistories PlayerClassHistory[]
  playerAwards   PlayerAward[]

  // 경력
  playerCareers PlayerCareer[]

  // 캠프 등록, 레슨 패키지 등록
  campRegistrations        CampRegistration[]
  lessonPackageEnrollments LessonPackageEnrollment[]

  // 해외 원정 참가 등록
  overseasTripRegistrations OverseasTripRegistration[]

  // 승인/반려 감사 로그 (append-only)
  approvalLogs MemberApprovalLog[]

  // 훈련 스탯
  trainingSessions TrainingSession[] @relation("MemberTrainingSessions")

  // Unique constraint on (user_id, team_id)
  @@unique([userId, teamId])
  @@index([teamId])
  @@index([approvalStatus])
  @@index([joinedAt])
  // W7-2: 대시보드 집계 최적화용 복합 인덱스
  @@index([approvalStatus, joinedAt]) /// getMembersByMonth / admin dashboard 누적 집계
  @@index([userId, approvalStatus]) /// TeamMember.findFirst by (userId, approvalStatus='approved')
  @@index([teamId, approvalStatus]) /// director/coach의 팀별 승인 회원 count
  @@map("team_members")
}

// ==================== Classes & Schedules ====================

/// 수업 - 클럽에서 제공하는 수업 정보
model Class {
  id               String    @id @default(cuid())
  /// teamId 또는 academyId 중 하나는 반드시 존재해야 함 (orphan 방지)
  /// DB CHECK: ALTER TABLE classes ADD CONSTRAINT chk_class_owner CHECK (team_id IS NOT NULL OR academy_id IS NOT NULL);
  /// 서비스 레이어에서도 이중 검증 적용
  teamId           String?   @map("team_id") /// 팀 소속 수업 (nullable — 아카데미 수업은 null)
  academyId        String?   @map("academy_id") /// 아카데미 소속 수업 (nullable — 클럽 수업은 null)
  className        String    @map("class_name")
  description      String?
  /// 수업/훈련 유형. 같은 컬럼에 두 도메인이 공존한다:
  ///   - classes 도메인 (학부모용 결제 수업, 소문자): regular | spot | lesson
  ///   - training 도메인 (감독 내부 훈련, 대문자): REGULAR_TRAINING | GAME | FUN | CAMP | PICKUP
  /// 두 도메인은 API 라우트(/classes vs /training)·권한·UI가 분리되어 있다.
  trainingType     String?   @map("training_type")
  instructorName   String    @map("instructor_name")
  capacity         Int
  ageMin           Int?      @map("age_min")
  ageMax           Int?      @map("age_max")
  /// 대상 출생연도 개별 목록(SoT). 예: [2015, 2017, 2019] — 비연속 선택 가능.
  /// 빈 배열([]) = 전 연령 대상. ageMin/ageMax 는 이 값의 한국나이 min/max 파생값(Dual-write).
  targetBirthYears Int[]     @default([]) @map("target_birth_years")
  levelRequired    String?   @map("level_required")
  startTime        DateTime  @map("start_time")
  endTime          DateTime  @map("end_time")
  isActive         Boolean   @default(true) @map("is_active")
  approvalStatus   String    @default("PENDING") @map("approval_status") // PENDING|APPROVED|REJECTED
  approvedAt       DateTime? @map("approved_at")
  approvedBy       String?   @map("approved_by")
  rejectionReason  String?   @map("rejection_reason")
  coachId          String?   @map("coach_id")
  venueId          String?   @map("venue_id")
  classDays        Json?     @map("class_days") @db.JsonB
  category         String?   @map("category") // KIDS|JUNIOR|ADULT
  requiredCoaches  Int       @default(1) @map("required_coaches") /// 필요 코치 수
  /// 결제 방식 (감독이 수업 생성 시 지정, Phase B) — PREPAID(모드 B·선불 번들) | POSTPAID(모드 A·후불 정산)
  billingMode      String    @default("PREPAID") @map("billing_mode")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relationships
  team             Team?                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  academy          Academy?               @relation(fields: [academyId], references: [id], onDelete: Cascade)
  coach            User?                  @relation("ClassCoach", fields: [coachId], references: [id], onDelete: SetNull)
  venue            Venue?                 @relation(fields: [venueId], references: [id], onDelete: SetNull)
  schedules        ClassSchedule[]
  products         ClassProduct[]
  registrations    ClassRegistration[]
  // 2026-04-27 (N-9): 수업권(MemberCredit) 이 Class 단위로 결합됨
  memberCredits    MemberCredit[]
  enrollments      Enrollment[] /// 수강신청 목록
  reviews          ClassReview[] /// 수업 리뷰
  classHistories   PlayerClassHistory[] /// 수업 이력
  waitlists        Waitlist[] /// 대기자 목록
  coachAssignments ClassCoachAssignment[] /// 코치 초대/배정 (N:M)
  promotions       AcademyPromotion[]     @relation("PromotionClass") /// 연결된 홍보 게시물

  // 훈련 스탯
  trainingSessions TrainingSession[] @relation("ClassTrainingSessions")

  // 수업 일지
  classDiaries ClassDiary[] @relation("ClassDiaries")

  // 근무 스케줄
  workSchedules WorkSchedule[] @relation("ClassWorkSchedules")

  // 준비물 체크리스트
  equipmentChecklists EquipmentChecklist[] @relation("ClassEquipmentChecklists")

  // 오픈클래스 팀 노출 (academyId 수업 전용) — 어느 팀 소속자에게 보일지
  teamVisibilities ClassTeamVisibility[]

  // 요일별 시간·장소 규칙 (ClassDaySchedule 신규 테이블)
  dayScheduleEntries ClassDaySchedule[]

  // 월별 후불 청구 (모드 A — POSTPAID) — 감독 확정 단위
  postpaidBillings MonthlyPostpaidBilling[]

  @@index([teamId])
  @@index([academyId])
  @@index([isActive])
  @@index([startTime])
  @@index([instructorName])
  @@index([coachId])
  @@index([venueId])
  @@index([category])
  @@index([approvalStatus])
  @@index([billingMode])
  @@map("classes")
}

/// 월별 후불 청구 헤더 (Phase B · 모드 A POSTPAID) — 감독이 수업×월 단위로 출석 검수 후 확정.
/// (classId, yearMonth) 멱등 키. 확정 시 회원별 라인(MonthlyPostpaidBillingLine) 생성.
/// ⚠️ 팀 매출 정산(Settlement)과 별개 — 이것은 학부모 대상 출석 기반 청구다.
model MonthlyPostpaidBilling {
  id          String    @id @default(cuid())
  classId     String    @map("class_id")
  yearMonth   String    @map("year_month") /// "YYYY-MM"
  status      String    @default("draft") /// draft(초안) | confirmed(확정)
  confirmedAt DateTime? @map("confirmed_at")
  confirmedBy String?   @map("confirmed_by") /// 확정한 감독 User.id
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  class Class                        @relation(fields: [classId], references: [id], onDelete: Cascade)
  items MonthlyPostpaidBillingLine[]

  @@unique([classId, yearMonth]) /// 멱등성 — 수업×월 1건
  @@index([classId])
  @@index([status])
  @@map("monthly_postpaid_billings")
}

/// 월별 후불 청구 라인 — 회원별 출석 횟수 × 단가 청구 + 납부 상태.
model MonthlyPostpaidBillingLine {
  id              String   @id @default(cuid())
  billingId       String   @map("billing_id")
  userId          String   @map("user_id") /// 청구 대상(자녀 User.id)
  attendanceCount Int      @map("attendance_count")
  amount          Int /// ₩ KRW (attendanceCount × feePerSession)
  paymentStatus   String   @default("pending") @map("payment_status") /// pending | paid
  paymentId       String?  @map("payment_id") /// 생성된 Payment 연결
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  billing MonthlyPostpaidBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)
  user    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment?               @relation(fields: [paymentId], references: [id])

  @@unique([billingId, userId]) /// 청구 1회당 회원 1건
  @@index([billingId])
  @@index([userId])
  @@index([paymentStatus])
  @@map("monthly_postpaid_billing_lines")
}

/// 오픈클래스 ↔ 팀 노출 (N:M)
/// 오픈클래스 감독(ACADEMY_DIRECTOR)이 만든 수업(academyId)을 어느 팀 소속자에게
/// 노출할지 지정한다. 여기 등록된 팀의 감독·코치·학부모·학생에게만 해당 오픈클래스가
/// 수업목록·캘린더·대시보드에 노출된다. 정규 수업(teamId)은 이 테이블을 쓰지 않는다.
model ClassTeamVisibility {
  id        String   @id @default(cuid())
  classId   String   @map("class_id")
  teamId    String   @map("team_id")
  createdAt DateTime @default(now()) @map("created_at")

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([classId, teamId])
  @@index([teamId])
  @@index([classId])
  @@map("class_team_visibilities")
}

/// 수업 코치 배정 — 수업-코치 N:M (초대 → 수락/거절 프로세스)
model ClassCoachAssignment {
  id            String    @id @default(cuid())
  classId       String    @map("class_id")
  coachUserId   String    @map("coach_user_id")
  status        String    @default("INVITED") /// INVITED | ACCEPTED | DECLINED | REMOVED
  invitedBy     String    @map("invited_by")
  invitedAt     DateTime  @default(now()) @map("invited_at")
  respondedAt   DateTime? @map("responded_at")
  declineReason String?   @map("decline_reason") @db.Text
  role          String    @default("ASSISTANT") /// LEAD | ASSISTANT
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  coach   User  @relation("ClassCoachAssignments", fields: [coachUserId], references: [id], onDelete: Cascade)
  inviter User  @relation("ClassCoachInviter", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([classId, coachUserId])
  @@index([classId, status])
  @@index([coachUserId, status])
  @@index([invitedAt])
  @@map("class_coach_assignments")
}

/// 수업 요일별 시간·장소 규칙 — 요일마다 다른 시작/종료 시간과 장소를 지정한다.
/// 예: 월 17:00–18:00 A링크장 / 수 19:00–20:00 B링크장
/// Class.classDays(요일 여부)·Class.startTime/endTime(대표값)·ClassSchedule(회차)는 그대로 보존(하위호환).
model ClassDaySchedule {
  id        String   @id @default(cuid())
  classId   String   @map("class_id")
  dayOfWeek String   @map("day_of_week") // "월"~"일" (class_days 와 동일 한글 표기 SoT)
  startTime String   @map("start_time") // "HH:mm" 문자열
  endTime   String   @map("end_time") // "HH:mm" 문자열
  venueId   String?  @map("venue_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  class Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  venue Venue? @relation("ClassDayScheduleVenue", fields: [venueId], references: [id], onDelete: SetNull)

  @@unique([classId, dayOfWeek])
  @@index([classId])
  @@index([venueId])
  @@map("class_day_schedules")
}

/// 수업 일정 - 개별 수업 세션 (취소 관리)
model ClassSchedule {
  id                 String    @id @default(cuid())
  classId            String    @map("class_id")
  scheduledDate      DateTime  @map("scheduled_date")
  /// [2026-06-09] 오픈클래스 날짜별 일정 — 일정마다 시간/장소를 직접 지정(미니달력 입력).
  startTime          String?   @map("start_time") /// "HH:mm"
  endTime            String?   @map("end_time") /// "HH:mm"
  venueId            String?   @map("venue_id")
  isCancelled        Boolean   @default(false) @map("is_cancelled")
  cancellationReason String?   @map("cancellation_reason")
  rsvpDeadline       DateTime? @map("rsvp_deadline") /// RSVP 마감 시간 (null이면 수업 시작 24시간 전 자동 계산)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relationships
  class         Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  venue         Venue?               @relation(fields: [venueId], references: [id], onDelete: SetNull)
  attendances   ClassAttendance[]
  attendanceQRs AttendanceQR[]
  rsvps         ClassRsvp[] /// RSVP 참석/불참 응답 목록
  auditLogs     AttendanceAuditLog[] /// PR-C (v0.5)

  @@index([classId])
  @@index([scheduledDate])
  @@index([isCancelled])
  @@index([classId, scheduledDate, isCancelled]) // P0: 정산/통계 핫패스
  @@map("class_schedules")
}

/// 수업 상품 - 수업 가격 및 크레딧 패키지
model ClassProduct {
  id               String   @id @default(cuid())
  classId          String   @map("class_id")
  productName      String   @map("product_name")
  description      String?
  price            Int // ₩ KRW
  sessionsPerMonth Int      @map("sessions_per_month")
  durationDays     Int      @default(30) @map("duration_days")
  // 결제 방식: MONTHLY_FIXED(월정액), PER_SESSION(횟수제), PER_GAME(경기당)
  feeType          String   @default("PER_SESSION") @map("fee_type")
  // 결제 시점: PREPAID(선결제), POSTPAID(후결제)
  billingTiming    String   @default("PREPAID") @map("billing_timing")
  sessionsPerWeek  Int?     @map("sessions_per_week")
  feePerSession    Decimal? @map("fee_per_session") @db.Decimal(10, 2)
  isActive         Boolean  @default(true) @map("is_active") /// 상품 활성화 여부
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relationships
  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  payments    Payment[]
  enrollments Enrollment[] /// 해당 상품으로 신청된 수강신청 목록

  @@index([classId])
  @@index([feeType])
  @@index([billingTiming])
  @@index([isActive])
  @@map("class_products")
}

// ==================== Payments & Credits ====================

/// 결제 - 결제 거래 정보 (KG이니시스 연동)
model Payment {
  id            String    @id @default(cuid())
  orderNumber   String    @unique @map("order_number")
  userId        String    @map("user_id")
  productId     String?   @map("product_id")
  amount        Int // ₩ KRW
  paymentStatus String    @default("pending") @map("payment_status") // pending|completed|failed|refunded
  paymentMethod String?   @map("payment_method") // card|wallet
  tid           String?   @map("tid") // KG이니시스 거래번호
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  completedAt   DateTime? @map("completed_at")
  deletedAt     DateTime? @map("deleted_at") /// Soft Delete (NEW-06 — 2026-05-21, PIPA 5년 보존 + 회계 감사 대비)

  // Relationships
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product                 ClassProduct?            @relation(fields: [productId], references: [id])
  credits                 MemberCredit[]
  refundLogs              RefundLog[]
  eventRegistrations      TeamEventRegistration[]
  enrollments             Enrollment[] /// 해당 결제로 완료된 수강신청 목록
  tournamentRegistrations TournamentRegistration[]
  pickupMatchApplicants   PickupMatchApplicant[] /// 픽업 매치 참가비 결제 연결

  // 정산 상세 내역 (1:N)
  settlementDetails SettlementDetail[]

  // 월별 후불 청구 라인 (모드 A — POSTPAID)
  monthlyBillingLines MonthlyPostpaidBillingLine[]

  // 영수증 (1:1)
  receipt PaymentReceipt?

  @@index([userId])
  @@index([paymentStatus])
  @@index([createdAt])
  // W7-2: 대시보드 집계 최적화
  @@index([paymentStatus, completedAt]) /// todayRevenue / weeklyRevenue / 월간 매출 집계
  @@index([userId, paymentStatus, createdAt]) /// parent/coach/admin의 유저별 결제 조회
  @@map("payments")
}

/// 회원 크레딧 - 수업 크레딧 잔액 (90일 만료)
/// 수업권 (구 MemberCredit) - 회원이 특정 수업에 출석할 수 있는 회차 잔량.
/// 2026-04-27 정정 (N-9): "클럽 회원 단위 통합 풀" → "사용자(User) × 수업(Class) 단위" 로 의미 변경.
/// Team/Academy 무관 동일 모델 사용. TeamMember.id 결합 제거.
model MemberCredit {
  id            String   @id @default(cuid())
  userId        String   @map("user_id") /// 출석 주체 (자녀 User.id)
  classId       String   @map("class_id") /// 어느 수업의 수업권인가 (수업 단위 결합)
  totalSessions Int      @map("total_sessions") /// 발급된 총 회차 (구 totalCredits)
  usedSessions  Int      @default(0) @map("used_sessions") /// 사용된 회차 (구 usedCredits)
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  issuedDate    DateTime @default(now()) @map("issued_date")
  updatedAt     DateTime @updatedAt @map("updated_at")
  paymentId     String?  @map("payment_id")

  // Relationships
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  class        Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  payment      Payment?            @relation(fields: [paymentId], references: [id])
  transactions CreditTransaction[]

  @@index([userId])
  @@index([classId])
  @@index([expiresAt])
  @@index([userId, classId, expiresAt]) // P0: 출석 차감 핫패스 (수업+사용자 유효 수업권 FIFO)
  @@map("member_credits")
}

/// 환불 로그 - 환불 처리 내역
model RefundLog {
  id           String   @id @default(cuid())
  paymentId    String   @map("payment_id")
  refundAmount Int      @map("refund_amount")
  refundReason String   @map("refund_reason")
  processedAt  DateTime @default(now()) @map("processed_at")

  // Relationships
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("refund_logs")
}

// ==================== Attendance ====================

/// 출석 기록 - QR 체크인 기반 출석 관리
/// 출석 기록 - 회원 출석 관리.
/// 2026-04-27 (D-F + R4): 출처 추적 컬럼 5개 추가 — checkedInVia/checkedInBy + 코치 수정 추적(modifiedBy/At/Reason).
model ClassAttendance {
  id               String    @id @default(cuid())
  scheduleId       String    @map("schedule_id")
  memberId         String    @map("member_id") /// User.id (출석 대상자)
  attendanceStatus String    @default("unchecked") @map("attendance_status") // present|absent|unchecked (3-state, 2026-05-12 회의록 결정 — 이전 late/excused/cancelled 제거)
  checkedInAt      DateTime? @map("checked_in_at")
  creditDeducted   Boolean   @default(false) @map("credit_deducted")

  // 2026-04-27 (D-F + R4): 출석 출처 + 자녀 QR → 학부모 알림 트리거 + 감사 추적
  checkedInVia String? @map("checked_in_via") /// qr_scan|parent_button|coach_manual
  checkedInBy  String? @map("checked_in_by") /// 실제 클릭한 User.id (proxy 추적)

  // 2026-04-27 (F-2 + N-5): 코치 수정 추적
  modifiedBy     String?   @map("modified_by") /// 수정자 User.id (코치/관리자)
  modifiedAt     DateTime? @map("modified_at")
  modifiedReason String?   @map("modified_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  schedule        ClassSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  member          User          @relation("AttendanceMember", fields: [memberId], references: [id], onDelete: Cascade)
  checkedInByUser User?         @relation("AttendanceCheckedInBy", fields: [checkedInBy], references: [id])
  modifiedByUser  User?         @relation("AttendanceModifiedBy", fields: [modifiedBy], references: [id])

  // Unique constraint on (schedule_id, member_id)
  @@unique([scheduleId, memberId])
  @@index([memberId])
  @@index([createdAt])
  @@index([memberId, createdAt])
  // W7-2: 대시보드 count 집계 최적화
  @@index([attendanceStatus, scheduleId]) /// 오늘/월간 present/late/absent count
  @@index([memberId, attendanceStatus]) /// child-dashboard 멤버별 출석 상태 필터
  @@index([checkedInVia]) /// 출처별 통계 (QR 폐기 진행 모니터링)
  @@map("class_attendances")
}

/// PR-C (v0.6): AuditLog actor role enum — 액션 당시 사용자의 역할 보존
enum AuditActorRole {
  COACH
  DIRECTOR
  ACADEMY_DIRECTOR
  PARENT
  CHILD
  TEEN
  ADMIN
  SYSTEM
}

/// PR-C (v0.6): AuditLog action type enum — 5종 (24h 이의제기 폐기로 5종 유지)
enum AuditActionType {
  check_in
  modify
  clear
  auto_expire
  refund
}

/// PR-C (v0.5): 출석 변경 감사 로그 — append-only (INSERT only).
/// 모든 출석 변경(check_in / modify / clear / auto_expire / refund) 시 1줄 INSERT.
/// 영구 보존 — 학부모-코치 분쟁 시 증거 능력 보장.
/// 24h 이의제기 워크플로우는 v0.5 에서 폐기 — 본 모델은 단순 추적 용도.
/// PR-C (v0.6): actorRole/actionType 컬럼을 enum 으로 타입 안전성 강화.
model AttendanceAuditLog {
  id           String  @id @default(cuid())
  attendanceId String? @map("attendance_id") /// null = 신규 생성/삭제 케이스 (외래키 아닌 단순 reference)
  scheduleId   String  @map("schedule_id")
  memberId     String  @map("member_id") /// 학생 User.id

  actorUserId String         @map("actor_user_id") /// 실제 액션한 사람 (cron 은 SYSTEM 사용자 id)
  actorRole   AuditActorRole @map("actor_role")

  actionType  AuditActionType @map("action_type")
  fromStatus  String?         @map("from_status")
  toStatus    String          @map("to_status")
  creditDelta Int             @default(0) @map("credit_delta") /// -1/+1/0/+N(환불)

  notifiedParentId String?   @map("notified_parent_id") /// modify 액션 시 알림 대상 학부모
  notifiedAt       DateTime? @map("notified_at") /// 알림톡 큐 적재 시각

  reason    String?  @db.Text /// 사유 (modify 시 의무 입력 — PR-D)
  requestId String?  @map("request_id") /// X-Request-ID (API 요청 추적)
  clientIp  String?  @map("client_ip")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  // Relationships
  schedule       ClassSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  member         User          @relation("AuditLogMember", fields: [memberId], references: [id])
  actor          User          @relation("AuditLogActor", fields: [actorUserId], references: [id])
  notifiedParent User?         @relation("AuditLogNotifiedParent", fields: [notifiedParentId], references: [id])

  @@index([memberId, createdAt])
  @@index([scheduleId])
  @@index([actorUserId, createdAt])
  @@map("attendance_audit_logs")
}

// ==================== Notifications ====================

/// 알림 - 인앱 알림 메시지
model Notification {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  notificationType String    @map("notification_type") // payment_success|membership_approved|etc
  title            String
  message          String
  isRead           Boolean   @default(false) @map("is_read")
  readAt           DateTime? @map("read_at") // 읽음 처리 시각
  linkUrl          String?   @map("link_url") // 탭 시 이동 경로
  createdAt        DateTime  @default(now()) @map("created_at")

  // Relationships
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  alimtalkLog AlimtalkLog?
  template    NotificationTemplate? @relation(fields: [templateId], references: [id])
  templateId  String?               @map("template_id")

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([notificationType])
  @@index([userId, isRead])
  @@index([userId, readAt])
  @@map("notifications")
}

/// 알림톡 템플릿 - 카카오 알림톡 본문/변수 관리 (2026-05-13 Phase D-9)
///
/// 기존: alimtalk.gateway.ts 의 getTemplateContent() 하드코딩 stub.
/// 이관: 본 모델에 등록 → 관리자 UI 에서 운영 중 추가/수정 가능.
/// 캐시: AlimtalkGateway 가 5분 메모리 캐시로 DB 부하 차단.
model AlimtalkTemplate {
  id           String   @id @default(cuid())
  /// 카카오 비즈톡센터 등록 템플릿 코드. 예: PAYMENT_SUCCESS_001
  templateCode String   @unique @map("template_code")
  /// 사람이 읽을 수 있는 이름 — 관리자 UI 노출용.
  name         String
  /// 본문 (변수: #{key} 플레이스홀더).
  content      String
  /// 본문 내 치환되는 변수 키 목록. 검증/문서화용.
  variables    String[] @default([])
  /// 활성 여부 (false 면 발송 시 SMS 폴백).
  isActive     Boolean  @default(true) @map("is_active")
  /// 카테고리 (payment / attendance / class / credit / general).
  category     String?
  /// 비고/관리자 메모.
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@map("alimtalk_templates")
}

/// 알림톡 로그 - 카카오 알림톡 발송 기록
model AlimtalkLog {
  id             String    @id @default(cuid())
  notificationId String    @unique @map("notification_id")
  phone          String
  templateCode   String    @map("template_code")
  status         String    @default("pending") // pending|sent|failed
  sentAt         DateTime? @map("sent_at")
  responseData   Json?     @map("response_data") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relationships
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("alimtalk_logs")
}

// ==================== Auditing & Logging ====================

/// 감사 로그 - 시스템 활동 추적 (보안/컴플라이언스)
/// userId는 optional - 인증되지 않은 사용자(로그인 실패 등)의 이벤트도 기록 가능
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id") /// nullable - 인증 전 이벤트 기록용
  action    String
  resource  String
  oldValue  Json?    @map("old_value") @db.JsonB
  newValue  Json?    @map("new_value") @db.JsonB
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  // Relationships - optional relation
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

/// 사용자 활동 로그 - 전체 사용자 행동 추적 (PAGE_VIEW, CLICK, API_CALL, ERROR, LOGIN, LOGOUT)
/// v8.6 (2026-05-20) 신규 — 통합 파일 로깅 시스템의 DB 영속화 레이어
/// 파일(log/YYYY/MM/*.log) + DB 이중 기록 — DB 장애 시에도 파일은 안전망
model UserActivityLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id") /// nullable - 비로그인 사용자 활동도 기록
  sessionId  String?  @map("session_id") /// 클라이언트 세션 식별자 (anonymous tracking)
  platform   String? /// web | admin | app | home | backend
  action     String /// PAGE_VIEW | CLICK | API_CALL | ERROR | LOGIN | LOGOUT | PAYMENT 등
  category   String? /// access | activity | auth | payment | database | system | error-*
  resource   String? /// 페이지 경로 또는 API URL (예: /api/v1/auth/login)
  metadata   Json?    @db.JsonB /// 자유 메타 (button id, query params, status code, requestId 등)
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  durationMs Int?     @map("duration_ms") /// API 요청 등 작업 소요 시간
  createdAt  DateTime @default(now()) @map("created_at")

  // Optional relation — userId가 있으면 User로 연결, 탈퇴 시 SetNull
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([sessionId])
  @@index([platform, createdAt])
  @@index([category, createdAt])
  @@index([createdAt])
  @@map("user_activity_logs")
}

// ==================== Shopping Mall ====================

/// 상품 카테고리 - 4단계 계층 구조 (대분류 > 중분류 > 소분류 > 세분류)
model ShopCategory {
  id           String   @id @default(cuid())
  name         String // 카테고리명
  code         String   @unique // 카테고리 코드 (예: SKT-ICE-PRO-CCM)
  parentId     String?  @map("parent_id") // 상위 카테고리 ID (null이면 최상위)
  level        Int // 계층 레벨 (1: 대분류, 2: 중분류, 3: 소분류, 4: 세분류)
  path         String // 전체 경로 (예: "스케이트 > 아이스하키 > 프로용 > CCM")
  displayOrder Int      @default(0) @map("display_order") // 정렬 순서
  isActive     Boolean  @default(true) @map("is_active") // 활성화 여부
  description  String? // 카테고리 설명
  imageUrl     String?  @map("image_url") @db.Text // 카테고리 이미지
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Self-referential relationship (계층 구조)
  parent   ShopCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ShopCategory[] @relation("CategoryHierarchy")

  // Relationships
  products ShopProduct[]

  @@index([parentId])
  @@index([level])
  @@index([isActive])
  @@index([displayOrder])
  @@map("shop_categories")
}

/// 쇼핑몰 상품 - 판매 상품 정보 (가격, 재고, 브랜드)
model ShopProduct {
  id           String   @id @default(cuid())
  categoryId   String   @map("category_id")
  name         String // 상품명
  code         String   @unique // 상품 코드 (SKU)
  description  String?  @db.Text // 상품 설명
  price        Int // 정상가 (KRW)
  salePrice    Int?     @map("sale_price") // 할인가
  costPrice    Int?     @map("cost_price") // 원가
  stock        Int      @default(0) // 재고 수량
  minOrderQty  Int      @default(1) @map("min_order_qty") // 최소 주문 수량
  maxOrderQty  Int?     @map("max_order_qty") // 최대 주문 수량
  brand        String? // 브랜드
  manufacturer String? // 제조사
  origin       String? // 원산지
  weight       Int? // 무게 (g)
  isActive     Boolean  @default(true) @map("is_active")
  isFeatured   Boolean  @default(false) @map("is_featured") // 추천 상품
  isNew        Boolean  @default(false) @map("is_new") // 신상품
  viewCount    Int      @default(0) @map("view_count") // 조회수
  salesCount   Int      @default(0) @map("sales_count") // 판매량
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relationships
  category   ShopCategory        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images     ShopProductImage[]
  options    ShopProductOption[]
  orderItems ShopOrderItem[]
  wishlists  ShopWishlist[]
  reviews    ShopReview[]
  cartItems  ShopCartItem[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isNew])
  @@index([createdAt])
  @@index([salesCount])
  @@index([price])
  @@map("shop_products")
}

/// 상품 이미지 - 상품별 다중 이미지 (대표 이미지 지정)
model ShopProductImage {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  imageUrl     String   @map("image_url") @db.Text
  altText      String?  @map("alt_text")
  displayOrder Int      @default(0) @map("display_order")
  isMain       Boolean  @default(false) @map("is_main") // 대표 이미지 여부
  createdAt    DateTime @default(now()) @map("created_at")

  // Relationships
  product ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isMain])
  @@map("shop_product_images")
}

/// 상품 옵션 - 사이즈, 색상 등 상품별 선택 옵션
model ShopProductOption {
  id              String   @id @default(cuid())
  productId       String   @map("product_id")
  optionName      String   @map("option_name") // 옵션명 (예: "사이즈", "색상")
  optionValue     String   @map("option_value") // 옵션값 (예: "L", "검정")
  additionalPrice Int      @default(0) @map("additional_price") // 추가금액
  stock           Int      @default(0) // 옵션별 재고
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relationships
  product    ShopProduct     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems ShopOrderItem[]
  cartItems  ShopCartItem[]

  @@index([productId])
  @@index([optionName])
  @@map("shop_product_options")
}

/// 쇼핑몰 장바구니
model ShopCart {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ShopCartItem[]

  @@map("shop_carts")
}

/// 장바구니 상품
model ShopCartItem {
  id        String   @id @default(cuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  optionId  String?  @map("option_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart    ShopCart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product ShopProduct        @relation(fields: [productId], references: [id], onDelete: Cascade)
  option  ShopProductOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, optionId])
  @@index([cartId])
  @@map("shop_cart_items")
}

/// 쇼핑몰 주문 - 주문 정보 및 배송지 관리
model ShopOrder {
  id             String  @id @default(cuid())
  orderNumber    String  @unique @map("order_number") // 주문번호
  userId         String  @map("user_id")
  orderStatus    String  @default("pending") @map("order_status") // pending|paid|preparing|shipped|delivered|cancelled|refunded
  totalAmount    Int     @map("total_amount") // 총 주문금액
  discountAmount Int     @default(0) @map("discount_amount") // 할인금액
  shippingFee    Int     @default(0) @map("shipping_fee") // 배송비
  paymentAmount  Int     @map("payment_amount") // 실결제금액
  paymentMethod  String? @map("payment_method") // card|bank|wallet
  paymentStatus  String  @default("pending") @map("payment_status") // pending|completed|failed|refunded
  tid            String? // 결제 거래번호

  // 배송 정보
  recipientName  String  @map("recipient_name")
  recipientPhone String  @map("recipient_phone")
  zipCode        String  @map("zip_code")
  address        String
  addressDetail  String? @map("address_detail")
  deliveryMemo   String? @map("delivery_memo")

  // 배송 추적
  shippingId  String?   @map("shipping_id")
  shippedAt   DateTime? @map("shipped_at")
  deliveredAt DateTime? @map("delivered_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") /// Soft Delete (NEW-06 — 2026-05-21, 전자상거래법 5년 보존)

  // Relationships
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    ShopOrderItem[]
  shipping ShopShipping?   @relation(fields: [shippingId], references: [id])

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("shop_orders")
}

/// 주문 상품 - 주문별 상품 내역 (주문 시점 스냅샷 저장)
model ShopOrderItem {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  productId   String   @map("product_id")
  optionId    String?  @map("option_id")
  productName String   @map("product_name") // 주문 시점 상품명 스냅샷
  optionName  String?  @map("option_name") // 주문 시점 옵션명
  optionValue String?  @map("option_value") // 주문 시점 옵션값
  quantity    Int
  unitPrice   Int      @map("unit_price") // 주문 시점 단가
  totalPrice  Int      @map("total_price") // 소계
  createdAt   DateTime @default(now()) @map("created_at")

  // Relationships
  order   ShopOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product ShopProduct        @relation(fields: [productId], references: [id])
  option  ShopProductOption? @relation(fields: [optionId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("shop_order_items")
}

/// 택배사 - 배송 택배사 정보 (배송조회 URL 포함)
model ShopShippingCompany {
  id           String   @id @default(cuid())
  name         String // 택배사명 (예: CJ대한통운, 롯데택배)
  code         String   @unique // 택배사 코드 (예: CJ, LOTTE)
  trackingUrl  String?  @map("tracking_url") @db.Text // 배송조회 URL 템플릿
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relationships
  shippings ShopShipping[]

  @@index([isActive])
  @@map("shop_shipping_companies")
}

/// 배송 정보 - 송장번호 및 배송 상태 추적
model ShopShipping {
  id             String    @id @default(cuid())
  companyId      String    @map("company_id")
  trackingNumber String    @map("tracking_number") // 송장번호
  status         String    @default("preparing") // preparing|shipped|in_transit|out_for_delivery|delivered
  shippedAt      DateTime? @map("shipped_at")
  deliveredAt    DateTime? @map("delivered_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relationships
  company ShopShippingCompany @relation(fields: [companyId], references: [id])
  orders  ShopOrder[]

  @@index([companyId])
  @@index([trackingNumber])
  @@index([status])
  @@map("shop_shippings")
}

/// 배송 정책 - 배송비 및 무료배송 기준 관리
model ShippingPolicy {
  id                    String   @id @default(cuid())
  name                  String // 정책명 (예: 기본 배송, 익일 배송)
  type                  String   @default("standard") // standard|express|pickup
  shippingFee           Int      @map("shipping_fee") // 배송비 (원)
  freeShippingThreshold Int?     @map("free_shipping_threshold") // 무료배송 최소 금액 (원)
  additionalFee         Int      @default(0) @map("additional_fee") // 제주/도서산간 추가 배송비 (원)
  estimatedDays         String?  @map("estimated_days") // 예상 배송일 (예: "2-3")
  regions               String?  @db.Text // 적용 지역 (JSON 배열, null이면 전국)
  surcharge             Int      @default(0) // 지역 조건 충족 시 부과되는 추가 요금 (원)
  isDefault             Boolean  @default(false) @map("is_default") // 기본 정책 여부
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([isActive])
  @@index([isDefault])
  @@map("shipping_policies")
}

// ==================== 추가 테이블 (누락 보완) ====================

/// 수업 등록 - 학생이 어떤 수업에 등록되어 있는지 추적.
/// 2026-04-27 정정 (N-9): memberId(TeamMember.id) → userId(User.id) 로 통일.
/// Team/Academy 수업 모두 동일 모델 사용. TeamMember 가입 자격은 별도 검증.
model ClassRegistration {
  id               String   @id @default(cuid())
  classId          String   @map("class_id")
  userId           String   @map("user_id") /// 출석 주체 (자녀 User.id)
  registrationDate DateTime @default(now()) @map("registration_date")
  status           String   @default("active") // active, inactive, suspended
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relationships
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([userId])
  @@index([status])
  @@map("class_registrations")
}

/// 대기자 목록 - 수업 정원 초과 시 대기 순번 관리 (자동 승격 지원)
model Waitlist {
  id          String    @id @default(cuid())
  classId     String    @map("class_id")
  scheduleId  String?   @map("schedule_id")
  userId      String    @map("user_id")
  childId     String?   @map("child_id")
  position    Int // 대기 순번
  status      String    @default("WAITING") @map("status") // WAITING, CONFIRMED, CANCELLED, EXPIRED
  notifiedAt  DateTime? @map("notified_at")
  confirmedAt DateTime? @map("confirmed_at")
  expiresAt   DateTime? @map("expires_at") // 확인 응답 기한 (승격 후 24시간)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relationships
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation("WaitlistUser", fields: [userId], references: [id], onDelete: Cascade)
  child User? @relation("WaitlistChild", fields: [childId], references: [id])

  @@unique([classId, userId, childId])
  @@index([classId, status])
  @@index([userId])
  @@index([position])
  @@map("waitlists")
}

/// 크레딧 거래 내역 - 크레딧 차감/적립/환불 로그
model CreditTransaction {
  id             String   @id @default(cuid())
  memberCreditId String   @map("member_credit_id")
  type           String // earned, deducted, restored, expired
  amount         Int // 변동 크레딧 수
  balanceAfter   Int      @map("balance_after") // 거래 후 잔액
  scheduleId     String?  @map("schedule_id") // 출석으로 차감된 경우
  refundId       String?  @map("refund_id") // 환불로 복원된 경우
  reason         String? // 변동 사유
  adjustedBy     String?  @map("adjusted_by") // 관리자 크레딧 조정 시 조정자 User.id
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at") /// DB 레거시 NOT NULL 컬럼 호환용 (append-only 로그이므로 실질 갱신 없음)

  // Relationships
  memberCredit MemberCredit @relation(fields: [memberCreditId], references: [id], onDelete: Cascade)
  adjuster     User?        @relation("CreditAdjuster", fields: [adjustedBy], references: [id])

  @@index([memberCreditId])
  @@index([type])
  @@index([createdAt])
  @@index([adjustedBy])
  @@map("credit_transactions")
}

/// 시스템 공지 - 관리자 공지사항 (학년별 타겟 지원)
model SystemNotice {
  id                   String    @id @default(cuid())
  title                String // 공지 제목
  content              String    @db.Text // 공지 내용
  priority             Int       @default(0) // 정렬 우선순위 (고정 여부는 pinned 컬럼 사용 · priority 는 향후 정렬 가중치용 예약, @@index([priority]) 정렬 대비 유지)
  targetType           String?   @map("target_type") // all, parent, coach, admin (대상 사용자)
  isActive             Boolean   @default(true) @map("is_active")
  viewCount            Int       @default(0) @map("view_count") // 조회수
  pinned               Boolean   @default(false) @map("pinned") // 고정 공지 여부
  createdBy            String?   @map("created_by") // 작성자 ID
  createdAt            DateTime  @default(now()) @map("created_at")
  expiresAt            DateTime? @map("expires_at") // 만료일
  startAt              DateTime? @map("start_at")
  maintenanceReason    String?   @map("maintenance_reason") // 점검 사유(점검 공지 전용 · M4 화면 표시)
  displayLocationsJson Json      @default("[]") @map("display_locations_json") @db.JsonB

  // 학년별 타겟 공지 (출생연도 범위로 필터링)
  targetBirthYearFrom Int?    @map("target_birth_year_from") // 대상 출생연도 시작 (예: 2015 → 초등 1학년)
  targetBirthYearTo   Int?    @map("target_birth_year_to") // 대상 출생연도 종료 (예: 2020 → 5세)
  targetTeamId        String? @map("target_team_id") // 특정 팀 대상 공지

  // per-user 읽음 로그 (NoticeRead)
  reads NoticeRead[]

  // 댓글
  comments NoticeComment[]

  @@index([isActive])
  @@index([priority])
  @@index([createdAt])
  @@index([isActive, startAt])
  @@index([targetTeamId])
  @@index([pinned, createdAt])
  @@map("system_notices")
}

/// 공지 읽음 로그 - 사용자별 공지 읽음 추적
model NoticeRead {
  id       String   @id @default(cuid())
  noticeId String   @map("notice_id")
  userId   String   @map("user_id")
  readAt   DateTime @default(now()) @map("read_at")

  notice SystemNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
  @@index([userId, readAt])
  @@map("notice_reads")
}

/// 공지 댓글 - 공지사항에 대한 사용자 댓글
model NoticeComment {
  id        String   @id @default(cuid())
  noticeId  String   @map("notice_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  notice SystemNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user   User         @relation("UserNoticeComments", fields: [userId], references: [id])

  @@index([noticeId])
  @@index([userId])
  @@map("notice_comments")
}

/// 1일 1회 조회수 제한을 위한 통합 뷰 로그 테이블
/// - 모든 viewCount 대상(공지/아카데미홍보/커뮤니티/TMS/상품/영상)을 단일 테이블로 관리
/// - entityType + entityId + userId + viewedDate UNIQUE 제약으로 동일 사용자의 같은 날 중복 카운트를 원자적으로 차단
/// - INSERT 성공 = 오늘 첫 조회 → viewCount += 1
/// - INSERT 실패(P2002) = 오늘 이미 조회 → 카운트 유지
model DailyViewLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type") // notice | academy_promotion | club_post | tms_post | shop_product | video
  entityId   String   @map("entity_id")
  userId     String   @map("user_id")
  viewedDate String   @map("viewed_date") @db.Char(10) // 'YYYY-MM-DD' (KST 기준)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([entityType, entityId, userId, viewedDate], map: "daily_view_logs_unique")
  @@index([entityType, entityId])
  @@index([userId])
  @@index([viewedDate])
  @@map("daily_view_logs")
}

/// 아카데미 홍보 - 코치/감독이 레슨 홍보 게시물 등록
model AcademyPromotion {
  id           String    @id @default(cuid())
  coachId      String    @map("coach_id")
  teamId       String?   @map("team_id")
  academyId    String?   @map("academy_id") /// 아카데미 ID (독립 아카데미 홍보)
  classId      String?   @map("class_id") /// 연동된 실제 수업 ID
  title        String // 홍보 제목
  content      String    @db.Text // 홍보 내용
  imageUrl     String?   @map("image_url") @db.Text // 홍보 이미지 URL
  lessonType   String    @map("lesson_type") // PRIVATE, GROUP, GAME_LESSON, FUN
  scheduleInfo String?   @map("schedule_info") /// "매주 월/수 19:30~21:00"
  priceInfo    String?   @map("price_info") // "3회 20만원 / 4회 26만원"
  capacity     Int? // 정원
  venueInfo    String?   @map("venue_info") // "IN CHEON 블랙아이스A"
  contactPhone String?   @map("contact_phone")
  isActive     Boolean   @default(true) @map("is_active")
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  viewCount    Int       @default(0) @map("view_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relationships
  coach   User     @relation("PromotionCoach", fields: [coachId], references: [id])
  team    Team?    @relation(fields: [teamId], references: [id])
  academy Academy? @relation(fields: [academyId], references: [id])
  class   Class?   @relation("PromotionClass", fields: [classId], references: [id])

  @@index([isActive, createdAt])
  @@index([coachId])
  @@index([academyId])
  @@index([classId])
  @@index([lessonType])
  @@map("academy_promotions")
}

/// 알림 템플릿 - 알림톡/푸시 템플릿 관리
model NotificationTemplate {
  id           String   @id @default(cuid())
  templateCode String   @unique @map("template_code") // payment_success, membership_approved
  templateName String   @map("template_name") // 템플릿 이름
  content      String   @db.Text // {{name}}, {{amount}} 등 플레이스홀더 포함
  channel      String   @default("alimtalk") // alimtalk, push, email
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relationships
  notifications Notification[]

  @@index([channel])
  @@index([isActive])
  @@map("notification_templates")
}

/// 사용자 알림 설정 - 사용자별 알림 수신 설정
model UserNotificationPreference {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  pushEnabled       Boolean  @default(true) @map("push_enabled") // 푸시 알림
  smsEnabled        Boolean  @default(true) @map("sms_enabled") // SMS/알림톡
  emailEnabled      Boolean  @default(false) @map("email_enabled") // 이메일
  quietHoursStart   String?  @map("quiet_hours_start") // 방해금지 시작 (예: "22:00")
  quietHoursEnd     String?  @map("quiet_hours_end") // 방해금지 종료 (예: "08:00")
  quietHoursEnabled Boolean  @default(false) @map("quiet_hours_enabled")
  soundEnabled      Boolean  @default(true) @map("sound_enabled")
  vibrationEnabled  Boolean  @default(true) @map("vibration_enabled")
  /// 카테고리별 수신 여부 JSON: { class: bool, payment: bool, notice: bool, system: bool }
  categories        Json     @default("{\"class\":true,\"payment\":true,\"notice\":true,\"system\":true}") @db.JsonB
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}

/// 결제 웹훅 로그 - KG이니시스 웹훅 로깅 및 재처리
model PaymentWebhook {
  id             String    @id @default(cuid())
  paymentId      String?   @map("payment_id") // 연결된 결제 ID
  webhookType    String    @map("webhook_type") // kg_inicis, refund
  webhookPayload Json      @map("webhook_payload") @db.JsonB // 웹훅 페이로드
  signature      String? // 서명 값
  verified       Boolean   @default(false) // 검증 여부
  status         String    @default("pending") // pending|success|failed|retrying
  retryCount     Int       @default(0) @map("retry_count") // 재시도 횟수
  maxRetries     Int       @default(3) @map("max_retries") // 최대 재시도 횟수
  lastError      String?   @map("last_error") // 마지막 오류 메시지
  errorMessage   String?   @map("error_message") // 오류 메시지 (레거시)
  nextRetryAt    DateTime? @map("next_retry_at") // 다음 재시도 시각
  processedAt    DateTime  @default(now()) @map("processed_at")
  completedAt    DateTime? @map("completed_at") // 처리 완료 시각

  @@index([paymentId])
  @@index([webhookType])
  @@index([processedAt])
  @@index([status])
  @@index([nextRetryAt])
  @@map("payment_webhooks")
}

// ==================== Identity Verification (본인인증) ====================

/// 본인인증 요청 - 4개 제공자 (KG이니시스, 카카오, NICE, PASS) 지원
model IdentityVerification {
  id        String  @id @default(cuid())
  userId    String? @map("user_id") /// 회원가입 전이면 NULL
  requestId String  @unique @map("request_id") /// 고유 요청 ID (UUID)
  provider  String /// kg_inicis | kakao | nice | pass
  status    String  @default("pending") /// pending | processing | completed | failed | expired

  // 인증 결과 (암호화 저장)
  ci             String? /// 연계정보 (Connecting Information) - AES-256 암호화
  ciHash         String? @map("ci_hash") /// [2026-06-10] CI 결정적 HMAC — register 시 User.ciHash 중복검사에 사용
  di             String? /// 중복가입확인정보 (Duplicate Information) - AES-256 암호화
  verifiedName   String? @map("verified_name") /// 인증된 실명
  verifiedPhone  String? @map("verified_phone") /// 인증된 전화번호
  verifiedBirth  String? @map("verified_birth") /// 인증된 생년월일 (YYYYMMDD)
  verifiedGender String? @map("verified_gender") /// 성별 (M/F)

  // 요청 정보
  purpose   String /// registration | payment | profile_update
  returnUrl String? @map("return_url") /// 인증 완료 후 리다이렉트 URL
  clientIp  String? @map("client_ip") /// 요청 IP
  userAgent String? @map("user_agent") /// 요청 User-Agent

  // 타임스탬프
  requestedAt DateTime  @default(now()) @map("requested_at")
  verifiedAt  DateTime? @map("verified_at")
  expiresAt   DateTime  @map("expires_at") /// 인증 요청 만료 시간 (30분)

  // 에러 정보
  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message")

  // Relationships
  user        User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  webhookLogs IdentityWebhookLog[]

  @@index([userId])
  @@index([provider])
  @@index([status])
  @@index([purpose])
  @@index([requestedAt])
  @@index([expiresAt])
  @@map("identity_verifications")
}

/// 본인인증 웹훅 로그 - 제공자 콜백 로깅
model IdentityWebhookLog {
  id                     String   @id @default(cuid())
  identityVerificationId String   @map("identity_verification_id")
  provider               String /// kg_inicis | kakao | nice | pass
  webhookType            String   @map("webhook_type") /// callback | webhook | redirect
  webhookPayload         Json     @map("webhook_payload") @db.JsonB /// 원본 페이로드 (민감정보 마스킹)
  signature              String? /// 서명 값
  verified               Boolean  @default(false) /// 서명 검증 성공 여부
  httpStatus             Int?     @map("http_status") /// HTTP 응답 상태 코드
  errorMessage           String?  @map("error_message")
  processedAt            DateTime @default(now()) @map("processed_at")

  // Relationships
  identityVerification IdentityVerification @relation(fields: [identityVerificationId], references: [id], onDelete: Cascade)

  @@index([identityVerificationId])
  @@index([provider])
  @@index([webhookType])
  @@index([processedAt])
  @@map("identity_webhook_logs")
}

// ==================== App Management (앱 관리) ====================

/// 앱 메뉴 - 사용자 유형별 네비게이션 메뉴 관리
model AppMenu {
  id        String   @id @default(cuid())
  userType  UserType @map("user_type") /// 대상 사용자 유형
  label     String /// 메뉴 이름
  icon      String /// 아이콘 이름 (Lucide 또는 Material Icon)
  href      String /// 이동 경로
  parentId  String?  @map("parent_id") /// 상위 메뉴 ID (계층 구조용)
  order     Int      @default(0) /// 정렬 순서
  isActive  Boolean  @default(true) @map("is_active") /// 활성화 여부
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Self-referential relationship for sub-menus
  parent   AppMenu?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children AppMenu[] @relation("MenuHierarchy")

  @@index([userType])
  @@index([isActive])
  @@index([parentId])
  @@map("app_menus")
}

// ==================== Parent-Child Relationship (학부모-자녀 관계) ====================

/// 학부모-자녀 관계 테이블
/// ParentProfile.children (JSON 배열) 대신 정규화된 관계형 테이블
/// 한 자녀에 여러 보호자(부모, 조부모 등) 연결 가능
model ParentChild {
  id           String   @id @default(cuid())
  parentId     String   @map("parent_id") /// 학부모 User ID
  childId      String   @map("child_id") /// 자녀 User ID
  relationship String   @default("parent") /// parent | guardian | grandparent | other
  isPrimary    Boolean  @default(true) @map("is_primary") /// 주 보호자 여부 (결제/승인 권한)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relationships
  parent User @relation("ParentChildren", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("ChildParents", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([childId])
  @@index([isPrimary])
  @@map("parent_children")
}

// ==================== Enrollment (수강신청) ====================

/// 수강신청 테이블
/// 방식1: 학부모가 직접 자녀 수강신청 (parent_direct)
/// 방식2: 자녀가 요청 → 학부모 승인 후 결제 (child_request)
/// 중요: 두 방식 모두 결제는 학부모만 가능
model Enrollment {
  id String @id @default(cuid())

  // 신청 대상
  childId        String  @map("child_id") /// 수강할 자녀 User ID
  classId        String  @map("class_id") /// 신청할 수업 ID
  classProductId String? @map("class_product_id") /// 선택한 상품 (월정액 등)

  // 신청 정보
  requestedBy String @map("requested_by") /// 신청자 ID (학부모 or 자녀)
  requestType String @default("parent_direct") @map("request_type") /// parent_direct | child_request

  // 상태 관리
  /// pending: 초기 상태 (방식1)
  /// pending_approval: 자녀 요청 후 학부모 승인 대기 (방식2)
  /// approved: 승인됨 (결제 진행 가능)
  /// rejected: 거절됨
  /// paid: 결제 완료
  /// cancelled: 취소됨
  /// expired: 승인 대기 만료 (72시간)
  status String @default("pending")

  // 승인 정보 (방식2 전용)
  approvedBy      String?   @map("approved_by") /// 승인한 학부모 User ID
  approvedAt      DateTime? @map("approved_at")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?   @map("rejection_reason") @db.Text

  // 결제 연결 (학부모만 결제 가능)
  paymentId String?   @map("payment_id") /// 결제 완료 시 연결되는 Payment ID
  paidAt    DateTime? @map("paid_at")

  // 타임스탬프
  createdAt   DateTime @default(now()) @map("created_at")
  requestedAt DateTime @default(now()) @map("requested_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  expiresAt   DateTime @map("expires_at") /// 승인 대기 만료 시간 (72시간)

  // 메모
  note String? @db.Text

  // Relationships
  child        User                @relation("ChildEnrollments", fields: [childId], references: [id], onDelete: Cascade)
  class        Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  product      ClassProduct?       @relation(fields: [classProductId], references: [id], onDelete: SetNull)
  requester    User                @relation("EnrollmentRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  approver     User?               @relation("EnrollmentApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  payment      Payment?            @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  classHistory PlayerClassHistory?

  @@index([childId])
  @@index([classId])
  @@index([requestedBy])
  @@index([status])
  @@index([requestType])
  @@index([expiresAt])
  @@index([status, requestedAt]) // P0: 72h 만료 스케줄러 최적화
  @@map("enrollments")
}

// ==================== QR Attendance ====================

/// QR 출석 코드 - QR 코드 생성/추적
model AttendanceQR {
  id          String    @id @default(cuid())
  scheduleId  String    @map("schedule_id") // 수업 일정 ID
  generatedBy String    @map("generated_by") // QR 생성한 코치 User ID
  qrData      String    @unique @map("qr_data") // QR 코드 데이터
  generatedAt DateTime  @default(now()) @map("generated_at")
  expiresAt   DateTime  @map("expires_at") // 만료 시간
  scannedAt   DateTime? @map("scanned_at") // 스캔된 시간
  scannedBy   String?   @map("scanned_by") // 스캔한 회원 User ID

  // Relationships
  schedule  ClassSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  generator User          @relation("AttendanceQRGenerator", fields: [generatedBy], references: [id], onDelete: Cascade)
  scanner   User?         @relation("AttendanceQRScanner", fields: [scannedBy], references: [id])

  @@index([scheduleId])
  @@index([generatedBy])
  @@index([expiresAt])
  @@map("attendance_qr_codes")
}

/// 일간 지표 - 팀별 일간 통계
model DailyMetrics {
  id             String   @id @default(cuid())
  teamId         String   @map("team_id")
  metricDate     DateTime @map("metric_date") @db.Date // 통계 날짜
  activeMembers  Int      @default(0) @map("active_members") // 활성 회원 수
  newMembers     Int      @default(0) @map("new_members") // 신규 회원 수
  classesHeld    Int      @default(0) @map("classes_held") // 진행된 수업 수
  totalAttendees Int      @default(0) @map("total_attendees") // 총 출석자 수
  attendanceRate Int      @default(0) @map("attendance_rate") // 출석률 (0-100)
  totalRevenue   Int      @default(0) @map("total_revenue") // 총 매출 (KRW)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

