// ==================== Team Community ====================

/// 팀 게시글 - 팀/연령대별 공지 및 피드
model TeamPost {
  id           String   @id @default(cuid())
  teamId       String   @map("team_id")
  authorId     String   @map("author_id")
  title        String
  content      String   @db.Text
  postType     String   @default("announcement") @map("post_type") // announcement|lesson|tournament|friendly|survey
  targetLevel  String?  @map("target_level") // U8/U10, beginner/intermediate 등 태그용
  isPinned     Boolean  @default(false) @map("is_pinned")
  isActive     Boolean  @default(true) @map("is_active")
  likeCount    Int      @default(0) @map("like_count") // 좋아요 수 캐시
  commentCount Int      @default(0) @map("comment_count") // 댓글 수 캐시
  viewCount    Int      @default(0) @map("view_count") // 조회수
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relationships
  team        Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  author      User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    TeamPostComment[]
  likes       TeamPostLike[]
  attachments TeamPostAttachment[]

  @@index([teamId])
  @@index([authorId])
  @@index([postType])
  @@index([isActive])
  @@index([teamId, isPinned, createdAt]) // P0: 게시판 정렬 최적화
  @@map("team_posts")
}

/// 팀 게시글 댓글
model TeamPostComment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  post   TeamPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@map("team_post_comments")
}

/// 팀 게시글 좋아요 - 사용자별 좋아요 관리
model TeamPostLike {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relationships
  post TeamPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("team_post_likes")
}

/// 팀 게시글 첨부파일 - 이미지/파일 첨부
model TeamPostAttachment {
  id           String   @id @default(cuid())
  postId       String   @map("post_id")
  fileUrl      String   @map("file_url") @db.Text // S3 URL
  fileName     String   @map("file_name")
  fileType     String   @map("file_type") // image/jpeg, image/png, application/pdf
  fileSize     Int      @map("file_size") // bytes
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relationships
  post TeamPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("team_post_attachments")
}

/// 팀 이벤트 - 정규 수업 외 체험, 클리닉, 대회 참가 등
model TeamEvent {
  id          String   @id @default(cuid())
  teamId      String   @map("team_id")
  title       String
  description String?  @db.Text
  eventType   String   @map("event_type") // clinic|trial|tournament|friendly|meeting
  targetLevel String?  @map("target_level")
  capacity    Int? // 모집 정원 (null 이면 무제한)
  startAt     DateTime @map("start_at")
  endAt       DateTime @map("end_at")
  priceMode   String   @default("payment") @map("price_mode") // payment|credit|free
  priceAmount Int?     @map("price_amount") // 결제형 이벤트 금액
  status      String   @default("draft") // draft|published|closed|cancelled
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relationships
  team          Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  registrations TeamEventRegistration[]

  @@index([teamId])
  @@index([eventType])
  @@index([status])
  @@index([startAt])
  @@index([endAt])
  @@map("team_events")
}

/// 팀 이벤트 참가 신청
model TeamEventRegistration {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  memberId  String   @map("member_id")
  status    String   @default("pending") // pending|confirmed|cancelled|waiting
  paid      Boolean  @default(false)
  paymentId String?  @map("payment_id")
  memo      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relationships
  event   TeamEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member  TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  payment Payment?   @relation(fields: [paymentId], references: [id])

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
  @@index([status])
  @@map("team_event_registrations")
}

// ==================== Tournaments & Matches ====================

/// 링크장 정보 - 경기장/빙상장 메타데이터
model Rink {
  id        String   @id @default(cuid())
  name      String
  location  String?
  phone     String?
  memo      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tournaments Tournament[]
  matches     HockeyMatch[]

  @@index([name])
  @@map("rinks")
}

/// 토너먼트/대회 정보
model Tournament {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  teamId      String?  @map("team_id") // 주최 팀 (선택)
  rinkId      String?  @map("rink_id")
  venueId     String?  @map("venue_id") // 개최 링크장 (Venue FK · 2026-05-22)
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  status      String   @default("scheduled") // scheduled|ongoing|finished|cancelled
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // 참가 자격 및 비용 설정
  eligibleBirthYearFrom Int?      @map("eligible_birth_year_from") // 참가 자격 출생연도 시작 (예: 2014)
  eligibleBirthYearTo   Int?      @map("eligible_birth_year_to") // 참가 자격 출생연도 종료 (예: 2016)
  /// 참가 자격 출생연도 개별 집합 — Class.targetBirthYears(Int[]) 동일 컨벤션.
  ///  · 비어있으면([]) 기존 eligibleBirthYearFrom/To 범위로 폴백(이중지원).
  eligibleBirthYears    Int[]     @default([]) @map("eligible_birth_years")
  feePerGame            Decimal?  @map("fee_per_game") @db.Decimal(10, 2) // 경기당 참가비
  totalGames            Int?      @map("total_games") // 총 경기 수
  feeType               String?   @map("fee_type") // PER_GAME | TOTAL_FIXED
  /// 결제 모드 — PREPAID | POSTPAID. 기존 Class.billingMode(:616)와 대문자 컨벤션 통일.
  billingMode           String    @default("PREPAID") @map("billing_mode")
  maxParticipants       Int?      @map("max_participants") // 최대 참가 인원 (UI 노출 폐기, 호환용 보존)
  registrationDeadline  DateTime? @map("registration_deadline") // 등록 마감일

  /// [추가 2026-05-11] 참가 연령 그룹 — "ALL" | "U8" | "U9" | "U10" | "U11" | "U12"
  ///  - "ALL" 은 연령 제한 없음 (전체) 의미. DTO 에서 enum 으로 검증.
  ageGroup               String? @map("age_group")
  /// [추가 2026-05-11] 코치/감독이 사전 선택한 참가 선수 User.id 리스트
  ///  · 이 리스트에 포함된 자녀의 학부모 + 본인 학생에게 대회 일정 노출
  ///  · 형식: ["userId1", "userId2", ...]
  selectedParticipantIds Json?   @map("selected_participant_ids")

  /// [추가 2026-06-05] 참가 자격 팀 하위그룹(TeamGroup) ID 리스트.
  ///  · 출생연도(eligibleBirthYearFrom/To)와 함께 참가 대상을 지정한다.
  ///  · 형식: ["groupId1", "groupId2", ...]
  eligibleGroupIds Json? @map("eligible_group_ids")

  /// [추가 2026-05-15 db-keeper] 대회 규정 (자유 텍스트) — 대회 정보 페이지에 노출.
  rules       String?  @map("rules") @db.Text
  /// [추가 2026-05-15 db-keeper] 추가 장소 정보 — rink.location 이외의 보조 안내 텍스트.
  ///  rink 가 없거나 별도 장소를 표기해야 할 때 사용.
  location    String?  @map("location")
  /// [추가 2026-05-15 db-keeper] 상금 (원) — 대회 정보 페이지에 노출. 0 또는 null 이면 미표시.
  prizeAmount Decimal? @map("prize_amount") @db.Decimal(12, 2)

  team          Team?                    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  rink          Rink?                    @relation(fields: [rinkId], references: [id], onDelete: SetNull)
  venue         Venue?                   @relation(fields: [venueId], references: [id], onDelete: SetNull)
  matches       HockeyMatch[]
  playerAwards  PlayerAward[]
  teamAwards    TeamAward[]
  gameExpenses  GameExpense[]
  registrations TournamentRegistration[]

  // 리그 대회 경기 일정
  tournamentMatches TournamentMatch[]

  // 영상
  videos Video[]

  @@index([teamId])
  @@index([rinkId])
  @@index([venueId])
  @@index([startDate])
  @@index([status])
  @@map("tournaments")
}

/// 대회 참가 등록 - 참가 자격 검증 + 비용 자동계산
model TournamentRegistration {
  id            String    @id @default(cuid())
  tournamentId  String    @map("tournament_id")
  userId        String    @map("user_id")
  childId       String?   @map("child_id")
  gamesCount    Int       @map("games_count") // 참가 경기 수
  calculatedFee Decimal   @map("calculated_fee") @db.Decimal(10, 2) // 자동계산된 참가비
  paymentStatus String    @default("PENDING") @map("payment_status") // PENDING|PAID|CANCELLED|REFUNDED|UNPAID(후불 대회 정산 전 — 종료 후 일괄 청구 시 PENDING 전환)
  paymentId     String?   @map("payment_id")
  registeredAt  DateTime  @default(now()) @map("registered_at")
  cancelledAt   DateTime? @map("cancelled_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation("TournamentRegUser", fields: [userId], references: [id], onDelete: Cascade)
  child      User?      @relation("TournamentRegChild", fields: [childId], references: [id], onDelete: SetNull)
  payment    Payment?   @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, userId, childId])
  @@index([tournamentId, paymentStatus])
  @@index([userId])
  @@index([childId])
  @@map("tournament_registrations")
}

/// 경기 정보 - 대회 또는 친선 경기
model HockeyMatch {
  id            String    @id @default(cuid())
  tournamentId  String?   @map("tournament_id")
  rinkId        String?   @map("rink_id")
  venueId       String?   @map("venue_id")
  homeTeamId    String?   @map("home_team_id")
  awayTeamId    String?   @map("away_team_id")
  /// [추가 2026-06-05] 상대팀 자유 텍스트 — awayTeamId(등록 팀) 없이 외부/미등록 팀명 표기.
  ///  대회일정의 "vs 상대팀"을 직접 입력할 때 사용.
  opponentName  String?   @map("opponent_name")
  /// [추가 2026-06-15] 대회일정(경기)별 참가비 — 감독이 일정마다 개별 금액 입력.
  ///  null/0 = 무료. 학부모는 일정들을 선택해 합산 결제하거나 전체 결제한다.
  fee           Decimal?  @map("fee") @db.Decimal(10, 2)
  homeClubId    String?   @map("home_club_id")
  awayClubId    String?   @map("away_club_id")
  scheduledAt   DateTime  @map("scheduled_at")
  startedAt     DateTime? @map("started_at")
  endedAt       DateTime? @map("ended_at")
  homeScore     Int       @default(0) @map("home_score")
  awayScore     Int       @default(0) @map("away_score")
  status        String    @default("scheduled") // scheduled|warmup|in_progress|intermission|completed|postponed|cancelled
  currentPeriod Int?      @map("current_period") // 1|2|3|4(OT)|5(SO)
  round         String? // group|quarter|semi|final
  matchOrder    Int?      @map("match_order")
  refereeMain   String?   @map("referee_main")
  refereeLines  String?   @map("referee_lines")
  gameSheet     Json?     @map("game_sheet")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tournament   Tournament?   @relation(fields: [tournamentId], references: [id])
  rink         Rink?         @relation(fields: [rinkId], references: [id])
  venue        Venue?        @relation(fields: [venueId], references: [id])
  homeTeam     Team?         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team?         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  // Phase 2 (2026-04-29) — 구 Team 모델 폐기, FK CASCADE 제거됨. homeClubId/awayClubId 컬럼은 보존 (레거시)
  periods      MatchPeriod[]
  events       MatchEvent[]
  playerAwards PlayerAward[]
  gameExpenses GameExpense[]

  @@index([tournamentId])
  @@index([rinkId])
  @@index([venueId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([scheduledAt])
  @@index([status])
  @@map("hockey_matches")
}

// ==================== Teams ====================

/// 팀 - 클럽 소속 팀 정보
// Phase 2 (2026-04-29) — 구 Team 모델 폐기, 메타는 Club 으로 흡수, roster는 TeamGroupMember 로 흡수
// Phase 4 완료 — Club → Team rename 완료. "팀 = teams" 으로 통일

/// 팀 그룹 - 팀(Club) 안의 하위 그룹 (예: 선수반 A조, U10 평일반)
/// 감독·코치가 팀 관리 화면에서 직접 생성하는 단위.
model TeamGroup {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id") /// 상위 팀 (clubs.id 참조 — Phase 2 변경)
  name      String /// 그룹 이름
  ageGroup  String?  @map("age_group") /// U8|U9|U10|U11|U12
  createdId String?  @map("created_id") /// 생성한 감독/코치 user.id
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team    Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members TeamGroupMember[]

  @@index([teamId])
  @@index([ageGroup])
  @@index([teamId, isActive])
  @@map("team_groups")
}

/// 팀 그룹 멤버 - 팀 그룹에 소속된 TeamMember (구 TeamRoster + TeamGroupMember 통합)
model TeamGroupMember {
  id           String    @id @default(cuid())
  groupId      String    @map("group_id")
  memberId     String    @map("member_id") /// TeamMember.id
  joinedAt     DateTime  @default(now()) @map("joined_at")
  // Phase 2 (2026-04-29) — TeamRoster 컬럼 흡수
  position     String? /// goalie|defense|forward
  jerseyNumber Int?      @map("jersey_number")
  isCaptain    Boolean   @default(false) @map("is_captain")
  isAltCaptain Boolean   @default(false) @map("is_alt_captain")
  status       String    @default("active") /// active|injured|suspended
  leftAt       DateTime? @map("left_at")

  group  TeamGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  member TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([groupId, memberId])
  @@index([groupId])
  @@index([memberId])
  @@index([status])
  @@index([position])
  @@map("team_group_members")
}

// ==================== Match Details ====================

/// 피리어드 정보 - 경기 피리어드별 스코어
model MatchPeriod {
  id                 String    @id @default(cuid())
  matchId            String    @map("match_id")
  periodNumber       Int       @map("period_number") // 1|2|3|4(OT)|5(SO)
  startedAt          DateTime? @map("started_at")
  endedAt            DateTime? @map("ended_at")
  homeScore          Int       @default(0) @map("home_score")
  awayScore          Int       @default(0) @map("away_score")
  homePenaltyMinutes Int       @default(0) @map("home_penalty_minutes")
  awayPenaltyMinutes Int       @default(0) @map("away_penalty_minutes")

  match HockeyMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, periodNumber])
  @@index([matchId])
  @@map("match_periods")
}

/// 경기 이벤트 - 골/어시스트/페널티 등 경기 중 발생 이벤트
model MatchEvent {
  id              String   @id @default(cuid())
  matchId         String   @map("match_id")
  periodNumber    Int      @map("period_number")
  eventTime       String   @map("event_time") // MM:SS 형식
  eventType       String   @map("event_type") // goal|assist|penalty|shot|save|timeout|period_start|period_end
  teamId          String?  @map("team_id")
  playerId        String?  @map("player_id") // TeamRoster ID
  assistPlayer1Id String?  @map("assist_player1_id")
  assistPlayer2Id String?  @map("assist_player2_id")
  penaltyType     String?  @map("penalty_type") // minor|major|misconduct|game_misconduct
  penaltyMinutes  Int?     @map("penalty_minutes")
  description     String?
  isGameWinner    Boolean  @default(false) @map("is_game_winner")
  isPowerPlay     Boolean  @default(false) @map("is_power_play")
  isShortHanded   Boolean  @default(false) @map("is_short_handed")
  createdAt       DateTime @default(now()) @map("created_at")

  match HockeyMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  // Phase 2 (2026-04-29) — TeamRoster 모델 폐기, FK CASCADE 제거됨. 컬럼은 보존 (Phase 4에서 정리)

  @@index([matchId])
  @@index([eventType])
  @@index([periodNumber])
  @@index([playerId])
  @@map("match_events")
}

// ==================== Venue ====================

/// 구장/경기장 - 빙상장 상세 정보
model Venue {
  id             String   @id @default(cuid())
  teamId         String?  @map("team_id")
  name           String
  address        String?
  addressDetail  String?  @map("address_detail")
  city           String?
  zipCode        String?  @map("zip_code")
  phone          String?
  latitude       Decimal? @db.Decimal(10, 8)
  longitude      Decimal? @db.Decimal(11, 8)
  capacity       Int?
  rinkSize       String?  @map("rink_size") // NHL|International|Olympic
  amenities      Json?    @db.JsonB // locker_rooms|pro_shop|cafe|parking
  operatingHours Json?    @map("operating_hours") @db.JsonB
  status         String   @default("active") // active|maintenance|closed
  imageUrl       String?  @map("image_url") @db.Text
  hourlyRate     Int?     @map("hourly_rate")
  managerId      String?  @map("manager_id")
  description    String?  @db.Text /// 시설 안내 / 소개 (2026-04-12 추가)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  team              Team?              @relation("VenueOwningTeam", fields: [teamId], references: [id], onDelete: SetNull)
  homeTeams         Team[]             @relation("TeamHomeVenue") // 이 링크장을 홈으로 쓰는 팀들 (2026-05-22)
  tournaments       Tournament[] // 이 링크장에서 개최되는 대회들 (2026-05-22)
  classes           Class[]
  classDaySchedules ClassDaySchedule[] @relation("ClassDayScheduleVenue")
  classSchedules    ClassSchedule[]
  matches           HockeyMatch[]

  // 대관 스케줄, 대관 예약, 계약, 반복 스케줄, 휴무, 캠프, 레슨 패키지
  timeSlots       VenueTimeSlot[]
  bookings        VenueBooking[]
  rentalContracts VenueRentalContract[]
  rentalSchedules VenueRentalSchedule[]
  holidays        VenueHoliday[]
  camps           Camp[]
  lessonPackages  LessonPackage[]

  // 리그 대회 경기 장소
  tournamentMatches TournamentMatch[]

  @@index([teamId])
  @@index([status])
  @@index([city])
  @@index([name])
  @@map("venues")
}

// ==================== Settlement ====================

/// 정산 - 팀별 월간 정산 정보
model Settlement {
  id              String    @id @default(cuid())
  teamId          String    @map("team_id")
  settlementMonth String    @map("settlement_month") // YYYY-MM 형식
  totalRevenue    Int       @default(0) @map("total_revenue") // 총 매출
  platformFee     Int       @default(0) @map("platform_fee") // 플랫폼 수수료
  paymentFee      Int       @default(0) @map("payment_fee") // PG 수수료
  refundAmount    Int       @default(0) @map("refund_amount") // 환불 금액
  netAmount       Int       @default(0) @map("net_amount") // 정산 금액
  status          String    @default("pending") // pending|processing|completed|failed
  bankName        String?   @map("bank_name")
  bankAccount     String?   @map("bank_account")
  accountHolder   String?   @map("account_holder")
  scheduledAt     DateTime? @map("scheduled_at") // 정산 예정일
  completedAt     DateTime? @map("completed_at") // 정산 완료일
  approvedBy      String?   @map("approved_by") /// @deprecated — 관리자 매니저 승인 체계로 이관 (SettlementApprovalStatus 참고)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // 매니저 승인 (신규 승인 워크플로우)
  managerId             String?                   @map("manager_id") /// 승인 담당 매니저 User.id
  managerApprovalStatus SettlementApprovalStatus? @map("manager_approval_status") /// 매니저 승인 상태
  managerApprovalAt     DateTime?                 @map("manager_approval_at") /// 매니저 승인 일시

  team         Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  transactions SettlementTransaction[]
  manager      User?                   @relation("SettlementManager", fields: [managerId], references: [id], onDelete: SetNull)
  details      SettlementDetail[]

  @@unique([teamId, settlementMonth])
  @@index([teamId])
  @@index([settlementMonth])
  @@index([status])
  @@index([managerId])
  @@index([managerApprovalStatus])
  @@map("settlements")
}

/// 정산 상세 내역 - 정산에 포함된 거래 내역
model SettlementTransaction {
  id              String   @id @default(cuid())
  settlementId    String   @map("settlement_id")
  paymentId       String?  @map("payment_id")
  transactionType String   @map("transaction_type") // class_payment|shop_order|refund|fee
  amount          Int
  description     String?
  transactionDate DateTime @map("transaction_date")
  createdAt       DateTime @default(now()) @map("created_at")

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@index([paymentId])
  @@index([transactionType])
  @@index([transactionDate])
  @@map("settlement_transactions")
}

// ==================== Skill Evaluation ====================

/// 기술 평가 - 선수 기술 평가 기록
model SkillEvaluation {
  id               String   @id @default(cuid())
  memberId         String   @map("member_id") // TeamMember ID
  coachId          String   @map("coach_id") // User (coach) ID
  classId          String?  @map("class_id")
  evaluationDate   DateTime @map("evaluation_date")
  overallScore     Int      @map("overall_score") // 1-100
  coachComment     String?  @map("coach_comment") @db.Text
  improvementAreas String?  @map("improvement_areas") @db.Text
  status           String   @default("draft") // draft|published
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  member     TeamMember       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  coach      User             @relation("SkillEvaluationCoach", fields: [coachId], references: [id])
  dimensions SkillDimension[]

  @@index([memberId])
  @@index([coachId])
  @@index([classId])
  @@index([evaluationDate])
  @@index([status])
  @@map("skill_evaluations")
}

/// 기술 평가 세부 항목 - 영역별 평가 점수
model SkillDimension {
  id            String  @id @default(cuid())
  evaluationId  String  @map("evaluation_id")
  dimensionName String  @map("dimension_name") // 스케이팅|퍽핸들링|패싱|슛팅|게임운영
  score         Int // 1-100
  comment       String?
  previousScore Int?    @map("previous_score") // 이전 평가 점수
  improvement   Int? // 향상도

  evaluation SkillEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@index([dimensionName])
  @@map("skill_dimensions")
}

// ==================== Badge & Gamification ====================

/// 뱃지 - 아이 동기부여용 뱃지 정의
model Badge {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconUrl     String?  @map("icon_url")
  category    String // attendance|skill|achievement|special
  rarity      String   @default("common") // common|uncommon|rare|epic|legendary
  criteria    Json? // 획득 조건 JSON
  pointValue  Int      @default(0) @map("point_value")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  childBadges ChildBadge[]

  @@index([category])
  @@index([rarity])
  @@index([isActive])
  @@map("badges")
}

/// 아이 획득 뱃지 - 아이가 획득한 뱃지 기록
model ChildBadge {
  id           String   @id @default(cuid())
  childId      String   @map("child_id") // User (child) ID
  badgeId      String   @map("badge_id")
  earnedAt     DateTime @default(now()) @map("earned_at")
  earnedReason String?  @map("earned_reason")
  isDisplayed  Boolean  @default(true) @map("is_displayed") // 프로필 표시 여부
  displayOrder Int      @default(0) @map("display_order")

  child User  @relation(fields: [childId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([childId, badgeId])
  @@index([childId])
  @@index([badgeId])
  @@index([isDisplayed])
  @@map("child_badges")
}

// ==================== Shop Enhancement (찜하기, 리뷰, 쿠폰) ====================

/// 찜하기 - 상품 위시리스트
model ShopWishlist {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  product ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("shop_wishlists")
}

/// 상품 리뷰 - 구매자 리뷰 및 평점
model ShopReview {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  productId    String    @map("product_id")
  orderId      String?   @map("order_id") // 구매 확인용
  rating       Int // 1-5 별점
  title        String? // 리뷰 제목
  content      String    @db.Text // 리뷰 내용
  images       Json      @default("[]") // 리뷰 이미지 URL 배열
  isVerified   Boolean   @default(false) @map("is_verified") // 구매 인증 리뷰
  isVisible    Boolean   @default(true) @map("is_visible") // 공개 여부
  helpfulCount Int       @default(0) @map("helpful_count") // 도움이 됨 수
  adminReply   String?   @map("admin_reply") @db.Text // 관리자 답변
  repliedAt    DateTime? @map("replied_at") // 답변 시간
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user    User        @relation("ShopReviewUser", fields: [userId], references: [id], onDelete: Cascade)
  product ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
  @@index([rating])
  @@index([isVisible])
  @@index([createdAt])
  @@map("shop_reviews")
}

/// 수업 리뷰 - 학부모가 수업 후 작성하는 코치/수업 리뷰
model ClassReview {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") // 작성자 (학부모)
  classId   String   @map("class_id") // 리뷰 대상 수업
  rating    Int // 1-5 별점
  content   String?  @db.Text // 상세 후기 (선택)
  images    Json     @default("[]") // 첨부 사진 URL 배열
  isVisible Boolean  @default(true) @map("is_visible") // 공개 여부
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId]) // 수업당 1회 리뷰
  @@index([classId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
  @@map("class_reviews")
}

/// 쿠폰 정의 - 관리자가 생성하는 쿠폰
model Coupon {
  id                String       @id @default(cuid())
  code              String       @unique // 쿠폰 코드
  name              String // 쿠폰명
  description       String? // 쿠폰 설명
  discountType      DiscountType @map("discount_type") // 할인 유형
  discountValue     Int          @map("discount_value") // 할인 금액/비율
  minOrderAmount    Int?         @map("min_order_amount") // 최소 주문금액
  maxDiscountAmount Int?         @map("max_discount_amount") // 최대 할인금액
  usageLimit        Int?         @map("usage_limit") // 전체 사용 제한
  usagePerUser      Int          @default(1) @map("usage_per_user") // 1인당 사용 제한
  usedCount         Int          @default(0) @map("used_count") // 사용된 횟수
  startDate         DateTime     @map("start_date") // 사용 시작일
  endDate           DateTime     @map("end_date") // 사용 종료일
  isActive          Boolean      @default(true) @map("is_active")
  targetType        CouponTarget @default(ALL) @map("target_type") // 적용 대상
  targetIds         Json         @default("[]") @map("target_ids") // 대상 ID 배열 (카테고리/상품)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  userCoupons UserCoupon[]

  @@index([isActive])
  @@index([startDate, endDate])
  @@map("coupons")
}

/// 할인 유형
enum DiscountType {
  FIXED // 정액 할인
  PERCENTAGE // 정률 할인
}

/// 쿠폰 적용 대상
enum CouponTarget {
  ALL // 전체 상품
  CATEGORY // 특정 카테고리
  PRODUCT // 특정 상품
}

/// 사용자 쿠폰 - 사용자에게 발급된 쿠폰
model UserCoupon {
  id       String    @id @default(cuid())
  userId   String    @map("user_id")
  couponId String    @map("coupon_id")
  isUsed   Boolean   @default(false) @map("is_used")
  usedAt   DateTime? @map("used_at")
  orderId  String?   @map("order_id") // 사용된 주문
  issuedAt DateTime  @default(now()) @map("issued_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
  @@index([userId])
  @@index([couponId])
  @@index([isUsed])
  @@map("user_coupons")
}

// ==================== Member Level & Points ====================

enum LevelApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  DIRECTOR_OVERRIDE
}

/// 회원 레벨 - VIP/충성도 프로그램
model MemberLevel {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  level          Int      @default(1) // 레벨 (1-5: Bronze, Silver, Gold, Platinum, Diamond)
  levelName      String   @default("Bronze") @map("level_name")
  totalPoints    Int      @default(0) @map("total_points") // 총 적립 포인트
  currentPoints  Int      @default(0) @map("current_points") // 현재 사용 가능 포인트
  pointsToNext   Int      @default(1000) @map("points_to_next") // 다음 레벨까지 필요 포인트
  benefits       Json     @default("{}") // 레벨별 혜택 JSON
  levelUpdatedAt DateTime @default(now()) @map("level_updated_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([level])
  @@map("member_levels")
}

/// 회원 레벨 변경 이력 - 연도별 등급 변화 추적
model MemberLevelHistory {
  id            String              @id @default(cuid())
  userId        String              @map("user_id")
  previousLevel Int                 @map("previous_level")
  newLevel      Int                 @map("new_level")
  previousName  String              @map("previous_name")
  newName       String              @map("new_name")
  status        LevelApprovalStatus @default(PENDING_APPROVAL)
  reason        String?
  season        String?
  changedAt     DateTime            @default(now()) @map("changed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([changedAt])
  @@index([season])
  @@index([status])
  @@map("member_level_histories")
}

/// 선수 기술 등급 - 코치 평가 기반 1-3 티어 (MemberLevel VIP와 별도)
model PlayerSkillLevel {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  tier      Int      @default(1) @map("tier") // 1=하위, 2=중위, 3=상위
  tierName  String   @default("하위") @map("tier_name")
  season    String? // 최근 계산 시즌 (예: 2025-2026)
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@map("player_skill_levels")
}

/// 포인트 거래 내역
model PointTransaction {
  id            String          @id @default(cuid())
  userId        String          @map("user_id")
  type          PointActionType // 적립/사용/만료/조정
  amount        Int // 포인트 양 (+/-)
  balance       Int // 거래 후 잔액
  description   String? // 설명
  referenceId   String?         @map("reference_id") // 관련 ID (주문번호 등)
  referenceType String?         @map("reference_type") // 관련 유형 (order/review/event)
  expiresAt     DateTime?       @map("expires_at") // 만료일
  createdAt     DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("point_transactions")
}

/// 포인트 액션 유형
enum PointActionType {
  EARN // 적립
  USE // 사용
  EXPIRE // 만료
  ADJUST // 관리자 조정
  REFUND // 환불 복구
}

// ==================== Chat & Messaging ====================

/// 채팅방 - 1:1 또는 그룹 채팅
model ChatRoom {
  id            String                @id @default(cuid())
  name          String? // 그룹 채팅방 이름
  type          ChatRoomType          @default(DIRECT) // 채팅방 유형
  category      ConsultationCategory? // 상담 카테고리 (상담 채팅방 전용, 일반 채팅은 null)
  teamId        String?               @map("team_id") // 팀 관련 채팅방
  classId       String?               @map("class_id") // 수업 관련 채팅방
  isActive      Boolean               @default(true) @map("is_active")
  lastMessage   String?               @map("last_message") @db.Text
  lastMessageAt DateTime?             @map("last_message_at")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  members      ChatRoomMember[]
  messages     ChatMessage[]
  consultation Consultation?

  @@index([teamId])
  @@index([classId])
  @@index([type])
  @@index([isActive])
  @@index([lastMessageAt])
  @@index([createdAt])
  @@map("chat_rooms")
}

/// 채팅방 유형
enum ChatRoomType {
  DIRECT // 1:1 채팅
  GROUP // 그룹 채팅
  CLASS // 수업 채팅방
  CLUB // 클럽 채팅방
  SUPPORT // 고객 지원
}

/// 채팅방 멤버
model ChatRoomMember {
  id          String    @id @default(cuid())
  roomId      String    @map("room_id")
  userId      String    @map("user_id")
  role        String    @default("member") // admin/moderator/member
  nickname    String? // 채팅방 내 닉네임
  isActive    Boolean   @default(true) @map("is_active")
  isMuted     Boolean   @default(false) @map("is_muted") // 알림 음소거
  lastReadAt  DateTime? @map("last_read_at") // 마지막 읽은 시간
  unreadCount Int       @default(0) @map("unread_count")
  joinedAt    DateTime  @default(now()) @map("joined_at")
  leftAt      DateTime? @map("left_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@index([isActive])
  @@map("chat_room_members")
}

/// 채팅 메시지
model ChatMessage {
  id          String          @id @default(cuid())
  roomId      String          @map("room_id")
  senderId    String          @map("sender_id")
  receiverId  String?         @map("receiver_id") // 1:1 채팅 수신자
  type        ChatMessageType @default(TEXT)
  content     String          @db.Text
  attachments Json            @default("[]") // 첨부파일 URL 배열
  isEdited    Boolean         @default(false) @map("is_edited")
  isDeleted   Boolean         @default(false) @map("is_deleted")
  readBy      Json            @default("[]") @map("read_by") // 읽은 사용자 ID 배열
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  room     ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender   User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User?    @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([roomId, isDeleted, createdAt]) // P0: 메시지 페이징 최적화
  @@map("chat_messages")
}

/// 메시지 유형
enum ChatMessageType {
  TEXT // 텍스트
  IMAGE // 이미지
  FILE // 파일
  SYSTEM // 시스템 메시지
  NOTICE // 공지
}

// ==================== App Management ====================

/// 앱 배너 - 메인 화면 배너 관리
/// 프리미엄 이벤트 - 앱 내 특별 이벤트 관리
model AppPremiumEvent {
  id           String    @id @default(cuid())
  title        String    @db.VarChar(200)
  subtitle     String?   @db.VarChar(200)
  description  String    @db.Text
  eventDate    DateTime  @map("event_date")
  venueName    String    @map("venue_name") @db.VarChar(200)
  venueAddress String?   @map("venue_address") @db.VarChar(400)
  benefitsJson Json      @map("benefits_json") @db.JsonB
  ctaLabel     String    @default("이벤트 신청하기") @map("cta_label") @db.VarChar(100)
  ctaUrl       String?   @map("cta_url") @db.Text
  imageUrl     String?   @map("image_url") @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  startAt      DateTime? @map("start_at")
  endAt        DateTime? @map("end_at")
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdId    String?   @map("created_id")
  updatedId    String?   @map("updated_id")

