# Database Configuration (MariaDB/MySQL)
DATABASE_URL=mysql://teamplus_user:LocalPassword123@localhost:3306/teamplus_db
DB_USER=teamplus_user
DB_PASSWORD=LocalPassword123
DB_ROOT_PASSWORD=RootPassword123
DB_NAME=teamplus_db
DB_PORT=3306

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_MAX_RETRIES=3
REDIS_ENABLE_OFFLINE_QUEUE=true

# Redis Cache TTL (초 단위)
CACHE_TTL_CLASS_LIST=300          # 수업 목록: 5분
CACHE_TTL_CLUB_INFO=600           # 클럽 정보: 10분
CACHE_TTL_USER_PROFILE=900        # 사용자 프로필: 15분
CACHE_TTL_PAYMENT_IDEMPOTENCY=86400  # 결제 중복 방지: 24시간
CACHE_TTL_RATE_LIMIT=60           # 레이트 리미팅: 1분

# Server Configuration
BACKEND_PORT=5003
NODE_ENV=development
LOG_LEVEL=debug
WEB_BUILD_PATH=../teamplus-web/out

# 업로드 디렉토리 루트 (UPLOAD_ROOT)
#   - 미설정 시 `<teamplus-backend cwd>/uploads/` 사용 (기본 — 개발 환경)
#   - 운영 환경에서는 외부 디스크/별도 파티션 권장:
#     예) UPLOAD_ROOT=/var/lib/teamplus/uploads
#         sudo mkdir -p /var/lib/teamplus/uploads
#         sudo chown -R nestjs:nestjs /var/lib/teamplus/uploads
#         sudo chmod 750 /var/lib/teamplus/uploads
#   - 부팅 시 카테고리 디렉토리(avatar/image/video/document/...) 자동 생성됨.
#   - 정적 서빙 prefix 는 `/uploads/` (변경되지 않음, main.ts 참조).
UPLOAD_ROOT=

# Rate Limit Environment
# - local: 30 requests/min (개발자 로컬)
# - development: 10 requests/min (개발 서버)
# - production: 3 requests/min (운영 서버)
# 미설정 시 NODE_ENV 기반 자동 결정 (development → local, production → production)
RATE_LIMIT_ENV=local

# JWT Configuration
# ⚠️ 운영 배포 시 JWT_SECRET / JWT_REFRESH_SECRET 을 반드시 서로 다른 강력한 값으로 교체.
#    (예: `openssl rand -hex 32`) 미교체/공유 시 production 부팅이 실패합니다(auth.module.ts 가드).
JWT_SECRET=CHANGE_ME_64_HEX_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_64_HEX_REFRESH_SECRET # access 와 반드시 다른 값
JWT_EXPIRATION=900 # 15 minutes in seconds
JWT_REFRESH_EXPIRATION=604800 # 7 days in seconds

# ─── At-rest 필드 암호화 키 (서버 전용) ─────────────────────────────────────
# [2026-06-15 SECURITY] Settlement.bankAccount 등 DB 필드 암호화(AES-256-GCM)에 사용.
#   ⚠️ 절대 NEXT_PUBLIC_* 로 노출 금지(브라우저 번들에 인라인됨). CRYPTO_SECRET_KEY 와도
#   분리하라 — 그 값은 web 의 NEXT_PUBLIC_CRYPTO_SECRET_KEY 와 동일해 공개로 읽힌다.
#   생성: `openssl rand -hex 32` (64 hex). 미설정 시 레거시 CRYPTO_SECRET_KEY 로 폴백(기존 동작).
#   설정 후 기존 데이터는 자동 폴백 복호화되며, 강제 이관은
#   `npx tsx prisma/reencrypt-fields.ts` 로 신규 키로 재암호화 가능.
FIELD_ENCRYPTION_KEY=CHANGE_ME_64_HEX_SERVER_ONLY_KEY

# [DEV ONLY] 평문 로그인 엔드포인트(/auth/login/dev) 활성화 플래그.
#   NODE_ENV=development + ENABLE_DEV_LOGIN=true 일 때만 동작. 운영/스테이징에서는 절대 설정 금지.
ENABLE_DEV_LOGIN=true

# [DEV ONLY] 동시(중복) 로그인 허용 플래그.
#   NODE_ENV=development + AUTH_ALLOW_CONCURRENT_LOGIN=true 일 때만 동작 (production 은 무시).
#   미설정(기본)은 단일 세션 정책 — 활성 세션 존재 시 로그인이 409 SESSION_EXISTS 를 반환하고,
#   클라이언트 확인(force) 재요청 시 기존 세션을 강제 종료한다.
AUTH_ALLOW_CONCURRENT_LOGIN=false

# CORS Configuration
CORS_ORIGIN=*

# KG이니시스 Payment Gateway
INICIS_MERCHANT_KEY=test-merchant-key
INICIS_STORE_ID=test-store-id
INICIS_API_VERSION=1.0
INICIS_TIMEOUT=30000
INICIS_SIGNATURE_KEY=default-signature-key
INICIS_VERIFY_SIGNATURE=true
INICIS_IP_WHITELIST=
INICIS_RETURN_URL=http://localhost:5003/api/v1/payments/callback
INICIS_WEBHOOK_URL=http://localhost:5003/api/v1/payments/webhook

# Payment Retry Configuration
PAYMENT_RETRY_MAX_ATTEMPTS=3
PAYMENT_RETRY_DELAY=1000

# Kakao Alimtalk (Notifications)
KAKAO_API_KEY=test-kakao-api-key
KAKAO_SENDER_KEY=test-sender-key
KAKAO_API_URL=https://api.kakaowork.com/v1/messages

# Kakao Alimtalk Templates (카카오 비즈니스에서 사전 승인 필요)
KAKAO_TEMPLATE_PAYMENT_SUCCESS=PAYMENT_SUCCESS_001
KAKAO_TEMPLATE_MEMBERSHIP_APPROVED=MEMBERSHIP_APPROVED_001
KAKAO_TEMPLATE_CLASS_REMINDER=CLASS_REMINDER_001
KAKAO_TEMPLATE_ATTENDANCE_CONFIRMED=ATTENDANCE_CONFIRMED_001
KAKAO_TEMPLATE_CREDIT_EXPIRY=CREDIT_EXPIRY_001
KAKAO_TEMPLATE_CLASS_CANCELLED=CLASS_CANCELLED_001

# Alimtalk Retry Configuration
ALIMTALK_RETRY_ATTEMPTS=3
ALIMTALK_RETRY_DELAY=1000
ALIMTALK_RETRY_BACKOFF=exponential

# SMS Fallback (알림톡 실패 시 SMS 발송)
SMS_FALLBACK_ENABLED=true
SMS_SENDER_NUMBER=010-1234-5678

# Firebase Cloud Messaging (FCM) - 푸시 알림 발송
# Firebase Console > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성에서 발급
# 3개 환경변수가 모두 설정되어야 FCM 발송이 활성화됩니다.
# 미설정 시 푸시 발송이 건너뛰어지며 로그만 남습니다.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# FcmGateway 단일 JSON 초기화 (Firebase Console > 서비스 계정 > JSON 전체를 문자열로)
# 설정 시 FcmGateway가 활성화됩니다. 미설정 시 경고 로그만 출력됩니다.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Apple Sign in with Apple (SIWA) - 탈퇴 시 Apple 토큰 revoke (iOS 5.1.1(v) 필수)
# Apple Developer > Certificates, Identifiers & Profiles > Keys 에서 "Sign in with Apple" 체크하여 .p8 발급.
# 4개가 모두 설정되어야 AppleTokenService.isConfigured()=true → 토큰교환/revoke 활성화.
# 미설정 시 자동 스킵(로그인·탈퇴 흐름은 정상 동작하되 Apple 측 토큰 무효화는 생략됨).
# APPLE_TEAM_ID: Apple Developer Team ID (10자, 예: VG2U99V32J)
APPLE_TEAM_ID=
# APPLE_KEY_ID: SIWA Key ID (.p8 발급 시 표시되는 10자)
APPLE_KEY_ID=
# APPLE_CLIENT_ID: 네이티브 앱은 번들 ID(kr.co.teamplus) / 웹 Service ID 사용 시 해당 값
APPLE_CLIENT_ID=
# APPLE_PRIVATE_KEY: .p8 파일 전체 내용(PKCS#8 PEM). 개행은 실제 개행 또는 \n 이스케이프 모두 허용.
# 예: APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----"
APPLE_PRIVATE_KEY=

# SMTP 메일 발송 (회원가입 OTP 등) — Postfix 릴레이 가정
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@kci.co.kr
SMTP_FROM_NAME=
# TLS 인증서 검증 — 기본 true(검증 강제, OTP MITM 차단).
# 자가서명 Postfix 등으로 핸드셰이크가 실패할 때만 개발 환경(NODE_ENV=development)에서
# false 로 검증을 끌 수 있다. 운영을 포함한 그 외 환경에서는 값과 무관하게 항상 검증한다.
MAIL_TLS_REJECT_UNAUTHORIZED=true

# Prisma migrate dev용 shadow database (별도 생성 DB 권장)
# SHADOW_DATABASE_URL="postgresql://user:PASSWORD@host:55432/icehockey_shadow?schema=public"

