{
  "name": "teamplus-backend",
  "version": "1.0.0",
  "description": "TEAMPLUS - Ice Hockey Club Management System Backend",
  "author": "TEAMPLUS Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prebuild": "npm run prisma:generate && rimraf dist tsconfig.tsbuildinfo",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "prestart:dev": "npm run prisma:generate",
    "start:dev": "nest start --watch",
    "prestart:debug": "npm run prisma:generate",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "prisma migrate dev",
    "db:migrate:manual": "bash prisma/manual-migrations/apply-all.sh",
    "db:migrate:prod": "prisma migrate deploy && npm run db:migrate:manual",
    "db:seed": "tsx prisma/seed.ts",
    "seed:notifications": "tsx prisma/seeds/notifications.seed.ts",
    "db:studio": "prisma studio",
    "auth:decrypt": "node scripts/decrypt-login-payload.js",
    "di:verify": "tsx tools/di-doctor/di-doctor.ts verify",
    "di:verify:json": "tsx tools/di-doctor/di-doctor.ts verify --json",
    "di:fix": "tsx tools/di-doctor/di-doctor.ts fix",
    "roles:check": "tsx tools/roles-check.ts",
    "perf:n-plus-one": "tsx tools/n-plus-one-check.ts",
    "check:upload-limits": "tsx tools/check-upload-limits.ts",
    "uploads:doctor": "tsx scripts/uploads-doctor.ts",
    "uploads:doctor:json": "tsx scripts/uploads-doctor.ts --json",
    "uploads:cleanup-orphans": "tsx scripts/uploads-doctor.ts --cleanup-orphans",
    "apple:siwa": "tsx scripts/setup-apple-siwa.ts",
    "seed:alimtalk": "tsx prisma/seeds/run-alimtalk-templates.ts",
    "swagger": "nest-swagger-gen",
    "build:web": "cd ../teamplus-web && npm install && npm run build",
    "build:all": "npm run build:web && npm run build",
    "deploy": "npm run build:all",
    "deploy:prod": "npm run build:all && pm2 restart teamplus-api"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^10.2.10",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.10",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.3.0",
    "@nestjs/throttler": "^5.0.1",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.7.1",
    "@sentry/node": "^10.44.0",
    "@types/bull": "^3.15.9",
    "@types/compression": "^1.8.1",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "dotenv": "^16.3.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^3.1.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.2.10",
    "@playwright/test": "^1.57.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^3.0.13",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^30.2.0",
    "prettier": "^3.1.1",
    "prisma": "^5.7.1",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.1",
    "ts-node": "^1.7.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(axios)/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "module": "commonjs"
        }
      }
    }
  }
}
