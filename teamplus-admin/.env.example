# TEAMPLUS Admin — 환경변수 예시 (.env.local 로 복사 후 실제 값 주입)

# ─── API 백엔드 주소 ──────────────────────────────────────────────────────
# 로컬: http://localhost:5003/api/v1
# 운영: https://teamplusadmin.icetimes.co.kr/api/v1  (nginx 동일 origin /api/v1 프록시)
NEXT_PUBLIC_API_URL=http://localhost:5003/api/v1

# ─── 서버 전용 시크릿 (브라우저 미노출, env.ts serverEnv 에서 검증) ────────
# 운영(NODE_ENV=production) 부팅 시 ≥32자 강제. backend JWT_SECRET 과 동일 값 사용.
JWT_SECRET=
DATABASE_URL=

# ─── 페이로드 암호화 키 (web/backend 와 동일 값 사용) ─────────────────────
# openssl rand -hex 32 (64 hex chars)
NEXT_PUBLIC_CRYPTO_SECRET_KEY=

# ─── 로그 디렉토리 (선택) ──────────────────────────────────────────────────
# 미설정 시: process.cwd()/log (앱 폴더 내부)
# 운영 권장 : 앱 폴더 외부에 두어 deploy reset/clone 영향 차단.
# 예) backend → /kcs-project/backend-log
#     web     → /kcs-project/web-log
#     admin   → /kcs-project/admin-log
#     home    → /kcs-project/home-log
# LOG_ROOT=
