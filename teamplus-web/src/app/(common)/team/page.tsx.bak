"use client";

/**
 * /team — 팀 목록 (관리 + 조회 겸용)
 *
 * teamplus 디자인 7원칙 준수:
 *  ① 화면 분석 → 사용자 제공 HTML "팀 목록" 레퍼런스 기반
 *  ② 휴먼 디자인 → 카드 리스트 + 필터 칩, 과장 금지
 *  ③ AI 스타일 금지 → gradient / backdrop-blur / shadow-color/30 0건
 *  ④ 페르소나 융합 → frontend + architect + a11y
 *  ⑤ 명령어 필수 → 역할별 CRUD 분기 명령 중심
 *  ⑥ 원칙 표기 → 본 주석 + 하단 design-notes
 *  ⑦ 한글 존댓말 + MESSAGES 상수
 *
 * 권한 분기:
 *  - ADMIN/DIRECTOR/COACH: FAB(등록하기) + 카드 진입 시 관리 메뉴 노출
 *  - PARENT/TEEN/CHILD: 조회 전용
 */

import { useCallback, useEffect, useMemo, useState } from "react";
import { useNavigation } from "@/components/ui/NavLink";
import { MobileContainer } from "@/components/layout/MobileContainer";
import { SubmainAppBar } from "@/components/layout/SubmainAppBar";
import { Icon } from "@/components/ui/Icon";
import { EmptyState } from "@/components/ui/EmptyState";
// 2026-04-12 재디자인 공통 컴포넌트 (학부모/일반 조회 뷰용)
import { TeamListCard, TeamFilterChip, TeamSearchBar } from "@/components/team";
import { usePageReady } from '@/hooks/usePageReady';
import { useNativeUI } from '@/hooks/useNativeUI';
import { useSessionAuth } from "@/hooks/useSessionAuth";
import { cn } from "@/lib/utils";
import { MESSAGES } from "@/lib/messages";
import { isTeamManager } from "@/lib/team-roles";
import {
  listManagedTeams,
  listParentVisibleTeams,
  listPublicTeams,
  type MyChildInTeam,
  type ParentChildTeamItem,
  type TeamListItem,
  type TeamDivision,
} from "@/services/team.service";

// ─── 필터 정의 ───────────────────────────────────────────
type FilterKey = "all" | TeamDivision;

const FILTERS: { key: FilterKey; label: string }[] = [
  { key: "all", label: "전체" },
  { key: "U8", label: "U8" },
  { key: "U9", label: "U9" },
  { key: "U10", label: "U10" },
  { key: "U11", label: "U11" },
  { key: "U12", label: "U12" },
];

// ─── 권한 유틸 ───────────────────────────────────────────
function useCanManageTeams() {
  const { user } = useSessionAuth();
  return isTeamManager(user);
}

function useIsParent() {
  const { user } = useSessionAuth();
  return user?.userType === "parent";
}

// 로고 폴백 컬러 및 `resolveLogoColor` 는 `TeamListCard` 로 이관 (2026-04-12).

// ─── 클라이언트 필터 로직 (공통) ──────────────────────
/**
 * 제네릭으로 구현하여 TeamListItem 또는 그 확장 타입(ParentChildTeamItem)을
 * 타입 보존한 채 필터링한다. `as unknown as` 같은 강제 캐스팅이 필요 없다.
 */
function applyClientFilter<T extends TeamListItem>(
  source: readonly T[],
  filter: FilterKey,
  searchQuery: string,
): T[] {
  let list: T[] = [...source];
  if (filter !== "all") {
    list = list.filter((t) => t.division === filter);
  }
  const q = searchQuery.trim().toLowerCase();
  if (q) {
    list = list.filter(
      (t) =>
        (t.name ?? "").toLowerCase().includes(q) ||
        (t.shortName?.toLowerCase().includes(q) ?? false),
    );
  }
  return list;
}

// ─── Main Page ───────────────────────────────────────────
export default function TeamListPage() {
  const { navigate } = useNavigation();
  const canManage = useCanManageTeams();
  const isParent = useIsParent();

  const [teams, setTeams] = useState<TeamListItem[]>([]);
  // 학부모 전용 뷰 상태
  const [myChildTeams, setMyChildTeams] = useState<ParentChildTeamItem[]>([]);
  const [clubTeams, setClubTeams] = useState<TeamListItem[]>([]);
  const [totalChildren, setTotalChildren] = useState(0);

  const [isLoading, setIsLoading] = useState(true);


  // 풀스크린 로더 fast-path (v11) — fetch 완료 시점에 PageTransitionLoader OFF

  usePageReady(!isLoading);

  // [2026-05-09] Native (Flutter WebView) UI 상태 복원.
  //   탭 전환 시 LoadingContext 가 ui.enterFullscreen() 으로 status bar 를 숨겼지만,
  //   이 페이지가 useNativeUI 호출이 없으면 exitFullscreen 이 트리거되지 않아
  //   iOS 시뮬레이터에서 status bar 가 ~2-3초 후에야 노출되는 현상 발생.
  //   isDataLoaded 를 fetch 완료 신호로 전달 → useNativeUI 가 적시에 ui.stopLoading()
  //   + exitFullscreen 을 호출하여 status bar 즉시 복원.
  useNativeUI({
    showStatusBar: true,
    showAppBar: false, // SubmainAppBar (web DOM 헤더) 사용
    showBottomNav: true,
    isDataLoaded: !isLoading,
  });
  const [error, setError] = useState<string | null>(null);
  const [searchQuery, setSearchQuery] = useState("");
  const [filter, setFilter] = useState<FilterKey>("all");

  // ─── 데이터 로딩 ───────────────────────────────────
  const fetchTeams = useCallback(async () => {
    setIsLoading(true);
    setError(null);
    try {
      // 학부모: 학부모 특화 뷰 / 관리자: 관리 팀 / 그 외: 공개 팀 목록
      if (isParent) {
        const res = await listParentVisibleTeams();
        if (res.success && res.data) {
          setMyChildTeams(res.data.myChildTeams);
          setClubTeams(res.data.clubTeams);
          setTotalChildren(res.data.totalChildren);
        } else {
          setMyChildTeams([]);
          setClubTeams([]);
          setTotalChildren(0);
          if (res.error) {
            setError(res.error.message || MESSAGES.team.loadError);
          }
        }
      } else if (canManage) {
        // ADMIN/DIRECTOR/COACH 는 "내 관리 팀" 우선 시도.
        // 결과가 비어 있으면(예: 코치의 CoachProfile.clubId 누락, 감독의 팀 미소유)
        // 공개 팀 목록으로 폴백하여 최소한의 조회 경험을 보장한다.
        // `/teams` 는 admin 전용이므로 WebView 공통 팀 화면에서는 호출하지 않는다.
        const managedRes = await listManagedTeams();
        if (
          managedRes.success &&
          managedRes.data &&
          managedRes.data.length > 0
        ) {
          setTeams(managedRes.data);
        } else {
          const fallbackRes = await listPublicTeams({ limit: 100 });
          if (fallbackRes.success && fallbackRes.data) {
            setTeams(fallbackRes.data);
          } else {
            setTeams([]);
            const err = managedRes.error ?? fallbackRes.error;
            if (err) {
              setError(err.message || MESSAGES.team.loadError);
            }
          }
        }
      } else {
        const res = await listPublicTeams({ limit: 100 });
        if (res.success && res.data) {
          setTeams(res.data);
        } else {
          setTeams([]);
          if (res.error) {
            setError(res.error.message || MESSAGES.team.loadError);
          }
        }
      }
    } catch {
      setError(MESSAGES.error.network);
      setTeams([]);
      setMyChildTeams([]);
      setClubTeams([]);
    } finally {
      setIsLoading(false);
    }
  }, [canManage, isParent]);

  useEffect(() => {
    void fetchTeams();
  }, [fetchTeams]);

  // ─── 클라이언트 필터 ───────────────────────────────
  const filteredTeams = useMemo(
    () => applyClientFilter(teams, filter, searchQuery),
    [teams, filter, searchQuery],
  );

  const filteredMyChildTeams = useMemo<ParentChildTeamItem[]>(
    () =>
      applyClientFilter<ParentChildTeamItem>(myChildTeams, filter, searchQuery),
    [myChildTeams, filter, searchQuery],
  );

  const filteredClubTeams = useMemo(
    () => applyClientFilter<TeamListItem>(clubTeams, filter, searchQuery),
    [clubTeams, filter, searchQuery],
  );

  const hasAnyParentResult =
    filteredMyChildTeams.length > 0 || filteredClubTeams.length > 0;

  // ─── 핸들러 ────────────────────────────────────────
  const handleCardClick = useCallback(
    (teamId: string) => {
      navigate(`/team/${teamId}`);
    },
    [navigate],
  );

  const handleCreateClick = useCallback(() => {
    navigate("/team/create");
  }, [navigate]);

  // ─── Render ────────────────────────────────────────
  const appBarTitle = isParent
    ? MESSAGES.team.titleParent
    : MESSAGES.team.titleList;

  // 카테고리별 카운트 (코치/관리자 뷰 04c 칩 배지용)
  const teamCounts = useMemo(() => {
    const counts: Record<string, number> = { all: teams.length };
    for (const key of ['U8', 'U9', 'U10', 'U11', 'U12']) counts[key] = 0;
    for (const t of teams) {
      const div = t.division ?? '';
      if (div in counts) counts[div]++;
    }
    return counts;
  }, [teams]);

  return (
    <MobileContainer hasBottomNav>
      <SubmainAppBar title={appBarTitle} />

      <main
        className="hide-scrollbar flex-1 overflow-y-auto bg-wbg dark:bg-rink-900"
        role="main"
        aria-label={appBarTitle}
      >
        {/* ─── 검색바 ─── 코치/관리자 뷰: 04c 풀너비 알약형 / 학부모: 기존 컴포넌트 ─── */}
        {canManage && !isParent ? (
          <section className="px-5 pt-2.5" aria-label="팀 검색">
            <div className="relative">
              <Icon
                name="search"
                className="absolute left-3.5 top-1/2 -translate-y-1/2 text-[16px] text-wtext-3 dark:text-wtext-4 pointer-events-none"
                aria-hidden="true"
              />
              <input
                type="text"
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
                placeholder="팀 이름으로 검색"
                aria-label="팀 이름으로 검색"
                className="w-full h-11 bg-wsurface dark:bg-rink-800 border border-wline-2 dark:border-rink-700 rounded-[12px] pl-10 pr-10 text-[13px] text-wtext-1 dark:text-white placeholder:text-wtext-4 dark:placeholder:text-wtext-3 focus:border-ice-500 focus:ring-2 focus:ring-ice-500/20 outline-none transition-colors motion-reduce:transition-none"
              />
              {searchQuery && (
                <button
                  type="button"
                  onClick={() => setSearchQuery('')}
                  aria-label="검색어 지우기"
                  className="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 rounded-full hover:bg-wline dark:hover:bg-rink-700 transition-colors motion-reduce:transition-none"
                >
                  <Icon name="close" className="text-[18px] text-wtext-3 dark:text-wtext-4" aria-hidden="true" />
                </button>
              )}
            </div>
          </section>
        ) : (
          <section
            className="border-b border-wline-2 bg-wsurface px-5 pb-3 pt-4 dark:border-rink-700 dark:bg-rink-800"
            aria-label="팀 검색"
          >
            <TeamSearchBar
              value={searchQuery}
              onChange={setSearchQuery}
              placeholder={MESSAGES.team.searchPlaceholder}
            />
          </section>
        )}

        {/* ─── 필터 칩 ─── 코치/관리자 뷰: 04c 카운트 배지 칩 (count 0 숨김) / 학부모: 기존 ─── */}
        {canManage && !isParent ? (
          <section
            className="hide-scrollbar flex gap-2 overflow-x-auto px-5 pt-2 pb-1"
            role="tablist"
            aria-label="부문별 필터"
          >
            {FILTERS.map((f) => {
              const isActive = filter === f.key;
              const count = teamCounts[f.key] ?? 0;
              return (
                <button
                  key={f.key}
                  type="button"
                  role="tab"
                  aria-selected={isActive}
                  onClick={() => setFilter(f.key)}
                  className={cn(
                    'shrink-0 inline-flex items-center gap-2 h-9 px-3.5 rounded-full text-[13px] font-bold whitespace-nowrap tracking-[-0.01em] transition-colors duration-300 ease-ios motion-reduce:transition-none',
                    isActive
                      ? 'bg-ice-500 text-white border border-transparent'
                      : 'bg-wsurface dark:bg-rink-800 text-wtext-2 dark:text-wtext-4 border border-wline-2 dark:border-rink-700 hover:bg-wbg dark:hover:bg-rink-700',
                  )}
                >
                  {f.label}
                  {count > 0 && (
                    <span
                      className={cn(
                        'inline-flex items-center justify-center min-w-[18px] h-[18px] px-1.5 rounded-full text-[10px] font-extrabold tabular-nums',
                        isActive
                          ? 'bg-white/22 text-white'
                          : 'bg-wline-2 dark:bg-rink-700 text-wtext-3 dark:text-wtext-4',
                      )}
                    >
                      {count}
                    </span>
                  )}
                </button>
              );
            })}
          </section>
        ) : (
          <section
            className="hide-scrollbar flex gap-2 overflow-x-auto border-b border-wline-2 bg-wsurface px-5 py-3 dark:border-rink-700 dark:bg-rink-800"
            role="tablist"
            aria-label="부문별 필터"
          >
            {FILTERS.map((f) => (
              <TeamFilterChip
                key={f.key}
                label={f.label}
                active={filter === f.key}
                onClick={() => setFilter(f.key)}
              />
            ))}
          </section>
        )}

        {/* ─── 본문 ────────────────────────────── */}
        <section
          className={cn(
            canManage && !isParent ? 'px-5 pt-3 pb-30' : 'px-4 pb-30 pt-4',
          )}
          aria-label="팀 목록"
        >
          {isLoading ? null : error ? (
            <ErrorView message={error} onRetry={fetchTeams} />
          ) : isParent ? (
            // ─── 학부모 전용 뷰 ─────────────────
            totalChildren === 0 ? (
              <EmptyState
                icon="child_care"
                title={MESSAGES.team.parentNoChildren}
                description={MESSAGES.team.parentNoChildrenHint}
              />
            ) : !hasAnyParentResult ? (
              <div className="flex flex-col items-center justify-center py-12 px-4 text-center">
                <h3 className="text-w-title font-bold text-wtext-1 dark:text-white">
                  {searchQuery.trim() || filter !== "all"
                    ? MESSAGES.team.noSearchResults
                    : MESSAGES.team.noChildTeamsYet}
                </h3>
                <p className="mt-2 text-w-small text-wtext-3 dark:text-wtext-4">
                  {searchQuery.trim() || filter !== "all"
                    ? MESSAGES.team.searchResultHint
                    : MESSAGES.team.noChildTeamsHint}
                </p>
              </div>
            ) : (
              <div className="flex flex-col gap-8">
                {/* 우리 아이 팀 섹션 */}
                <div className="flex flex-col gap-3">
                  <SectionHeader
                    icon="favorite"
                    title={MESSAGES.team.myChildTeamsSection}
                    hint={MESSAGES.team.myChildTeamsSectionHint}
                    count={filteredMyChildTeams.length}
                  />
                  {filteredMyChildTeams.length === 0 ? (
                    <div className="flex flex-col items-center justify-center py-12 px-4 text-center">
                      <h3 className="text-w-title font-bold text-wtext-1 dark:text-white">
                        {MESSAGES.team.noChildTeamsYet}
                      </h3>
                      <p className="mt-2 text-w-small text-wtext-3 dark:text-wtext-4">
                        {MESSAGES.team.noChildTeamsHint}
                      </p>
                    </div>
                  ) : (
                    <ul className="flex flex-col gap-3" aria-label="내 자녀 팀">
                      {filteredMyChildTeams.map((team) => {
                        const myChildren = Array.isArray(team.myChildren)
                          ? team.myChildren
                          : [];

                        return (
                          <li key={team.id}>
                            <TeamListCard
                              team={team}
                              onClick={() => handleCardClick(team.id)}
                              highlight
                              footerSlot={
                                myChildren.length > 0 ? (
                                  <ul
                                    className="mt-3 flex flex-wrap gap-2"
                                    aria-label="이 팀에 소속된 내 자녀 목록"
                                  >
                                    {myChildren.map((child) => (
                                      <li key={child.rosterId}>
                                        <ChildChip child={child} />
                                      </li>
                                    ))}
                                  </ul>
                                ) : null
                              }
                            />
                          </li>
                        );
                      })}
                    </ul>
                  )}
                </div>

                {/* 같은 팀의 다른 팀 섹션 */}
                <div className="flex flex-col gap-3">
                  <SectionHeader
                    icon="apartment"
                    title={MESSAGES.team.teamsSection}
                    hint={MESSAGES.team.teamsSectionHint}
                    count={filteredClubTeams.length}
                  />
                  {filteredClubTeams.length === 0 ? (
                    <div className="flex flex-col items-center justify-center py-12 px-4 text-center">
                      <h3 className="text-w-title font-bold text-wtext-1 dark:text-white">
                        {MESSAGES.team.noOtherTeams}
                      </h3>
                      <p className="mt-2 text-w-small text-wtext-3 dark:text-wtext-4">
                        {MESSAGES.team.emptyHint}
                      </p>
                    </div>
                  ) : (
                    <ul
                      className="flex flex-col gap-3"
                      aria-label="같은 팀의 다른 팀"
                    >
                      {filteredClubTeams.map((team) => (
                        <li key={team.id}>
                          <TeamListCard
                            team={team}
                            onClick={() => handleCardClick(team.id)}
                          />
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>
            )
          ) : filteredTeams.length === 0 ? (
            // ─── 관리자/기타 조회자 빈 상태 ───
            <div className="flex flex-col items-center justify-center py-12 px-4 text-center">
              <h3 className="text-w-title font-bold text-wtext-1 dark:text-white">
                {searchQuery.trim() || filter !== "all"
                  ? MESSAGES.team.noSearchResults
                  : MESSAGES.team.empty}
              </h3>
              <p className="mt-2 text-w-small text-wtext-3 dark:text-wtext-4">
                {searchQuery.trim() || filter !== "all"
                  ? MESSAGES.team.searchResultHint
                  : MESSAGES.team.emptyHint}
              </p>
            </div>
          ) : canManage && !isParent ? (
            // ─── 04c 감독 팀 관리 카드 (코치/감독/관리자 전용) ───
            <ul className="flex flex-col gap-3" aria-label="팀 카드 목록">
              {filteredTeams.map((team) => (
                <li key={team.id}>
                  <CoachTeamManageCard
                    team={team}
                    onClick={() => handleCardClick(team.id)}
                  />
                </li>
              ))}
            </ul>
          ) : (
            <ul className="flex flex-col gap-3" aria-label="팀 카드 목록">
              {filteredTeams.map((team) => (
                <li key={team.id}>
                  <TeamListCard
                    team={team}
                    onClick={() => handleCardClick(team.id)}
                  />
                </li>
              ))}
            </ul>
          )}
        </section>
      </main>

      {/* ─── 등록하기 FAB (관리자 전용) — 원형 플로팅 액션 버튼 ────────
          [2026-05-09] Android 안전영역 보정.
            기존 `bottom-24` (96px) 는 Android 제스처 네비(safe-area-inset-bottom 24~48px)
            + BottomNav(60px) 합 ≈ 84-108px 와 겹쳐 FAB 하단이 BottomNav 에 가려지는
            현상 발생. BottomNav 는 60px + safe-area-inset-bottom 으로 구성되므로,
            FAB 하단을 (BottomNav 상단 + 16px 여유) 위치로 고정하여 모든 디바이스에서
            잘리지 않도록 보정. */}
      {canManage && !isLoading && (
        <button
          type="button"
          onClick={handleCreateClick}
          style={{
            bottom: 'calc(76px + var(--safe-area-inset-bottom, env(safe-area-inset-bottom, 0px)))',
          }}
          className="absolute right-5 z-30 flex h-14 w-14 items-center justify-center rounded-w-pill bg-ice-500 text-white shadow-sh-blue hover:bg-ice-600 active:brightness-95 transition-colors duration-200 ease-ios-spring motion-reduce:transition-none focus:outline-none focus-visible:ring-2 focus-visible:ring-ice-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-puck"
          aria-label={MESSAGES.team.titleCreate}
        >
          <Icon name="add" className="text-[28px]" aria-hidden="true" />
        </button>
      )}
    </MobileContainer>
  );
}

// ─── 다음 일정 날짜·시간 포맷 헬퍼 ─────────────────────
function formatNextDate(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return '';
  const now = new Date();
  const startOfToday = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  const startOfTarget = new Date(d.getFullYear(), d.getMonth(), d.getDate());
  const diffDays = Math.round(
    (startOfTarget.getTime() - startOfToday.getTime()) / (24 * 60 * 60 * 1000),
  );
  if (diffDays === 0) return '오늘';
  if (diffDays === 1) return '내일';
  if (diffDays > 1 && diffDays < 7) {
    const dayNames = ['일', '월', '화', '수', '목', '금', '토'];
    return `${dayNames[d.getDay()]} ${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
  }
  return `${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
}

function formatNextTime(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return '';
  return `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
}

// ─── 04c 감독 팀 관리 카드 (Coach/Admin/Director 전용) ───────────
// 참고 디자인 "04c · 감독 팀 관리 (개선)" 100% 매칭.
// 데이터 미연결 영역(승무패·출석률·일정·gender·pending)은 placeholder/기본값으로
// 시각 골격을 유지. 실제 백엔드 응답이 추가되면 props 매핑만으로 대체 가능.
//
// 그라디언트 정책: teamplus 토큰 SoT 준수 → linear-gradient 금지, 솔리드 + alpha hex.
function CoachTeamManageCard({
  team,
  onClick,
}: {
  team: TeamListItem;
  onClick: () => void;
}) {
  const teamColor = (team.primaryColor && /^#[0-9a-fA-F]{6}$/.test(team.primaryColor))
    ? team.primaryColor
    : '#2f5fff'; // ice-500 폴백
  const memberCount = team._count?.roster ?? 0;
  const division = team.division ?? null;

  // 04c 메타 필드 매핑 (백엔드 합성 → 프론트 표시)
  // 모든 필드가 실데이터 — 하드코딩 폴백 제거 (2026-05-09 Phase B)
  const gender = (team.genderType ?? 'MIX') as 'MIX' | 'M' | 'F';
  const record = {
    w: team.seasonWins ?? 0,
    l: team.seasonLosses ?? 0,
    d: team.seasonDraws ?? 0,
  };
  // recentAttendanceRate가 null이면 0% 표시 (데이터 부족)
  const attendance = team.recentAttendanceRate ?? 0;
  const hasAttendance = team.recentAttendanceRate !== null && team.recentAttendanceRate !== undefined;
  const pending = team.pendingApplications ?? 0;

  // 다음 일정 — 백엔드 nextEvent 응답을 04c 시각 모델로 변환
  type NextSchedule = { type: '연습' | '경기'; date: string; time: string; place: string; urgent: boolean };
  const next: NextSchedule | null = team.nextEvent
    ? {
        type: team.nextEvent.eventType === 'tournament' || team.nextEvent.eventType === 'friendly' ? '경기' : '연습',
        date: formatNextDate(team.nextEvent.startAt),
        time: formatNextTime(team.nextEvent.startAt),
        place: team.nextEvent.location ?? team.nextEvent.title,
        urgent: team.nextEvent.isUrgent,
      }
    : null;

  // 아바타 스택 — 참고 04c 동일 팔레트 (ice-400/flame-500/mint-500/sun-500)
  // 다양한 선수 컬러로 활력 부여 (실 선수 데이터 미연결 시 기본 팔레트)
  const avatarColors = ['#5a82ff', '#ff5a36', '#00d4a8', '#ffc940'];
  const visibleAvatars = Math.min(4, memberCount);
  const overflow = Math.max(0, memberCount - visibleAvatars);

  return (
    <article className="relative overflow-hidden rounded-[18px] bg-wsurface dark:bg-rink-800 border border-wline-2 dark:border-rink-700 shadow-sh-1 hover:shadow-sh-2 transition-shadow motion-reduce:transition-none">
      <button
        type="button"
        onClick={onClick}
        aria-label={`${team.name ?? '팀'} 상세 보기`}
        className="block w-full text-left active:brightness-95"
      >
        {/* 헤더: 로고 + 이름 + 칩 + 상세 이동 표시 — 패딩 16/16/12 */}
        <div className="px-4 pt-4 pb-3 flex items-center gap-3">
          {/* 로고 타일 (56x56, radius 16, 솔리드 + 컬러섀도 X — wallet shadow 토큰 사용) */}
          <div
            className="w-14 h-14 rounded-[16px] flex items-center justify-center shrink-0 text-white shadow-sh-1"
            style={{ backgroundColor: teamColor }}
            aria-hidden="true"
          >
            <Icon name="sports_hockey" className="text-[26px]" aria-hidden="true" />
          </div>

          <div className="flex-1 min-w-0">
            {/* 팀명 + age + gender — 팀명 17px (참고 동일) */}
            <div className="flex items-center gap-1.5 mb-1 flex-wrap">
              <h3 className="text-[17px] font-extrabold text-wtext-1 dark:text-white tracking-[-0.03em] truncate">
                {team.name ?? '팀명 미지정'}
              </h3>
              {division && (
                <span
                  className="px-1.5 py-0.5 rounded text-[10px] font-extrabold tracking-[0.02em] shrink-0"
                  style={{ color: teamColor, backgroundColor: `${teamColor}18` }}
                >
                  {division}
                </span>
              )}
              <span className="px-1.5 py-0.5 rounded bg-wline-2 dark:bg-rink-700 text-[10px] font-extrabold tracking-[0.04em] text-wtext-3 dark:text-wtext-4 shrink-0">
                {gender}
              </span>
            </div>
            {/* 인원수 + 승무패 record */}
            <div className="flex items-center gap-1.5 text-[11px] text-wtext-3 dark:text-wtext-4 min-w-0">
              <span className="font-bold text-wtext-2 dark:text-wtext-4 tabular-nums shrink-0">
                {memberCount}명
              </span>
              <span aria-hidden="true">·</span>
              <span className="tabular-nums">
                {record.w}승 {record.l}패 {record.d}무
              </span>
            </div>
          </div>

          {/* 상세 이동 표시 */}
          <span
            className="w-8 h-8 inline-flex items-center justify-center text-wtext-3 dark:text-wtext-4 shrink-0"
            aria-hidden="true"
          >
            <Icon name="chevron_right" className="text-[28px]" aria-hidden="true" />
          </span>
        </div>

        {/* 다음 일정 인라인 배너 — urgent 시 팀 컬러 alpha / 평상시 wbg 토큰 (다크 대응) */}
        <div
          className={cn(
            'mx-4 mb-3 px-3 py-2.5 rounded-xl flex items-center gap-2.5 border',
            !next?.urgent && 'bg-wbg dark:bg-rink-900/40 border-wline-2 dark:border-rink-700',
          )}
          style={
            next?.urgent
              ? { borderColor: `${teamColor}30`, backgroundColor: `${teamColor}10` }
              : undefined
          }
        >
          {/* 좌측 8x8 캘린더 박스 */}
          <div
            className={cn(
              'w-8 h-8 rounded-[10px] flex items-center justify-center shrink-0',
              !next?.urgent && 'bg-wsurface dark:bg-rink-800 border border-wline-2 dark:border-rink-700 text-wtext-2 dark:text-wtext-4',
            )}
            style={
              next?.urgent
                ? { backgroundColor: teamColor, color: '#ffffff' }
                : undefined
            }
            aria-hidden="true"
          >
            <Icon name="calendar_today" className="text-[14px]" aria-hidden="true" />
          </div>

          <div className="flex-1 min-w-0">
            {next ? (
              <>
                <div className="flex items-center gap-1.5">
                  <span
                    className="text-[10px] font-extrabold px-1.5 py-0.5 rounded"
                    style={{
                      color: next.type === '경기' ? '#ff5a36' : teamColor,
                      backgroundColor: next.type === '경기' ? '#fee4dc' : `${teamColor}18`,
                    }}
                  >
                    {next.type}
                  </span>
                  <span className="text-[12px] font-bold text-wtext-1 dark:text-white tabular-nums">
                    {next.date} {next.time}
                  </span>
                </div>
                <div className="text-[11px] text-wtext-3 dark:text-wtext-4 mt-0.5 truncate">
                  {next.place}
                </div>
              </>
            ) : (
              <>
                <div className="text-[12px] font-bold text-wtext-2 dark:text-wtext-4">
                  예정된 일정 없음
                </div>
                <div className="text-[11px] text-wtext-3 dark:text-wtext-4 truncate">
                  새 일정을 등록해 팀에 알려주세요
                </div>
              </>
            )}
          </div>

          {next?.urgent && (
            <span
              className="px-2 py-1 rounded-md text-[10px] font-extrabold tracking-[0.02em] text-white shrink-0"
              style={{ backgroundColor: teamColor }}
            >
              오늘
            </span>
          )}
        </div>

        {/* 출석률 + 아바타 그룹 + 빠른 액션 — 참고 패딩: "12px 16px 14px" */}
        <div className="px-4 pt-3 pb-3.5">
          {/* 아바타 스택 + 출석률 진행바 — marginBottom 12 */}
          <div className="flex items-center gap-2.5 mb-3">
            <div className="flex items-center shrink-0" aria-hidden="true">
              {avatarColors.slice(0, visibleAvatars).map((c, i) => (
                <span
                  key={i}
                  className="w-[22px] h-[22px] rounded-full border-2 border-wsurface dark:border-rink-800"
                  style={{
                    backgroundColor: c,
                    marginLeft: i === 0 ? 0 : -8,
                  }}
                />
              ))}
              {overflow > 0 && (
                <span
                  className="min-w-[22px] h-[22px] rounded-full border-2 border-wsurface dark:border-rink-800 bg-wline-2 dark:bg-rink-700 inline-flex items-center justify-center text-[9px] font-extrabold text-wtext-2 dark:text-wtext-4 px-1"
                  style={{ marginLeft: -8 }}
                >
                  +{overflow}
                </span>
              )}
            </div>
            <div className="flex-1 min-w-0">
              <div className="flex items-baseline justify-between mb-1">
                <span className="text-[10px] font-bold uppercase tracking-[0.04em] text-wtext-3 dark:text-wtext-4">
                  최근 출석률
                </span>
                <span className="text-[12px] font-extrabold text-wtext-1 dark:text-white tabular-nums">
                  {hasAttendance ? `${attendance}%` : '—'}
                </span>
              </div>
              <div className="h-1 rounded-[2px] bg-wline-2 dark:bg-rink-700 overflow-hidden">
                <div
                  className="h-full rounded-[2px]"
                  style={{
                    width: `${hasAttendance ? attendance : 0}%`,
                    backgroundColor: teamColor,
                  }}
                  aria-hidden="true"
                />
              </div>
            </div>
          </div>

          {/* 빠른 액션 3종 — 36px 사각 보더 칩 (라인업 / 통계 / 채팅) */}
          <div className="flex gap-1.5">
            {[
              { l: '라인업', icon: 'list_alt' },
              { l: '통계',   icon: 'bar_chart' },
              { l: '채팅',   icon: 'chat_bubble_outline', badge: pending },
            ].map((a) => (
              <span
                key={a.l}
                className="relative flex-1 h-9 rounded-[10px] bg-wbg dark:bg-rink-900/40 border border-wline-2 dark:border-rink-700 inline-flex items-center justify-center gap-1.5 text-[11px] font-bold text-wtext-2 dark:text-wtext-4 select-none"
              >
                <Icon name={a.icon} className="text-[14px]" aria-hidden="true" />
                {a.l}
                {/* 채팅 pending 배지 — flame-500 빨간 동그라미 (count > 0) */}
                {'badge' in a && (a.badge ?? 0) > 0 && (
                  <span className="absolute top-1 right-1.5 min-w-[14px] h-[14px] px-1 rounded-full bg-[#ff5a36] text-white text-[9px] font-extrabold inline-flex items-center justify-center">
                    {a.badge}
                  </span>
                )}
              </span>
            ))}
          </div>
        </div>
      </button>

      {/* 가입 신청 footer — pending > 0 일 때만 표시 (조건부) */}
      {pending > 0 && (
        <div className="border-t border-wline-2 dark:border-rink-700 bg-wbg dark:bg-rink-900/40 px-4 py-2.5 flex items-center gap-2">
          <span className="w-6 h-6 rounded-full bg-[#fee4dc] dark:bg-[#ff5a36]/15 text-[#ff5a36] inline-flex items-center justify-center text-[12px] font-extrabold shrink-0" aria-hidden="true">
            !
          </span>
          <span className="flex-1 text-[11px] font-semibold text-wtext-2 dark:text-wtext-4">
            가입 신청 <span className="font-extrabold text-[#ff5a36]">{pending}건</span> 승인 대기
          </span>
          <span className="text-[11px] font-bold text-ice-500 shrink-0">처리 →</span>
        </div>
      )}
    </article>
  );
}

// ─── Sub Components ──────────────────────────────────────
// (2026-04-12) 레거시 inline TeamCard / ParentTeamCard 는 `@/components/team/TeamListCard` 로 이관.
// 이 페이지는 공통 컴포넌트만 임포트하여 렌더링 로직을 위임한다.

function ErrorView({
  message,
  onRetry,
}: {
  message: string;
  onRetry: () => void;
}) {
  return (
    <div className="flex flex-col items-center gap-3 py-10 text-center">
      <div className="flex size-20 items-center justify-center rounded-w-pill bg-flame-100 dark:bg-flame-500/15">
        <Icon
          name="error_outline"
          className="text-[36px] text-flame-500 dark:text-flame-500"
          aria-hidden="true"
        />
      </div>
      <p className="text-w-small font-bold text-wtext-1 dark:text-white">
        {message}
      </p>
      <button
        type="button"
        onClick={onRetry}
        className="mt-2 rounded-w-md border border-ice-500 bg-wsurface px-4 py-2 text-w-small font-bold text-ice-500 transition-colors duration-200 ease-wallet motion-reduce:transition-none hover:bg-ice-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ice-500/30 dark:bg-rink-800 dark:hover:bg-ice-500/15"
      >
        {MESSAGES.dashboard.errorRetry}
      </button>
    </div>
  );
}

// ─── 학부모 전용 섹션 헤더 ────────────────────────────
function SectionHeader({
  icon,
  title,
  hint,
  count,
}: {
  icon: string;
  title: string;
  hint?: string;
  count: number;
}) {
  return (
    <header className="flex items-start gap-3 px-1">
      <div
        className="flex size-10 shrink-0 items-center justify-center rounded-w-md bg-ice-50 text-ice-500 dark:bg-ice-500/15"
        aria-hidden="true"
      >
        <Icon name={icon} className="text-[22px]" />
      </div>
      <div className="flex-1">
        <div className="flex items-center gap-2">
          <h2 className="text-w-body-lg font-bold text-wtext-1 dark:text-white">
            {title}
          </h2>
          <span
            className="inline-flex items-center justify-center rounded-w-pill bg-wline-2 px-2 py-0.5 text-[11px] font-bold font-num tabular-nums text-wtext-2 dark:bg-rink-700 dark:text-wtext-4"
            aria-label={MESSAGES.team.teamCountLabel(count)}
          >
            {count}
          </span>
        </div>
        {hint && (
          <p className="mt-0.5 text-w-caption text-wtext-3 dark:text-wtext-4">
            {hint}
          </p>
        )}
      </div>
    </header>
  );
}

// ─── 학부모 "우리 아이 팀" 카드 ───────────────────────
// (2026-04-12) ParentTeamCard 는 TeamListCard(highlight=true) + footerSlot 으로 대체.
// ChildChip 은 footerSlot 내부에서만 사용되므로 이 파일에 남겨둔다.

function ChildChip({ child }: { child: MyChildInTeam }) {
  const name = child.playerName ?? MESSAGES.team.defaultChildName;
  const jersey =
    child.jerseyNumber != null
      ? MESSAGES.team.jerseyLabel(child.jerseyNumber)
      : MESSAGES.team.jerseyUnassigned;
  const position = child.position
    ? child.position === "goalie"
      ? MESSAGES.team.positionGoalie
      : child.position === "defense"
        ? MESSAGES.team.positionDefense
        : MESSAGES.team.positionForward
    : null;

  return (
    <span
      className="inline-flex items-center gap-1.5 rounded-w-pill border border-ice-500/30 bg-ice-50 px-3 py-1 text-[11px] font-bold text-ice-500 dark:border-ice-500/40 dark:bg-ice-500/15 dark:text-ice-500"
      aria-label={`${name}, ${jersey}${position ? `, ${position}` : ""}`}
    >
      <Icon name="face" className="text-[14px]" aria-hidden="true" />
      <span className="font-bold">{name}</span>
      <span className="text-wtext-3 dark:text-wtext-4">·</span>
      <span className="font-num tabular-nums">{jersey}</span>
      {position && (
        <>
          <span className="text-wtext-3 dark:text-wtext-4">·</span>
          <span>{position}</span>
        </>
      )}
      {child.isCaptain && (
        <span className="ml-1 rounded-w-pill bg-sun-500 px-1.5 py-0.5 text-[9px] font-extrabold text-rink-900">
          C
        </span>
      )}
      {child.isAltCaptain && !child.isCaptain && (
        <span className="ml-1 rounded-w-pill bg-sun-100 px-1.5 py-0.5 text-[9px] font-extrabold text-sun-500">
          A
        </span>
      )}
    </span>
  );
}
