# TEAMPLUS Web - Environment Variables
# 이 파일을 복사하여 .env.local 로 저장하고 실제 값을 입력하세요.
#
# ─── 로컬 개발 시나리오 가이드 ─────────────────────────────
# [A] Full Local (Backend 도 로컬에서 실행) — 기본값
#     → 아래 NEXT_PUBLIC_API_URL 을 localhost:5003 으로 둔다.
# [B] Remote Backend (공용 개발서버 사용)
#     → NEXT_PUBLIC_API_URL 을 http://<서버IP>:5003 으로 덮어쓴다.
#     → CSP 는 next.config.js 가 호스트를 자동 허용 목록에 추가한다.
# ─────────────────────────────────────────────────────────

# API URL — 백엔드 서버 주소 (시나리오 A 기본값, backend=5003)
NEXT_PUBLIC_API_URL=http://localhost:5003

# WebSocket URL — Socket.io 서버 주소 (기본: API URL 과 동일 호스트)
# 미설정 시 NEXT_PUBLIC_API_URL 을 사용한다.
NEXT_PUBLIC_WS_URL=http://localhost:5003

# E2E 암호화 키 (32 bytes hex)
NEXT_PUBLIC_CRYPTO_SECRET_KEY=your-secret-key-here

# 카카오 JavaScript SDK 키 — SNS 공유 시트의 카카오톡 공유 버튼에 사용
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# 미설정 시 카카오톡 버튼은 비활성화되며, 페이스북·X·링크 복사는 정상 동작.
# 자세한 설정 가이드: docs/Guides/KAKAO_SHARE_SETUP.md
NEXT_PUBLIC_KAKAO_JS_KEY=

# ─── App Store / Play Store ───────────────────────────────
# /get-app 설치 안내 페이지, 상단 AppInstallBanner, deeplink fallback 에서 사용.
# iOS App Store 숫자 ID (App Store Connect → 앱 정보 → Apple ID). 미설정 시 검색 fallback.
NEXT_PUBLIC_IOS_APP_STORE_ID=
# Android Play Store 패키지명. teamplus-app/android/app/build.gradle 의 applicationId 와 동일해야 한다.
NEXT_PUBLIC_ANDROID_PACKAGE_NAME=kr.co.teamplus.app

# ─── 딥링크 (Universal Links / App Links) ──────────────────
# iOS Universal Links 용 Apple Team ID. 미설정 시 코드 기본값 VG2U99V32J(TEAMPLUS 프로덕션)로
# AASA 가 서빙되므로 별도 주입 없이도 동작한다. 다른 팀/빌드 재사용 시에만 이 값으로 오버라이드.
NEXT_PUBLIC_IOS_TEAM_ID=VG2U99V32J
# iOS 번들 ID — Xcode PRODUCT_BUNDLE_IDENTIFIER 와 정확히 일치해야 한다(불일치 시 Universal Links 미동작).
NEXT_PUBLIC_IOS_BUNDLE_ID=kr.co.teamplus
# Android App Links 서명 지문(콤마 구분 · debug/release/upload 키 모두 등록 가능).
# Play Console > 앱 무결성 > 앱 서명 > SHA-256 인증서 지문. 미설정 시 assetlinks 가 빈 배열로 서빙되어 autoVerify 실패.
NEXT_PUBLIC_ANDROID_SHA256_FINGERPRINTS=

# Sentry 에러 트래킹 (프로덕션용)
# https://sentry.io에서 프로젝트 생성 후 DSN 값을 입력하세요.
# 활성화 조건: SENTRY_DSN + NEXT_PUBLIC_SENTRY_ENABLED=true 모두 필요.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENABLED=false
# 긴급 비활성화 스위치 — true 시 DSN이 있어도 비활성화
SENTRY_DISABLED=false

# Sentry 조직 및 프로젝트 (소스맵 업로드용)
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=teamplus-web

# Sentry Auth Token (소스맵 업로드용)
# https://sentry.io/settings/auth-tokens/ 에서 생성
SENTRY_AUTH_TOKEN=


# ─── 로그 디렉토리 (선택) ──────────────────────────────────────────────────
# 미설정 시: process.cwd()/log (앱 폴더 내부)
# 운영 권장 : 앱 폴더 외부에 두어 deploy reset/clone 영향 차단.
# 예) backend → /kcs-project/logs/backend
#     web     → /kcs-project/logs/web
#     admin   → /kcs-project/logs/admin
#     home    → /kcs-project/logs/home
# LOG_ROOT=
