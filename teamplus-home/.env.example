# TEAMPLUS Home — 환경변수 예시 (.env.local 로 복사 후 실제 값 주입)

# SQLite DB 파일 경로 (prisma 기준 상대 경로 — prisma/ 디렉토리에서 출발)
DATABASE_URL="file:../data/notices.db"

# 관리자 로그인 비밀번호 (운영 시 강한 비밀번호로 교체)
ADMIN_PASSWORD="change-me-in-production"

# JWT 쿠키 서명용 비밀키 (openssl rand -base64 48 로 생성)
JWT_SECRET="change-me-openssl-rand-base64-48"
